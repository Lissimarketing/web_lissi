---
// src/pages/recursos/decodificador.astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

// La base de datos vive en un archivo aparte y editable: src/data/codigos-error.json
// Para agregar o corregir codigos, edita SOLO ese archivo. No toques este.
import dbData from '../../data/codigos-error.json';

const SIGNUP_URL = "https://app.lissi.app/signup";

const marcas = Object.keys(dbData.marcas);
const ultimaActualizacion = dbData._meta.ultimaActualizacion;
---
<Layout title="Buscador de Códigos de Error HVAC | Lissi">
  <Navbar />

  <main class="relative bg-[#0A0F1C] min-h-screen pt-28 pb-24 font-sans selection:bg-violet-500/30 overflow-hidden">

    <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-violet-900/15 to-transparent pointer-events-none"></div>
    <div class="absolute top-1/4 -right-40 w-[500px] h-[500px] bg-violet-600/10 rounded-full blur-[150px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 relative z-10">

      <a href="/recursos" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-violet-400 transition-colors group mb-10">
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Volver a Recursos
      </a>

      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 mb-6">
          <svg class="w-3.5 h-3.5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <span class="font-mono text-[10px] font-bold uppercase tracking-widest text-violet-300">Base técnica verificada</span>
        </div>

        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tight leading-[1.1] mb-5">
          Códigos de error<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-fuchsia-500">HVAC en terreno</span>
        </h1>

        <p class="text-slate-400 text-base md:text-lg leading-relaxed max-w-2xl mx-auto">
          Haz clic en el buscador para desplegar los códigos. Filtra por marca o escribe el código del display.
        </p>
      </div>

      <!-- BUSCADOR + DESPLEGABLE -->
      <div class="relative mb-4 z-30">
        <div class="w-full bg-slate-900/60 rounded-3xl border border-slate-700/70 shadow-[0_20px_50px_rgba(0,0,0,0.4)] p-2 backdrop-blur-xl flex flex-col sm:flex-row items-stretch gap-2 transition-all focus-within:border-violet-500/50">
          <div class="relative w-full sm:w-56 shrink-0">
            <select id="brand-select" class="w-full h-full appearance-none bg-[#0A0F1C] sm:bg-transparent border border-slate-700 sm:border-transparent rounded-2xl pl-5 pr-10 py-4 font-display text-base font-bold text-white cursor-pointer focus:outline-none">
              <option value="">Todas las marcas</option>
              {marcas.map((m) => <option value={m}>{m}</option>)}
            </select>
            <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </div>

          <div class="hidden sm:block w-px bg-slate-700 my-2"></div>

          <div class="flex-1 flex items-center bg-[#0A0F1C] sm:bg-transparent rounded-2xl border border-slate-700 sm:border-transparent px-4 py-1">
            <svg class="w-5 h-5 text-slate-500 shrink-0 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input type="text" id="error-input" placeholder="Haz clic para ver los códigos…" class="w-full bg-transparent border-0 outline-none text-white font-display text-lg font-bold uppercase placeholder-slate-600 placeholder:normal-case placeholder:font-medium" autocomplete="off" autocorrect="off" spellcheck="false" style="font-size:16px;">
          </div>

          <button id="search-btn" class="shrink-0 bg-violet-600 hover:bg-violet-500 disabled:opacity-40 disabled:cursor-not-allowed text-white rounded-2xl px-8 py-4 font-bold text-sm transition-colors">Buscar</button>
        </div>

        <!-- DESPLEGABLE de códigos (overlay, no empuja el contenido) -->
        <div id="code-dropdown" class="hidden absolute left-0 right-0 top-[calc(100%+8px)] z-50 bg-[#0A0F1C]/95 backdrop-blur-xl border border-slate-700/80 rounded-2xl shadow-[0_24px_50px_rgba(0,0,0,0.6)] overflow-hidden">
          <div id="dropdown-header" class="px-4 py-2.5 text-[10px] uppercase tracking-widest text-slate-500 font-bold border-b border-slate-800 bg-slate-900/40 sticky top-0"></div>
          <div id="dropdown-list" class="max-h-[340px] overflow-y-auto"></div>
        </div>
      </div>

      <!-- Nota del sistema de códigos de la marca -->
      <div id="brand-note" class="hidden mb-8 rounded-xl bg-slate-900/60 border border-slate-800 p-3.5">
        <p class="text-[11px] text-slate-400 leading-relaxed"><span id="brand-note-text"></span></p>
      </div>

      <!-- RESULTADOS -->
      <div id="results-area" class="relative min-h-[200px]">

        <div id="state-empty" class="flex flex-col items-center justify-center text-center py-12">
          <div class="w-16 h-16 mb-5 rounded-full bg-slate-900/50 border border-slate-800 flex items-center justify-center">
            <svg class="w-7 h-7 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <p class="text-slate-500 px-4">Haz clic en el buscador y elige un código para ver el diagnóstico.</p>
        </div>

        <div id="state-result" class="hidden">
          <div class="bg-slate-900/80 rounded-3xl border border-slate-700/70 shadow-[0_30px_60px_rgba(0,0,0,0.4)] overflow-hidden backdrop-blur-xl">

            <div class="p-6 md:p-7 border-b border-slate-800 bg-[#0A0F1C]/40 relative overflow-hidden">
              <div id="result-glow" class="absolute top-0 right-0 w-56 h-56 rounded-full blur-[80px] pointer-events-none"></div>
              <div class="relative flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div class="flex items-center gap-4 min-w-0">
                  <div id="result-box-icon" class="w-16 h-16 shrink-0 rounded-2xl bg-[#0A0F1C] border-2 flex items-center justify-center px-1">
                    <span id="result-code" class="font-display text-lg font-black text-center leading-none">E4</span>
                  </div>
                  <div class="min-w-0">
                    <span id="result-brand" class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1 block">MARCA</span>
                    <h2 id="result-title" class="font-display text-xl md:text-2xl font-bold text-white leading-tight">Título</h2>
                  </div>
                </div>
                <div id="result-pill" class="flex items-center gap-2 px-4 py-2 rounded-full shrink-0 self-start sm:self-center">
                  <span id="result-pill-dot" class="w-2 h-2 rounded-full"></span>
                  <span id="result-pill-text" class="font-mono text-[10px] font-bold uppercase tracking-widest">Severidad</span>
                </div>
              </div>
            </div>

            <div class="p-6 md:p-7">

              <!-- Modelos / Serie a los que aplica este código -->
              <div id="models-section" class="hidden mb-6">
                <h3 class="font-mono text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-2.5">Aplica a</h3>
                <div id="result-models" class="flex flex-wrap gap-2"></div>
                <p class="text-[10px] text-slate-600 mt-2 leading-relaxed">Los chips en violeta son <strong class="text-slate-500">modelos confirmados en manual</strong>; los grises son la serie/familia donde aplica.</p>
              </div>

              <div class="mb-6">
                <h3 class="font-mono text-[10px] uppercase tracking-widest text-violet-400 font-bold mb-2">Qué significa</h3>
                <p id="result-desc" class="text-slate-300 leading-relaxed text-sm md:text-base"></p>
              </div>

              <div id="causes-section" class="mb-6">
                <h3 class="font-mono text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-3">Causas probables</h3>
                <ul id="result-causes" class="flex flex-wrap gap-2"></ul>
              </div>

              <div id="safety-warning" class="hidden mb-6 rounded-xl bg-rose-500/5 border border-rose-500/20 p-3.5">
                <div class="flex gap-3">
                  <svg class="w-5 h-5 text-rose-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                  <p class="text-xs text-rose-200/80 leading-relaxed"><strong class="text-rose-200">Riesgo eléctrico.</strong> Algunos pasos requieren mediciones con tensión presente. Solo personal capacitado, con EPP y herramientas adecuadas. Ante duda, corta energía desde el tablero.</p>
                </div>
              </div>

              <div class="bg-[#0A0F1C]/60 rounded-2xl border border-slate-800 p-5 md:p-6 mb-6">
                <h3 class="font-mono text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-5">Pasos de revisión sugeridos</h3>
                <ul id="result-steps" class="space-y-4"></ul>
              </div>

              <!-- Fuente + confianza -->
              <div id="result-meta" class="flex flex-wrap items-center gap-2 mb-6 text-[11px]">
                <span id="result-confianza" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md font-mono font-bold"></span>
                <span id="result-fuente" class="font-mono text-slate-500"></span>
              </div>

              <div class="rounded-xl bg-amber-500/5 border border-amber-500/20 p-3.5 mb-6">
                <p class="text-[11px] text-amber-200/80 leading-relaxed">
                  <strong class="text-amber-200">Importante:</strong> los códigos de error varían según modelo y serie del equipo. Esta información es orientativa. <strong class="text-amber-200">Verifica siempre el manual de servicio del modelo específico</strong> antes de intervenir.
                </p>
              </div>

              <div class="bg-gradient-to-r from-violet-900/30 to-fuchsia-900/30 rounded-2xl border border-violet-500/30 p-5 md:p-6 flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="flex-1 text-center md:text-left">
                  <h4 class="font-bold text-white text-base mb-1">¿Registras esta falla?</h4>
                  <p class="text-xs sm:text-sm text-violet-200/70 leading-relaxed">Guarda el diagnóstico en la bitácora del equipo y envíaselo a tu cliente con Lissi.</p>
                </div>
                <a href={SIGNUP_URL} class="w-full md:w-auto shrink-0 px-7 py-3 rounded-xl bg-white text-[#0A0F1C] text-xs font-bold uppercase tracking-wider hover:bg-violet-50 transition-all text-center">Probar Lissi gratis</a>
              </div>
            </div>
          </div>
        </div>

      </div>

      <p class="text-center font-mono text-[10px] text-slate-600 mt-8">Base actualizada al {ultimaActualizacion} · Información de referencia en construcción</p>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  input[type="text"] { font-size: 16px; }
  #brand-select option { background: #0A0F1C; color: white; }
  #dropdown-list::-webkit-scrollbar { width: 8px; }
  #dropdown-list::-webkit-scrollbar-thumb { background: #334155; border-radius: 8px; }
  #dropdown-list::-webkit-scrollbar-track { background: transparent; }
</style>

<script is:inline define:vars={{ DB: dbData.marcas }}>
  const GENERIC = {
    titulo: "Código no disponible en la base verificada",
    significado: "No tenemos este código confirmado para esta marca en nuestra base. Para no darte información incorrecta, abajo tienes los pasos generales seguros y dónde encontrar el significado exacto.",
    severidad: "desconocido", elec: false, serie: [], modelos: [],
    causas: ["Requiere manual del modelo específico"],
    pasos: [
      "Identifica el modelo exacto en la placa de características de la unidad (interior y exterior).",
      "Busca el manual de servicio de ese modelo en el sitio oficial del fabricante.",
      "Observa si hay un patrón de parpadeo en los LED de la PCB: muchos equipos codifican la falla en los parpadeos.",
      "Como prueba inicial segura, corta energía desde el tablero por 5 minutos y reinicia: descarta fallas transitorias.",
    ],
    fuente: "—", confianza: "—",
  };

  const SEV = {
    sensor:       { label: "Falla de sensor", color: "amber" },
    comunicacion: { label: "Comunicación / eléctrico", color: "amber" },
    refrigerante: { label: "Refrigerante", color: "rose" },
    proteccion:   { label: "Protección crítica", color: "rose" },
    desconocido:  { label: "Verificación manual", color: "slate" },
  };
  const COLORS = {
    rose:  { text: "text-rose-400", border: "border-rose-500/50", glow: "bg-rose-500/10", pillBg: "bg-rose-500/10 border-rose-500/20", dot: "bg-rose-500" },
    amber: { text: "text-amber-400", border: "border-amber-500/50", glow: "bg-amber-500/10", pillBg: "bg-amber-500/10 border-amber-500/20", dot: "bg-amber-500" },
    slate: { text: "text-slate-400", border: "border-slate-600/50", glow: "bg-slate-500/10", pillBg: "bg-slate-800 border-slate-700", dot: "bg-slate-500" },
  };
  const DOT = { sensor: "bg-amber-500", comunicacion: "bg-amber-500", refrigerante: "bg-rose-500", proteccion: "bg-rose-500", desconocido: "bg-slate-500" };

  const brandSelect = document.getElementById('brand-select');
  const errorInput = document.getElementById('error-input');
  const searchBtn = document.getElementById('search-btn');
  const stateEmpty = document.getElementById('state-empty');
  const stateResult = document.getElementById('state-result');
  const brandNote = document.getElementById('brand-note');
  const brandNoteText = document.getElementById('brand-note-text');
  const dropdown = document.getElementById('code-dropdown');
  const dropdownList = document.getElementById('dropdown-list');
  const dropdownHeader = document.getElementById('dropdown-header');

  function esc(s) { return String(s).replace(/[&<>"]/g, (ch) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[ch])); }

  const ALL = [];
  Object.keys(DB).forEach((brand) => {
    const cods = DB[brand].codigos || {};
    Object.keys(cods).forEach((code) => {
      ALL.push({ brand, code, titulo: cods[code].titulo, sev: cods[code].severidad });
    });
  });

  function updateButton() { searchBtn.disabled = !errorInput.value.trim(); }

  function onBrandChange() {
    const marca = DB[brandSelect.value];
    if (marca && marca.nota) { brandNote.classList.remove('hidden'); brandNoteText.textContent = marca.nota; }
    else { brandNote.classList.add('hidden'); }
  }

  let dropOpen = false, dropItems = [], dropActive = -1;
  function openDropdown() { dropOpen = true; renderDropdown(); dropdown.classList.remove('hidden'); }
  function closeDropdown() { dropOpen = false; dropdown.classList.add('hidden'); dropActive = -1; }

  function renderDropdown() {
    const brand = brandSelect.value;
    const term = errorInput.value.trim().toUpperCase();
    let list = ALL;
    if (brand) list = list.filter((x) => x.brand === brand);
    if (term) list = list.filter((x) => x.code.toUpperCase().includes(term) || x.brand.toUpperCase().includes(term));
    list = list.slice().sort((a, b) => {
      if (term) {
        const ap = a.code.toUpperCase().startsWith(term) ? 0 : 1;
        const bp = b.code.toUpperCase().startsWith(term) ? 0 : 1;
        if (ap !== bp) return ap - bp;
      }
      if (a.brand !== b.brand) return a.brand.localeCompare(b.brand);
      return a.code.localeCompare(b.code);
    });
    dropItems = list; dropActive = -1;

    dropdownHeader.textContent = brand
      ? `Códigos de ${brand} (${list.length})`
      : `Todos los códigos (${list.length}) · escribe o elige una marca para filtrar`;

    if (list.length === 0) {
      dropdownList.innerHTML = '<div class="px-4 py-6 text-center text-slate-600 text-sm">Sin coincidencias</div>';
      return;
    }
    dropdownList.innerHTML = list.map((x, i) =>
      `<button type="button" data-i="${i}" class="drop-row w-full flex items-center justify-between gap-3 px-4 py-2.5 text-left hover:bg-violet-500/10 transition-colors border-b border-slate-800/40 last:border-0">
         <span class="flex items-center gap-2.5 min-w-0">
           <span class="font-mono font-bold text-sm text-violet-300 w-16 shrink-0">${esc(x.code)}</span>
           <span class="w-1.5 h-1.5 rounded-full ${DOT[x.sev] || 'bg-slate-500'} shrink-0"></span>
           <span class="text-xs text-slate-400 truncate">${esc(x.titulo)}</span>
         </span>
         <span class="font-mono text-[11px] text-slate-500 shrink-0">${esc(x.brand)}</span>
       </button>`
    ).join('');
    dropdownList.querySelectorAll('.drop-row').forEach((el) => {
      el.addEventListener('click', () => pickRow(parseInt(el.dataset.i)));
    });
  }

  function paintActive(rows) {
    rows.forEach((el, i) => el.classList.toggle('bg-violet-500/10', i === dropActive));
    if (rows[dropActive]) rows[dropActive].scrollIntoView({ block: 'nearest' });
  }

  function pickRow(i) {
    const x = dropItems[i];
    if (!x) return;
    brandSelect.value = x.brand;
    errorInput.value = x.code;
    onBrandChange(); updateButton(); closeDropdown(); executeSearch();
  }

  function executeSearch() {
    const brand = brandSelect.value;
    const code = errorInput.value.trim().toUpperCase();
    if (!code) return;
    let useBrand = brand, data = null;
    if (brand && DB[brand]) {
      const key = Object.keys(DB[brand].codigos).find((k) => k.toUpperCase() === code);
      if (key) data = DB[brand].codigos[key];
    } else {
      for (const b of Object.keys(DB)) {
        const key = Object.keys(DB[b].codigos).find((k) => k.toUpperCase() === code);
        if (key) { useBrand = b; data = DB[b].codigos[key]; break; }
      }
    }
    renderResult(useBrand || "—", code, data || GENERIC);
  }

  function renderResult(brand, code, data) {
    const sev = SEV[data.severidad] || SEV.desconocido;
    const c = COLORS[sev.color];

    const codeEl = document.getElementById('result-code');
    codeEl.textContent = code;
    codeEl.className = `font-display text-lg font-black text-center leading-none ${c.text}`;
    document.getElementById('result-brand').textContent = brand;
    document.getElementById('result-title').textContent = data.titulo;
    document.getElementById('result-desc').textContent = data.significado;

    document.getElementById('result-box-icon').className = `w-16 h-16 shrink-0 rounded-2xl bg-[#0A0F1C] border-2 ${c.border} flex items-center justify-center px-1`;
    document.getElementById('result-glow').className = `absolute top-0 right-0 w-56 h-56 rounded-full blur-[80px] pointer-events-none ${c.glow}`;
    document.getElementById('result-pill').className = `flex items-center gap-2 px-4 py-2 rounded-full shrink-0 self-start sm:self-center border ${c.pillBg}`;
    document.getElementById('result-pill-dot').className = `w-2 h-2 rounded-full ${c.dot}`;
    const pillText = document.getElementById('result-pill-text');
    pillText.textContent = sev.label;
    pillText.className = `font-mono text-[10px] font-bold uppercase tracking-widest ${c.text}`;

    const modelsSection = document.getElementById('models-section');
    const modelsEl = document.getElementById('result-models');
    modelsEl.innerHTML = '';
    const series = data.serie || [];
    const modelos = data.modelos || [];
    if (series.length || modelos.length) {
      modelsSection.classList.remove('hidden');
      modelos.forEach((m) => {
        const chip = document.createElement('span');
        chip.className = 'px-2.5 py-1 rounded-md bg-violet-500/10 border border-violet-500/40 text-[11px] font-mono font-bold text-violet-300';
        chip.textContent = m; modelsEl.appendChild(chip);
      });
      series.forEach((s) => {
        const chip = document.createElement('span');
        chip.className = 'px-2.5 py-1 rounded-md bg-slate-800/60 border border-slate-700 text-[11px] font-mono text-slate-300';
        chip.textContent = s; modelsEl.appendChild(chip);
      });
    } else { modelsSection.classList.add('hidden'); }

    const causesEl = document.getElementById('result-causes');
    causesEl.innerHTML = '';
    (data.causas || []).forEach((cause) => {
      const li = document.createElement('li');
      li.className = 'px-3 py-1.5 rounded-lg bg-slate-800/60 border border-slate-700 text-xs text-slate-300';
      li.textContent = cause; causesEl.appendChild(li);
    });

    document.getElementById('safety-warning').classList.toggle('hidden', !data.elec);

    const stepsEl = document.getElementById('result-steps');
    stepsEl.innerHTML = '';
    (data.pasos || []).forEach((step, i) => {
      const li = document.createElement('li');
      li.className = 'flex items-start gap-4 text-sm text-slate-300';
      li.innerHTML = `<div class="w-6 h-6 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center text-[10px] font-bold text-slate-400 shrink-0 mt-0.5">${i + 1}</div><span class="leading-relaxed flex-1"></span>`;
      li.querySelector('span').textContent = step; stepsEl.appendChild(li);
    });

    const confEl = document.getElementById('result-confianza');
    const fuenteEl = document.getElementById('result-fuente');
    if (data.confianza && data.confianza !== '—') {
      const isAlta = data.confianza === 'alta';
      confEl.textContent = isAlta ? '✓ Confianza alta' : '~ Confianza media';
      confEl.className = `inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md font-mono font-bold ${isAlta ? 'bg-emerald-500/10 text-emerald-400' : 'bg-amber-500/10 text-amber-400'}`;
      confEl.style.display = '';
    } else { confEl.style.display = 'none'; }
    fuenteEl.textContent = (data.fuente && data.fuente !== '—') ? `Fuente: ${data.fuente}` : '';

    stateEmpty.classList.add('hidden');
    stateResult.classList.remove('hidden');
  }

  errorInput.addEventListener('focus', openDropdown);
  errorInput.addEventListener('click', openDropdown);
  errorInput.addEventListener('input', () => { updateButton(); openDropdown(); });
  brandSelect.addEventListener('change', () => { onBrandChange(); updateButton(); if (dropOpen) renderDropdown(); });

  errorInput.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { closeDropdown(); errorInput.blur(); return; }
    if (e.key === 'Enter') {
      if (dropOpen && dropActive >= 0) { e.preventDefault(); pickRow(dropActive); return; }
      if (!searchBtn.disabled) { executeSearch(); closeDropdown(); }
      return;
    }
    if (!dropOpen) return;
    const rows = dropdownList.querySelectorAll('.drop-row');
    if (e.key === 'ArrowDown') { e.preventDefault(); dropActive = Math.min(dropActive + 1, rows.length - 1); paintActive(rows); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); dropActive = Math.max(dropActive - 1, 0); paintActive(rows); }
  });

  searchBtn.addEventListener('click', () => { executeSearch(); closeDropdown(); });
  document.addEventListener('click', (e) => {
    if (!dropdown.contains(e.target) && e.target !== errorInput) closeDropdown();
  });

  updateButton();
</script>