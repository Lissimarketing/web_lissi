---
// src/pages/recursos/calculadora-sobrecalentamiento.astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const SIGNUP_URL = "https://app.lissi.app/signup";

// Refrigerantes con datos P-T verificados de tablas de fabricantes.
// Fuentes: Hudson Technologies, Arkema Forane, Honeywell.
// Cada tabla: [°C, PSIG]. Interpolación lineal por tramos (válida al ±1°C entre puntos).
const refrigerantes = [
  { id: "R-410A", asn: "A1", gwp: 2088, type: "HFC blend (azeotrópico)", glide: 0, note: null },
  { id: "R-32",   asn: "A2L", gwp: 675, type: "HFC puro", glide: 0, note: "Levemente inflamable (A2L). Requiere herramientas certificadas." },
  { id: "R-22",   asn: "A1", gwp: 1810, type: "HCFC (en eliminación)", glide: 0, note: "Refrigerante en eliminación gradual por Protocolo de Montreal." },
  { id: "R-134a", asn: "A1", gwp: 1430, type: "HFC puro", glide: 0, note: null },
  { id: "R-404A", asn: "A1", gwp: 3922, type: "HFC blend (con glide)", glide: 0.7, note: "Mezcla zeotrópica con glide ~0.7°C. Valores calculados como bubble point." },
];
---
<Layout title="Cálculo de Sobrecalentamiento y Subenfriamiento | Lissi">
  <Navbar />

  <main class="relative bg-[#0A0F1C] min-h-screen pt-28 pb-24 font-sans selection:bg-cyan-500/30 overflow-hidden">

    <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-cyan-900/15 to-transparent pointer-events-none"></div>
    <div class="absolute top-1/3 -right-40 w-[500px] h-[500px] bg-cyan-600/10 rounded-full blur-[150px] pointer-events-none"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

      <a href="/recursos" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-cyan-400 transition-colors group mb-8">
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Volver a Recursos
      </a>

      <div class="grid lg:grid-cols-[5fr_7fr] gap-8 lg:gap-12 items-start">

        <!-- Columna izquierda: info -->
        <div class="lg:sticky lg:top-28">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 mb-6">
            <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
            <span class="font-mono text-[10px] font-bold uppercase tracking-widest text-cyan-300">Calculadora de terreno</span>
          </div>

          <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-black text-white tracking-tight leading-[1.05] mb-5">
            Sobrecalentamiento y<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">subenfriamiento</span>
          </h1>

          <p class="text-slate-400 text-base leading-relaxed mb-8 max-w-md">
            Diagnostica la carga de refrigerante con la precisión de las tablas técnicas estándar del rubro. Elige el gas, ingresa tus lecturas, y obtén la lectura al instante.
          </p>

          <div class="rounded-2xl bg-slate-900/60 border border-slate-800 p-5">
            <p class="font-mono text-[10px] uppercase tracking-widest text-cyan-400 font-bold mb-3">// Cómo se usa</p>
            <ol class="space-y-3 text-sm text-slate-400">
              <li class="flex gap-3"><span class="w-5 h-5 rounded-full bg-slate-800 flex items-center justify-center text-[10px] font-bold text-cyan-400 shrink-0 border border-slate-700">1</span><span>Elige el refrigerante del equipo.</span></li>
              <li class="flex gap-3"><span class="w-5 h-5 rounded-full bg-slate-800 flex items-center justify-center text-[10px] font-bold text-cyan-400 shrink-0 border border-slate-700">2</span><span>Ingresa presión y temperatura de la línea, o usa saturación directa si tu manómetro la entrega.</span></li>
              <li class="flex gap-3"><span class="w-5 h-5 rounded-full bg-slate-800 flex items-center justify-center text-[10px] font-bold text-cyan-400 shrink-0 border border-slate-700">3</span><span>Lee el resultado y compara con el rango sugerido por el fabricante.</span></li>
            </ol>
          </div>

          <div class="mt-5 rounded-2xl bg-amber-500/5 border border-amber-500/20 p-4">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M12 3l9 16H3l9-16z"/></svg>
              <p class="text-xs text-amber-200/80 leading-relaxed">
                <span class="font-semibold text-amber-200">Valores referenciales.</span> Tablas P-T basadas en datos publicados por fabricantes (Hudson Tech, Arkema). Para diagnóstico final, verifica siempre contra la placa del equipo y manual del fabricante.
              </p>
            </div>
          </div>
        </div>

        <!-- Columna derecha: calculadora -->
        <div class="bg-slate-900/80 rounded-3xl border border-slate-700/70 shadow-[0_20px_50px_rgba(0,0,0,0.4)] backdrop-blur-xl overflow-hidden">

          <!-- Tabs de modo -->
          <div class="p-3 border-b border-slate-800 bg-[#0A0F1C]/40">
            <div class="relative flex p-1 rounded-xl bg-[#030508] border border-slate-800">
              <div id="tab-slider" class="absolute top-1 bottom-1 left-1 w-[calc(33.333%-3px)] bg-slate-800 rounded-lg shadow transition-transform duration-300 ease-out z-0"></div>
              <button id="btn-sc" class="mode-btn relative z-10 flex-1 py-2.5 text-[11px] sm:text-xs font-bold text-white transition-colors uppercase tracking-wider px-1" data-mode="sc">Sobrecalentam.</button>
              <button id="btn-se" class="mode-btn relative z-10 flex-1 py-2.5 text-[11px] sm:text-xs font-bold text-slate-500 hover:text-slate-300 transition-colors uppercase tracking-wider px-1" data-mode="se">Subenfriam.</button>
              <button id="btn-sat" class="mode-btn relative z-10 flex-1 py-2.5 text-[11px] sm:text-xs font-bold text-slate-500 hover:text-slate-300 transition-colors uppercase tracking-wider px-1" data-mode="sat">T° Saturación</button>
            </div>
          </div>

          <div class="p-5 sm:p-7 md:p-8">

            <!-- Selector de gas + unidades -->
            <div class="grid sm:grid-cols-[1fr_auto] gap-4 mb-6">
              <div>
                <label for="gas-select" class="font-mono text-[10px] uppercase tracking-widest text-slate-400 font-bold block mb-2">Refrigerante</label>
                <div class="relative">
                  <select id="gas-select" class="w-full appearance-none bg-[#0A0F1C] border border-slate-700 hover:border-cyan-500/60 focus:border-cyan-500/80 focus:outline-none rounded-xl pl-4 pr-10 py-3.5 font-mono text-sm font-bold text-white tracking-wider cursor-pointer transition-colors">
                    {refrigerantes.map((r) => (
                      <option value={r.id}>{r.id} — {r.type}</option>
                    ))}
                  </select>
                  <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </div>
              </div>
              <div>
                <span class="font-mono text-[10px] uppercase tracking-widest text-slate-400 font-bold block mb-2">Unidades</span>
                <div class="flex gap-1 rounded-xl bg-[#030508] border border-slate-800 p-1">
                  <button id="unit-psig" class="unit-btn px-3 py-2 rounded-lg text-[11px] font-bold text-white bg-slate-800 transition-colors" data-unit="psig">PSIG · °C</button>
                  <button id="unit-bar" class="unit-btn px-3 py-2 rounded-lg text-[11px] font-bold text-slate-500 hover:text-slate-300 transition-colors" data-unit="bar">bar · °C</button>
                </div>
              </div>
            </div>

            <!-- Ficha del gas seleccionado -->
            <div id="gas-info" class="rounded-xl bg-[#0A0F1C]/60 border border-slate-800 p-3 mb-6 grid grid-cols-3 gap-3 text-center">
              <div><span class="font-mono text-[9px] uppercase text-slate-500 block">Clase</span><span id="gas-asn" class="text-sm font-bold text-white">A1</span></div>
              <div><span class="font-mono text-[9px] uppercase text-slate-500 block">GWP</span><span id="gas-gwp" class="text-sm font-bold text-white">2088</span></div>
              <div><span class="font-mono text-[9px] uppercase text-slate-500 block">Glide</span><span id="gas-glide" class="text-sm font-bold text-white">0°C</span></div>
            </div>
            <div id="gas-note" class="hidden -mt-3 mb-6 rounded-xl bg-amber-500/5 border border-amber-500/20 p-3 text-[11px] text-amber-200/80 leading-snug"></div>

            <!-- DISPLAY de resultado -->
            <div class="relative rounded-2xl bg-[#030508] border border-slate-800 p-6 md:p-7 mb-6 overflow-hidden">
              <div id="result-glow" class="absolute inset-0 transition-all duration-500 opacity-30 pointer-events-none" style="background: radial-gradient(circle at center, rgba(0,229,255,0.25) 0%, transparent 70%);"></div>

              <div class="relative">
                <p id="result-label" class="font-mono text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] text-slate-500 mb-2">Sobrecalentamiento</p>
                <div class="flex items-start gap-1" aria-live="polite">
                  <span id="result-value" class="font-display text-5xl sm:text-6xl md:text-7xl font-black text-white tracking-tighter tabular-nums leading-none">0.0</span>
                  <span id="result-unit" class="text-xl sm:text-2xl font-bold text-slate-500 mt-2">K</span>
                </div>
                <div class="flex items-center gap-2 mt-4 flex-wrap">
                  <span id="result-pill" class="px-3 py-1.5 rounded-full border border-slate-700 bg-[#0A0F1C] text-[10px] md:text-xs font-bold uppercase tracking-wider text-slate-400 transition-colors">Ingresa los datos</span>
                  <span id="result-sat" class="font-mono text-[10px] text-slate-500"></span>
                </div>
              </div>
            </div>

            <!-- INPUT 1: Presión (oculto en modo "sat") -->
            <div id="input-presion" class="bg-[#0A0F1C]/50 p-4 sm:p-5 rounded-2xl border border-slate-800 mb-4">
              <div class="flex justify-between items-end mb-4">
                <div>
                  <label for="slider-presion" id="label-presion" class="font-mono text-[10px] uppercase tracking-widest text-cyan-400 font-bold block mb-1">Presión de succión</label>
                  <span class="text-[11px] text-slate-500">Manómetro de baja</span>
                </div>
                <div class="text-right flex items-baseline gap-1">
                  <input id="input-presion-num" type="number" inputmode="decimal" class="font-display text-3xl sm:text-4xl font-black text-white tabular-nums w-24 text-right bg-transparent border-0 focus:outline-none focus:text-cyan-400 transition-colors" value="115" step="1">
                  <span id="unit-presion-label" class="text-[10px] font-bold text-slate-500">PSIG</span>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <button class="step-btn w-10 h-10 shrink-0 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-300 hover:bg-slate-700 hover:text-white active:scale-95 transition-all" data-target="slider-presion" data-step="-1" aria-label="Disminuir presión">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/></svg>
                </button>
                <input type="range" id="slider-presion" min="0" max="700" value="115" step="1" class="flex-1 custom-range">
                <button class="step-btn w-10 h-10 shrink-0 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-300 hover:bg-slate-700 hover:text-white active:scale-95 transition-all" data-target="slider-presion" data-step="1" aria-label="Aumentar presión">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                </button>
              </div>
            </div>

            <!-- INPUT 2a: Temperatura de línea (en SC/SE) -->
            <div id="input-temp" class="bg-[#0A0F1C]/50 p-4 sm:p-5 rounded-2xl border border-slate-800">
              <div class="flex justify-between items-end mb-4">
                <div>
                  <label for="slider-temp" id="label-temp" class="font-mono text-[10px] uppercase tracking-widest text-emerald-400 font-bold block mb-1">Temp. línea succión</label>
                  <span class="text-[11px] text-slate-500">Termómetro de contacto</span>
                </div>
                <div class="text-right flex items-baseline gap-1">
                  <input id="input-temp-num" type="number" inputmode="decimal" class="font-display text-3xl sm:text-4xl font-black text-white tabular-nums w-24 text-right bg-transparent border-0 focus:outline-none focus:text-emerald-400 transition-colors" value="12.5" step="0.1">
                  <span class="text-[10px] font-bold text-slate-500">°C</span>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <button class="step-btn w-10 h-10 shrink-0 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-300 hover:bg-slate-700 hover:text-white active:scale-95 transition-all" data-target="slider-temp" data-step="-0.5" aria-label="Disminuir temperatura">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/></svg>
                </button>
                <input type="range" id="slider-temp" min="-40" max="80" value="12.5" step="0.5" class="flex-1 custom-range">
                <button class="step-btn w-10 h-10 shrink-0 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-300 hover:bg-slate-700 hover:text-white active:scale-95 transition-all" data-target="slider-temp" data-step="0.5" aria-label="Aumentar temperatura">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                </button>
              </div>
            </div>

            <!-- INPUT 2b: Temperatura de saturación directa (solo en modo "sat") -->
            <div id="input-sat" class="hidden bg-[#0A0F1C]/50 p-4 sm:p-5 rounded-2xl border border-slate-800 mt-4">
              <div class="flex justify-between items-end mb-4">
                <div>
                  <label for="slider-sat" class="font-mono text-[10px] uppercase tracking-widest text-cyan-400 font-bold block mb-1">Temp. saturación</label>
                  <span class="text-[11px] text-slate-500">Directo del manómetro digital</span>
                </div>
                <div class="text-right flex items-baseline gap-1">
                  <input id="input-sat-num" type="number" inputmode="decimal" class="font-display text-3xl sm:text-4xl font-black text-white tabular-nums w-24 text-right bg-transparent border-0 focus:outline-none focus:text-cyan-400 transition-colors" value="5" step="0.5">
                  <span class="text-[10px] font-bold text-slate-500">°C</span>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <button class="step-btn w-10 h-10 shrink-0 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-300 hover:bg-slate-700 hover:text-white active:scale-95 transition-all" data-target="slider-sat" data-step="-0.5" aria-label="Disminuir saturación">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/></svg>
                </button>
                <input type="range" id="slider-sat" min="-40" max="70" value="5" step="0.5" class="flex-1 custom-range">
                <button class="step-btn w-10 h-10 shrink-0 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-300 hover:bg-slate-700 hover:text-white active:scale-95 transition-all" data-target="slider-sat" data-step="0.5" aria-label="Aumentar saturación">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                </button>
              </div>
            </div>

            <!-- Nota contextual de rangos -->
            <div class="mt-6 rounded-xl bg-slate-900/60 border border-slate-800 p-4">
              <p class="font-mono text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-2">// Rangos típicos de referencia</p>
              <p id="ranges-text" class="text-[12px] text-slate-400 leading-relaxed">Sobrecalentamiento típico: <span class="text-white font-semibold">5–10 K</span> en sistemas con TXV; <span class="text-white font-semibold">8–20 K</span> en sistemas con orificio fijo (varía con carga térmica).</p>
            </div>

          </div>

          <!-- CTA al pie -->
          <div class="p-5 sm:p-6 border-t border-slate-800 bg-slate-900/60">
            <p class="text-center text-[11px] text-slate-400 mb-3">¿Registras estos diagnósticos en cada visita? Con Lissi quedan adjuntos al historial del equipo.</p>
            <a href={SIGNUP_URL} class="group w-full py-3.5 rounded-xl flex items-center justify-center gap-2 font-bold text-sm uppercase tracking-wider text-[#0A0F1C] bg-cyan-400 hover:bg-cyan-300 transition-all active:scale-[0.99]">
              Probar Lissi gratis 21 días
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .custom-range { -webkit-appearance: none; appearance: none; width: 100%; background: transparent; height: 30px; }
  .custom-range:focus { outline: none; }
  .custom-range::-webkit-slider-runnable-track { width: 100%; height: 4px; cursor: pointer; background: #1e293b; border-radius: 999px; }
  .custom-range::-moz-range-track { width: 100%; height: 4px; cursor: pointer; background: #1e293b; border-radius: 999px; }
  .custom-range::-webkit-slider-thumb { height: 22px; width: 22px; border-radius: 50%; background: #ffffff; cursor: pointer; -webkit-appearance: none; margin-top: -9px; box-shadow: 0 4px 10px rgba(0,0,0,0.5); border: 4px solid #06b6d4; transition: transform 0.1s; }
  .custom-range::-moz-range-thumb { height: 22px; width: 22px; border-radius: 50%; background: #ffffff; cursor: pointer; border: 4px solid #06b6d4; box-shadow: 0 4px 10px rgba(0,0,0,0.5); }
  .custom-range::-webkit-slider-thumb:active { transform: scale(1.1); }
  .custom-range.thumb-emerald::-webkit-slider-thumb { border-color: #10b981; }
  .custom-range.thumb-emerald::-moz-range-thumb { border-color: #10b981; }
  /* Quitar spinner del input numérico */
  input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
  input[type=number] { -moz-appearance: textfield; }
  /* Estilizar select nativo */
  #gas-select option { background: #0A0F1C; color: white; }
</style>

<script is:inline define:vars={{ refrigerantesData: refrigerantes }}>
  // ============================================
  // TABLAS P-T REALES por refrigerante
  // Formato: { tempC: PSIG }, datos verificados de Hudson Tech / Arkema / Honeywell
  // ============================================
  const ptTables = {
    // R-410A: blend azeotrópico, glide despreciable. Fuente: Hudson Tech / Arkema.
    'R-410A': [
      [-40, 11.6], [-30, 22.5], [-20, 48.6], [-10, 78.3], [-5, 96.8],
      [0, 118], [5, 142], [10, 169], [15, 201], [20, 235],
      [25, 274], [30, 317], [35, 365], [40, 418], [45, 476],
      [50, 539], [55, 608], [60, 685]
    ],
    // R-32: HFC puro. Presiones similares (algo más altas) que R-410A.
    'R-32': [
      [-40, 13.8], [-30, 26.4], [-20, 44.4], [-10, 69.2], [0, 102],
      [5, 122], [10, 143], [15, 167], [20, 195], [25, 226],
      [30, 261], [35, 300], [40, 343], [45, 390], [50, 443],
      [55, 500], [60, 563]
    ],
    // R-22: HCFC. Fuente: SkillCat / igas / Hudson.
    'R-22': [
      [-40, 0.5], [-30, 4.8], [-20, 10.9], [-10, 23.1], [-5, 30.4],
      [0, 38.7], [5, 49.4], [10, 58.7], [15, 69.4], [20, 81.4],
      [25, 95.0], [30, 110.3], [35, 127.5], [40, 146.6], [45, 167.8],
      [50, 191.2], [55, 217], [60, 245]
    ],
    // R-134a: HFC puro, presiones más bajas. Fuente: Honeywell Genetron.
    'R-134a': [
      [-40, -8.4], [-30, -2.0], [-20, 4.6], [-10, 14.4], [-5, 20.5],
      [0, 27.8], [5, 36.6], [10, 47.0], [15, 59.0], [20, 71.0],
      [25, 84.4], [30, 99.4], [35, 116.2], [40, 134.7], [45, 155.1],
      [50, 177.6], [55, 202.4], [60, 229.6]
    ],
    // R-404A: blend zeotrópico con glide ~0.7°C. Valores bubble point.
    'R-404A': [
      [-40, 5.5], [-30, 14.7], [-20, 26.6], [-10, 41.9], [-5, 51.0],
      [0, 60.9], [5, 71.9], [10, 84.6], [15, 98.6], [20, 113.6],
      [25, 130.9], [30, 149.7], [35, 169.7], [40, 192], [45, 215],
      [50, 240], [55, 268], [60, 296]
    ],
  };

  // Interpolación lineal entre tramos
  function tempFromPsig(gas, psig) {
    const table = ptTables[gas];
    if (!table) return null;
    if (psig <= table[0][1]) return table[0][0];
    if (psig >= table[table.length - 1][1]) return table[table.length - 1][0];
    for (let i = 0; i < table.length - 1; i++) {
      const [t1, p1] = table[i], [t2, p2] = table[i + 1];
      if (psig >= p1 && psig <= p2) {
        return t1 + (psig - p1) * (t2 - t1) / (p2 - p1);
      }
    }
    return null;
  }
  function psigFromTemp(gas, tempC) {
    const table = ptTables[gas];
    if (!table) return null;
    if (tempC <= table[0][0]) return table[0][1];
    if (tempC >= table[table.length - 1][0]) return table[table.length - 1][1];
    for (let i = 0; i < table.length - 1; i++) {
      const [t1, p1] = table[i], [t2, p2] = table[i + 1];
      if (tempC >= t1 && tempC <= t2) {
        return p1 + (tempC - t1) * (p2 - p1) / (t2 - t1);
      }
    }
    return null;
  }
  // Conversión PSIG ↔ bar
  function psigToBar(psig) { return psig * 0.0689476; }
  function barToPsig(bar) { return bar / 0.0689476; }

  // ============================================
  // STATE
  // ============================================
  let state = {
    mode: 'sc', // sc | se | sat
    gas: 'R-410A',
    unit: 'psig',
    presion: 115, // siempre en PSIG internamente
    temp: 12.5,
    sat: 5,
  };

  // Restaurar de localStorage
  try {
    const saved = JSON.parse(localStorage.getItem('lissi-calc-state') || '{}');
    state = { ...state, ...saved };
  } catch (e) {}

  function save() {
    try { localStorage.setItem('lissi-calc-state', JSON.stringify(state)); } catch (e) {}
  }

  // ============================================
  // DOM REFS
  // ============================================
  const gasSelect = document.getElementById('gas-select');
  const gasAsn = document.getElementById('gas-asn');
  const gasGwp = document.getElementById('gas-gwp');
  const gasGlide = document.getElementById('gas-glide');
  const gasNote = document.getElementById('gas-note');
  const tabSlider = document.getElementById('tab-slider');
  const modeBtns = document.querySelectorAll('.mode-btn');
  const unitBtns = document.querySelectorAll('.unit-btn');
  const unitPresLabel = document.getElementById('unit-presion-label');
  const labelPresion = document.getElementById('label-presion');
  const labelTemp = document.getElementById('label-temp');
  const sliderPresion = document.getElementById('slider-presion');
  const sliderTemp = document.getElementById('slider-temp');
  const sliderSat = document.getElementById('slider-sat');
  const numPresion = document.getElementById('input-presion-num');
  const numTemp = document.getElementById('input-temp-num');
  const numSat = document.getElementById('input-sat-num');
  const inputPresion = document.getElementById('input-presion');
  const inputTemp = document.getElementById('input-temp');
  const inputSat = document.getElementById('input-sat');
  const resultValue = document.getElementById('result-value');
  const resultUnit = document.getElementById('result-unit');
  const resultLabel = document.getElementById('result-label');
  const resultPill = document.getElementById('result-pill');
  const resultSat = document.getElementById('result-sat');
  const resultGlow = document.getElementById('result-glow');
  const rangesText = document.getElementById('ranges-text');

  // ============================================
  // INIT REFRIGERANTES
  // ============================================
  refrigerantesData.forEach((r) => { /* poblado por Astro */ });

  function updateGasInfo() {
    const g = refrigerantesData.find((r) => r.id === state.gas);
    if (!g) return;
    gasAsn.textContent = g.asn;
    gasGwp.textContent = g.gwp.toLocaleString('es-CL');
    gasGlide.textContent = g.glide > 0 ? `~${g.glide}°C` : '0°C';
    if (g.note) { gasNote.textContent = g.note; gasNote.classList.remove('hidden'); }
    else { gasNote.classList.add('hidden'); }
  }

  // ============================================
  // RENDER UI según modo y unidad
  // ============================================
  function renderUI() {
    // Tabs
    const idx = state.mode === 'sc' ? 0 : state.mode === 'se' ? 1 : 2;
    tabSlider.style.transform = `translateX(calc(${idx * 100}% + ${idx * 4}px))`;
    modeBtns.forEach((b) => {
      const on = b.dataset.mode === state.mode;
      b.classList.toggle('text-white', on);
      b.classList.toggle('text-slate-500', !on);
    });

    // Unidades
    unitBtns.forEach((b) => {
      const on = b.dataset.unit === state.unit;
      b.classList.toggle('bg-slate-800', on);
      b.classList.toggle('text-white', on);
      b.classList.toggle('text-slate-500', !on);
    });
    unitPresLabel.textContent = state.unit === 'psig' ? 'PSIG' : 'bar';

    // Mostrar/ocultar inputs según modo
    if (state.mode === 'sat') {
      inputPresion.classList.add('hidden');
      inputSat.classList.remove('hidden');
      inputTemp.classList.remove('hidden');
    } else {
      inputPresion.classList.remove('hidden');
      inputSat.classList.add('hidden');
      inputTemp.classList.remove('hidden');
    }

    // Etiquetas por modo
    if (state.mode === 'sc') {
      labelPresion.textContent = 'Presión de succión';
      labelPresion.className = 'font-mono text-[10px] uppercase tracking-widest text-cyan-400 font-bold block mb-1';
      labelTemp.textContent = 'Temp. línea succión';
      labelTemp.className = 'font-mono text-[10px] uppercase tracking-widest text-emerald-400 font-bold block mb-1';
      sliderPresion.classList.remove('thumb-emerald');
      sliderTemp.classList.remove('thumb-emerald');
      resultLabel.textContent = 'Sobrecalentamiento';
      rangesText.innerHTML = 'Sobrecalentamiento típico: <span class="text-white font-semibold">5–10 K</span> en sistemas con TXV; <span class="text-white font-semibold">8–20 K</span> en orificio fijo (varía con carga térmica).';
    } else if (state.mode === 'se') {
      labelPresion.textContent = 'Presión de descarga (línea líquido)';
      labelPresion.className = 'font-mono text-[10px] uppercase tracking-widest text-emerald-400 font-bold block mb-1';
      labelTemp.textContent = 'Temp. línea líquido';
      labelTemp.className = 'font-mono text-[10px] uppercase tracking-widest text-emerald-400 font-bold block mb-1';
      sliderPresion.classList.add('thumb-emerald');
      sliderTemp.classList.add('thumb-emerald');
      resultLabel.textContent = 'Subenfriamiento';
      rangesText.innerHTML = 'Subenfriamiento típico: <span class="text-white font-semibold">8–12 K</span> en sistemas con TXV; <span class="text-white font-semibold">5–10 K</span> en orificio fijo. Bajo subcooling sugiere falta de carga; alto puede ser exceso o restricción.';
    } else {
      labelTemp.textContent = 'Temp. línea (succión o líquido)';
      labelTemp.className = 'font-mono text-[10px] uppercase tracking-widest text-emerald-400 font-bold block mb-1';
      sliderTemp.classList.remove('thumb-emerald');
      resultLabel.textContent = 'Δ Temperatura';
      rangesText.innerHTML = 'Modo manual: ingresa la T° de saturación que ya entrega tu manómetro digital. Útil para mezclas zeotrópicas con glide notable.';
    }
    syncInputs();
    calculate();
  }

  function syncInputs() {
    // Presión: mostrar en unidad elegida
    if (state.unit === 'psig') {
      sliderPresion.min = 0; sliderPresion.max = 700; sliderPresion.step = 1;
      sliderPresion.value = state.presion;
      numPresion.value = Math.round(state.presion);
      numPresion.step = 1;
    } else {
      const bar = psigToBar(state.presion);
      sliderPresion.min = 0; sliderPresion.max = 48; sliderPresion.step = 0.1;
      sliderPresion.value = bar.toFixed(1);
      numPresion.value = bar.toFixed(2);
      numPresion.step = 0.01;
    }
    sliderTemp.value = state.temp;
    numTemp.value = state.temp.toFixed(1);
    sliderSat.value = state.sat;
    numSat.value = state.sat.toFixed(1);
  }

  // ============================================
  // CÁLCULO
  // ============================================
  function calculate() {
    let satTemp;
    if (state.mode === 'sat') {
      satTemp = state.sat;
    } else {
      satTemp = tempFromPsig(state.gas, state.presion);
    }
    if (satTemp === null || isNaN(satTemp)) return;

    let result, statusText, statusClass, glowColor;
    if (state.mode === 'sc') {
      result = state.temp - satTemp;
      if (result < 3) { statusText = 'Riesgo de líquido al compresor'; statusClass = 'text-rose-400 bg-rose-500/10 border-rose-500/30'; glowColor = 'rgba(244,63,94,0.2)'; }
      else if (result <= 10) { statusText = 'Rango óptimo'; statusClass = 'text-emerald-400 bg-emerald-500/10 border-emerald-500/30'; glowColor = 'rgba(16,185,129,0.2)'; }
      else if (result <= 20) { statusText = 'Alto · revisar carga'; statusClass = 'text-amber-400 bg-amber-500/10 border-amber-500/30'; glowColor = 'rgba(245,158,11,0.2)'; }
      else { statusText = 'Muy alto · posible undercharge'; statusClass = 'text-rose-400 bg-rose-500/10 border-rose-500/30'; glowColor = 'rgba(244,63,94,0.2)'; }
    } else if (state.mode === 'se') {
      result = satTemp - state.temp;
      if (result < 3) { statusText = 'Bajo · posible falta de carga'; statusClass = 'text-amber-400 bg-amber-500/10 border-amber-500/30'; glowColor = 'rgba(245,158,11,0.2)'; }
      else if (result <= 12) { statusText = 'Rango óptimo'; statusClass = 'text-emerald-400 bg-emerald-500/10 border-emerald-500/30'; glowColor = 'rgba(16,185,129,0.2)'; }
      else { statusText = 'Alto · exceso carga o restricción'; statusClass = 'text-rose-400 bg-rose-500/10 border-rose-500/30'; glowColor = 'rgba(244,63,94,0.2)'; }
    } else {
      result = state.temp - state.sat;
      statusText = result > 0 ? `Sobrecalentamiento ${result.toFixed(1)} K` : `Subenfriamiento ${Math.abs(result).toFixed(1)} K`;
      statusClass = 'text-cyan-400 bg-cyan-500/10 border-cyan-500/30';
      glowColor = 'rgba(0,229,255,0.2)';
      result = Math.abs(result);
    }

    resultValue.textContent = result.toFixed(1);
    resultUnit.textContent = 'K';
    resultPill.textContent = statusText;
    resultPill.className = `px-3 py-1.5 rounded-full border text-[10px] md:text-xs font-bold uppercase tracking-wider transition-colors ${statusClass}`;
    resultGlow.style.background = `radial-gradient(circle at center, ${glowColor} 0%, transparent 70%)`;
    if (state.mode !== 'sat') {
      resultSat.textContent = `T° saturación = ${satTemp.toFixed(1)} °C`;
    } else {
      resultSat.textContent = '';
    }
  }

  // ============================================
  // EVENTS
  // ============================================
  modeBtns.forEach((b) => b.addEventListener('click', () => { state.mode = b.dataset.mode; save(); renderUI(); }));
  unitBtns.forEach((b) => b.addEventListener('click', () => { state.unit = b.dataset.unit; save(); syncInputs(); }));
  gasSelect.addEventListener('change', () => { state.gas = gasSelect.value; save(); updateGasInfo(); calculate(); });

  sliderPresion.addEventListener('input', () => {
    const v = parseFloat(sliderPresion.value);
    state.presion = state.unit === 'psig' ? v : barToPsig(v);
    numPresion.value = state.unit === 'psig' ? Math.round(v) : v.toFixed(2);
    save(); calculate();
  });
  numPresion.addEventListener('input', () => {
    const v = parseFloat(numPresion.value);
    if (isNaN(v)) return;
    state.presion = state.unit === 'psig' ? v : barToPsig(v);
    sliderPresion.value = v;
    save(); calculate();
  });
  sliderTemp.addEventListener('input', () => { state.temp = parseFloat(sliderTemp.value); numTemp.value = state.temp.toFixed(1); save(); calculate(); });
  numTemp.addEventListener('input', () => { const v = parseFloat(numTemp.value); if (isNaN(v)) return; state.temp = v; sliderTemp.value = v; save(); calculate(); });
  sliderSat.addEventListener('input', () => { state.sat = parseFloat(sliderSat.value); numSat.value = state.sat.toFixed(1); save(); calculate(); });
  numSat.addEventListener('input', () => { const v = parseFloat(numSat.value); if (isNaN(v)) return; state.sat = v; sliderSat.value = v; save(); calculate(); });

  document.querySelectorAll('.step-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = document.getElementById(btn.dataset.target);
      const step = parseFloat(btn.dataset.step);
      const nv = Math.min(parseFloat(target.max), Math.max(parseFloat(target.min), parseFloat(target.value) + step));
      target.value = nv;
      target.dispatchEvent(new Event('input'));
    });
  });

  // INIT
  gasSelect.value = state.gas;
  updateGasInfo();
  renderUI();
</script>