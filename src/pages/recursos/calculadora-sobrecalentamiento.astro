---
// src/pages/recursos/calculadora-sobrecalentamiento.astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
const SIGNUP_URL = "https://app.lissi.app/signup";
---
<Layout title="Calculadora de Sobrecalentamiento y Subenfriamiento">
  <Navbar />
  <main class="pt-28 md:pt-32 pb-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Encabezado -->
      <div class="mb-10">
        <a href="/recursos" class="text-sm text-navy-400 hover:text-cyan-600 transition-colors">← Recursos</a>
        <h1 class="font-display text-3xl md:text-4xl font-extrabold text-navy-900 tracking-tight mt-3 mb-3 text-balance">
          Calculadora de sobrecalentamiento y subenfriamiento
        </h1>
        <p class="text-lg text-navy-500 text-balance">
          Diagnostica la carga de refrigerante de cualquier sistema en segundos. Gratis, para técnicos HVAC-R.
        </p>
      </div>

      <!-- Controles globales -->
      <div class="bg-navy-50 border border-navy-100 rounded-2xl p-5 mb-6 flex flex-wrap gap-x-8 gap-y-4 items-end">
        <div>
          <label class="block text-xs font-semibold text-navy-500 uppercase tracking-wider mb-2">Refrigerante</label>
          <select id="refrig" class="bg-white border border-navy-200 rounded-lg px-3 py-2 text-navy-900 font-medium focus:ring-2 focus:ring-cyan-500 outline-none">
            <option value="R410A">R-410A</option>
            <option value="R22">R-22</option>
            <option value="R404A">R-404A</option>
            <option value="R134a">R-134a</option>
            <option value="R32">R-32</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-navy-500 uppercase tracking-wider mb-2">Cómo ingresas la saturación</label>
          <div class="inline-flex rounded-lg border border-navy-200 bg-white p-1">
            <button data-satmode="temp" class="satmode-btn px-3 py-1.5 rounded-md text-sm font-semibold transition-all">Temp. de saturación</button>
            <button data-satmode="pressure" class="satmode-btn px-3 py-1.5 rounded-md text-sm font-semibold transition-all">Presión</button>
          </div>
        </div>
        <div class="flex gap-2">
          <div>
            <label class="block text-xs font-semibold text-navy-500 uppercase tracking-wider mb-2">Temp.</label>
            <div class="inline-flex rounded-lg border border-navy-200 bg-white p-1">
              <button data-tempunit="C" class="tempunit-btn px-2.5 py-1.5 rounded-md text-sm font-semibold">°C</button>
              <button data-tempunit="F" class="tempunit-btn px-2.5 py-1.5 rounded-md text-sm font-semibold">°F</button>
            </div>
          </div>
          <div id="press-unit-wrap">
            <label class="block text-xs font-semibold text-navy-500 uppercase tracking-wider mb-2">Presión</label>
            <div class="inline-flex rounded-lg border border-navy-200 bg-white p-1">
              <button data-pressunit="psi" class="pressunit-btn px-2.5 py-1.5 rounded-md text-sm font-semibold">PSI</button>
              <button data-pressunit="bar" class="pressunit-btn px-2.5 py-1.5 rounded-md text-sm font-semibold">bar</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Dos tarjetas -->
      <div class="grid md:grid-cols-2 gap-6">

        <!-- SOBRECALENTAMIENTO -->
        <div class="border border-navy-200 rounded-2xl p-6">
          <h2 class="font-display text-xl font-bold text-navy-900 mb-1">Sobrecalentamiento</h2>
          <p class="text-sm text-navy-400 mb-5">Lado de baja · línea de succión</p>

          <label class="block text-sm font-medium text-navy-700 mb-1" data-sat-label="sh-sat">Temp. de saturación (succión)</label>
          <input type="number" step="any" id="sh-sat" class="calc-input w-full px-3 py-2.5 border border-navy-200 rounded-lg mb-4 focus:ring-2 focus:ring-cyan-500 outline-none" placeholder="—" />

          <label class="block text-sm font-medium text-navy-700 mb-1">Temp. de la línea de succión</label>
          <input type="number" step="any" id="sh-line" class="calc-input w-full px-3 py-2.5 border border-navy-200 rounded-lg mb-4 focus:ring-2 focus:ring-cyan-500 outline-none" placeholder="—" />

          <div class="flex gap-3 mb-5">
            <div class="flex-1">
              <label class="block text-xs font-medium text-navy-500 mb-1">Objetivo</label>
              <input type="number" step="any" id="sh-target" value="5.5" class="calc-input w-full px-3 py-2 border border-navy-200 rounded-lg text-sm focus:ring-2 focus:ring-cyan-500 outline-none" />
            </div>
            <div class="flex-1">
              <label class="block text-xs font-medium text-navy-500 mb-1">Tolerancia ±</label>
              <input type="number" step="any" id="sh-tol" value="2.5" class="calc-input w-full px-3 py-2 border border-navy-200 rounded-lg text-sm focus:ring-2 focus:ring-cyan-500 outline-none" />
            </div>
          </div>

          <div id="sh-result" class="rounded-xl p-5 bg-navy-50 text-center">
            <div class="text-3xl font-display font-extrabold text-navy-300" id="sh-value">—</div>
            <div class="text-sm text-navy-400 mt-1" id="sh-diag">Ingresa los datos</div>
          </div>
        </div>

        <!-- SUBENFRIAMIENTO -->
        <div class="border border-navy-200 rounded-2xl p-6">
          <h2 class="font-display text-xl font-bold text-navy-900 mb-1">Subenfriamiento</h2>
          <p class="text-sm text-navy-400 mb-5">Lado de alta · línea de líquido</p>

          <label class="block text-sm font-medium text-navy-700 mb-1" data-sat-label="sc-sat">Temp. de saturación (líquido)</label>
          <input type="number" step="any" id="sc-sat" class="calc-input w-full px-3 py-2.5 border border-navy-200 rounded-lg mb-4 focus:ring-2 focus:ring-cyan-500 outline-none" placeholder="—" />

          <label class="block text-sm font-medium text-navy-700 mb-1">Temp. de la línea de líquido</label>
          <input type="number" step="any" id="sc-line" class="calc-input w-full px-3 py-2.5 border border-navy-200 rounded-lg mb-4 focus:ring-2 focus:ring-cyan-500 outline-none" placeholder="—" />

          <div class="flex gap-3 mb-5">
            <div class="flex-1">
              <label class="block text-xs font-medium text-navy-500 mb-1">Objetivo</label>
              <input type="number" step="any" id="sc-target" value="6" class="calc-input w-full px-3 py-2 border border-navy-200 rounded-lg text-sm focus:ring-2 focus:ring-cyan-500 outline-none" />
            </div>
            <div class="flex-1">
              <label class="block text-xs font-medium text-navy-500 mb-1">Tolerancia ±</label>
              <input type="number" step="any" id="sc-tol" value="2.5" class="calc-input w-full px-3 py-2 border border-navy-200 rounded-lg text-sm focus:ring-2 focus:ring-cyan-500 outline-none" />
            </div>
          </div>

          <div id="sc-result" class="rounded-xl p-5 bg-navy-50 text-center">
            <div class="text-3xl font-display font-extrabold text-navy-300" id="sc-value">—</div>
            <div class="text-sm text-navy-400 mt-1" id="sc-diag">Ingresa los datos</div>
          </div>
        </div>
      </div>

      <p class="text-xs text-navy-400 mt-6 leading-relaxed">
        El objetivo y la tolerancia están en grados de la unidad seleccionada. Los valores objetivo por defecto son referenciales (sistemas con válvula de expansión termostática): <b>siempre prioriza el dato de la placa o la ficha técnica del fabricante del equipo</b>. La conversión presión → temperatura de saturación es una estimación de tabla PT; para máxima precisión usa la temperatura de saturación directa de tu manómetro digital.
      </p>

      <!-- CTA suave -->
      <div class="mt-12 bg-navy-900 rounded-2xl p-8 text-center">
        <h3 class="font-display text-2xl font-bold text-white mb-2 text-balance">Guarda estos diagnósticos en la hoja de vida del equipo</h3>
        <p class="text-navy-300 mb-6 max-w-xl mx-auto text-balance">Con Lissi, cada medición queda en el historial del activo. Deja de anotar en papel que se pierde.</p>
        <a href={SIGNUP_URL} class="inline-flex items-center gap-2 px-7 py-3.5 bg-white text-navy-900 rounded-xl font-semibold hover:bg-cyan-50 transition-all">
          Empieza gratis
          <svg class="w-4 h-4 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<script>
  function initCalc() {
    const root = document.getElementById('sh-result');
    if (!root || document.body.dataset.calcInit) return;
    document.body.dataset.calcInit = '1';

    // Tablas PT [PSIG, °C]. R-410A y R-22 validados; R-404A/R-134a referenciales (verificar con carta del proveedor).
    const PT = {
      R410A: [[11.6,-40],[18.5,-34.4],[26.9,-28.9],[36.8,-23.3],[48.6,-17.8],[62.3,-12.2],[78.3,-6.7],[96.8,-1.1],[118.9,4.4],[142,10],[170,15.6],[201,21.1],[235,26.7],[274,32.2],[317,37.8],[365,43.3],[418,48.9],[476,54.4],[539,60],[608,65.6]],
      R22:   [[10,-31],[24,-17.8],[34,-12.2],[43,-6.7],[58,0],[68.5,4.4],[84,10],[103,15.6],[121.5,21.1],[143,26.7],[168,32.2],[196,37.8],[226,43.3],[260,48.9],[296,54.4]],
      R404A: [[16,-34.4],[28,-28.9],[41,-23.3],[56,-17.8],[72,-12.2],[88,-6.7],[110,0],[124,4.4],[155,12.8],[180,21.1],[210,28],[234.6,37.8],[280,43.3],[320,48.9]],
      R134a: [[6,-20],[12,-12],[18,-6.7],[27,0],[37,7.2],[49,15.6],[57,21.1],[71,26.7],[86,32.2],[104,37.8],[124,43.3],[147,48.9],[172,54.4],[185,60]],
      R32:   null
    };

    const els = {
      refrig: document.getElementById('refrig'),
      shSat: document.getElementById('sh-sat'), shLine: document.getElementById('sh-line'),
      shTarget: document.getElementById('sh-target'), shTol: document.getElementById('sh-tol'),
      shValue: document.getElementById('sh-value'), shDiag: document.getElementById('sh-diag'), shResult: document.getElementById('sh-result'),
      scSat: document.getElementById('sc-sat'), scLine: document.getElementById('sc-line'),
      scTarget: document.getElementById('sc-target'), scTol: document.getElementById('sc-tol'),
      scValue: document.getElementById('sc-value'), scDiag: document.getElementById('sc-diag'), scResult: document.getElementById('sc-result'),
    };

    let satMode = 'temp', tempUnit = 'C', pressUnit = 'psi';

    const toC = (v) => tempUnit === 'C' ? v : (v - 32) * 5 / 9;
    const deltaToDisplay = (dC) => tempUnit === 'C' ? dC : dC * 9 / 5;
    const psigFrom = (v) => pressUnit === 'psi' ? v : v * 14.5038;

    function interp(table, psig) {
      if (!table) return null;
      if (psig <= table[0][0]) return table[0][1];
      if (psig >= table[table.length-1][0]) return table[table.length-1][1];
      for (let i = 0; i < table.length - 1; i++) {
        const [p1,t1] = table[i], [p2,t2] = table[i+1];
        if (psig >= p1 && psig <= p2) return t1 + (t2-t1)*(psig-p1)/(p2-p1);
      }
      return null;
    }

    function satC(rawSat) {
      if (rawSat === '' || isNaN(parseFloat(rawSat))) return null;
      const val = parseFloat(rawSat);
      if (satMode === 'temp') return toC(val);
      const table = PT[els.refrig.value];
      if (!table) return null; // R-32 sin tabla: solo modo temp
      return interp(table, psigFrom(val));
    }

    function paint(resultEl, valueEl, diagEl, deltaC, targetC, tolC, kind) {
      if (deltaC === null) {
        valueEl.textContent = '—'; valueEl.className = 'text-3xl font-display font-extrabold text-navy-300';
        diagEl.textContent = 'Ingresa los datos'; resultEl.className = 'rounded-xl p-5 bg-navy-50 text-center';
        return;
      }
      const disp = deltaToDisplay(deltaC);
      valueEl.textContent = disp.toFixed(1) + '°' + tempUnit;
      const low = targetC - tolC, high = targetC + tolC;
      let state, msg;
      if (deltaC < low) state = 'low';
      else if (deltaC > high) state = 'high';
      else state = 'ok';

      if (state === 'ok') {
        msg = 'Dentro del rango objetivo';
        resultEl.className = 'rounded-xl p-5 bg-cyan-50 text-center';
        valueEl.className = 'text-3xl font-display font-extrabold text-cyan-700';
      } else {
        resultEl.className = 'rounded-xl p-5 bg-amber-50 text-center';
        valueEl.className = 'text-3xl font-display font-extrabold text-amber-700';
        if (kind === 'sh') {
          msg = state === 'low'
            ? 'Bajo: posible sobrecarga, sobrealimentación de la válvula o riesgo de retorno de líquido al compresor.'
            : 'Alto: posible falta de carga, restricción, válvula hambrienta o bajo flujo de aire en el evaporador.';
        } else {
          msg = state === 'low'
            ? 'Bajo: posible falta de carga o vapor flash en la línea de líquido.'
            : 'Alto: posible sobrecarga o restricción en la línea de líquido / condensador.';
        }
      }
      diagEl.textContent = msg;
    }

    function calc() {
      // Sobrecalentamiento = línea succión − sat succión
      const shS = satC(els.shSat.value), shL = els.shLine.value === '' ? null : toC(parseFloat(els.shLine.value));
      const sh = (shS === null || shL === null || isNaN(shL)) ? null : shL - shS;
      paint(els.shResult, els.shValue, els.shDiag, sh, parseFloat(els.shTarget.value)||0, Math.abs(parseFloat(els.shTol.value))||0, 'sh');

      // Subenfriamiento = sat líquido − línea líquido
      const scS = satC(els.scSat.value), scL = els.scLine.value === '' ? null : toC(parseFloat(els.scLine.value));
      const sc = (scS === null || scL === null || isNaN(scL)) ? null : scS - scL;
      paint(els.scResult, els.scValue, els.scDiag, sc, parseFloat(els.scTarget.value)||0, Math.abs(parseFloat(els.scTol.value))||0, 'sc');
    }

    function setActive(selector, attr, val) {
      document.querySelectorAll(selector).forEach((b) => {
        const on = b.getAttribute(attr) === val;
        b.classList.toggle('bg-navy-800', on);
        b.classList.toggle('text-white', on);
        b.classList.toggle('text-navy-500', !on);
      });
    }
    function updateSatLabels() {
      const txtSh = satMode === 'temp' ? 'Temp. de saturación (succión)' : 'Presión de succión';
      const txtSc = satMode === 'temp' ? 'Temp. de saturación (líquido)' : 'Presión de líquido';
      document.querySelector('[data-sat-label="sh-sat"]').textContent = txtSh;
      document.querySelector('[data-sat-label="sc-sat"]').textContent = txtSc;
      document.getElementById('press-unit-wrap').style.display = satMode === 'pressure' ? '' : 'none';
    }

    document.querySelectorAll('.satmode-btn').forEach((b) => b.addEventListener('click', () => {
      satMode = b.getAttribute('data-satmode'); setActive('.satmode-btn','data-satmode',satMode); updateSatLabels(); calc();
    }));
    document.querySelectorAll('.tempunit-btn').forEach((b) => b.addEventListener('click', () => {
      tempUnit = b.getAttribute('data-tempunit'); setActive('.tempunit-btn','data-tempunit',tempUnit); calc();
    }));
    document.querySelectorAll('.pressunit-btn').forEach((b) => b.addEventListener('click', () => {
      pressUnit = b.getAttribute('data-pressunit'); setActive('.pressunit-btn','data-pressunit',pressUnit); calc();
    }));
    document.querySelectorAll('.calc-input').forEach((i) => i.addEventListener('input', calc));
    els.refrig.addEventListener('change', calc);

    setActive('.satmode-btn','data-satmode','temp');
    setActive('.tempunit-btn','data-tempunit','C');
    setActive('.pressunit-btn','data-pressunit','psi');
    updateSatLabels();
  }
  initCalc();
  document.addEventListener('astro:page-load', initCalc);
</script>