---
// src/pages/recursos/codigos-error.astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
const SIGNUP_URL = "https://app.lissi.app/signup";

// Sitios oficiales de soporte (solo enlazamos, no alojamos manuales). VERIFICA las URLs de Chile.
const soporteOficial = {
  Midea: "https://www.midea.com",
  Samsung: "https://www.samsung.com/cl/support/",
  LG: "https://www.lg.com/cl/soporte",
  Daikin: "https://www.daikin.cl",
};

// BASE DE CÓDIGOS — punto de partida verificado. AMPLÍALA con la experiencia de tus técnicos.
// Cada entrada: significado típico + qué revisar en terreno. Siempre confirmar con el manual del modelo.
const codigos = [
  // MIDEA
  { marca:"Midea", codigo:"E1", sig:"Error de comunicación entre unidad interior y exterior (en algunas series: protección de alta presión).", check:"Reinicia 2 min. Revisa cableado y terminales entre unidades; si persiste, mide voltaje S-N y revisa PCB." },
  { marca:"Midea", codigo:"E2", sig:"Error de señal de cruce por cero (zero crossing).", check:"Verifica la señal de alimentación y la placa PCB interior." },
  { marca:"Midea", codigo:"E3", sig:"Velocidad del ventilador interior fuera de control.", check:"Revisa el motor del ventilador interior y su conexión." },
  { marca:"Midea", codigo:"E4", sig:"Falla en la placa PCB.", check:"Inspecciona la PCB; reemplazo si corresponde." },
  { marca:"Midea", codigo:"E5", sig:"Sensor de temperatura (interior/exterior según serie) abierto o en corto.", check:"Mide resistencia del sensor; reemplaza si está fuera de rango." },
  { marca:"Midea", codigo:"E6", sig:"Sensor de serpentín/evaporador (T2) abierto o en corto.", check:"Revisa el sensor del serpentín interior." },
  { marca:"Midea", codigo:"EC", sig:"Detección de fuga de gas refrigerante.", check:"Busca fugas, verifica carga y presiones." },
  { marca:"Midea", codigo:"P0", sig:"Protección de alta corriente / módulo de potencia (IPM).", check:"Revisa IPM, compresor, ventilador exterior y cableado." },
  // SAMSUNG
  { marca:"Samsung", codigo:"E1 / 21", sig:"Defecto del sensor de temperatura ambiente (termistor).", check:"Revisa el termistor de la unidad interior; reemplaza si está dañado." },
  { marca:"Samsung", codigo:"E1 / 22", sig:"Defecto del sensor de temperatura del intercambiador de calor.", check:"Mide el sensor del intercambiador; reemplaza si corresponde." },
  { marca:"Samsung", codigo:"E1 / 54", sig:"Defecto del motor del ventilador o del condensador.", check:"Revisa motor del ventilador y condensador." },
  { marca:"Samsung", codigo:"E1 / 63", sig:"Defecto del EEPROM.", check:"Requiere revisión de la placa/EEPROM por técnico." },
  { marca:"Samsung", codigo:"E5", sig:"Corto o circuito abierto del sensor del intercambiador interior.", check:"Comprueba la salida del sensor del intercambiador interior." },
  { marca:"Samsung", codigo:"C4 / 22", sig:"Posible problema con el gas refrigerante.", check:"Verifica carga, presiones y posibles fugas." },
  // LG
  { marca:"LG", codigo:"CH05 / E0 / CH53", sig:"Error de comunicación entre unidad interior y exterior (equipos inverter).", check:"Revisa cableado entre unidades. Si hay disyuntor exterior separado y está disparado, genera el error. Reinicia ambos disyuntores y espera 3-5 min." },
  { marca:"LG", codigo:"CH10 / E6", sig:"Problema del ventilador de la unidad interior.", check:"Revisa obstrucciones/residuos en el ventilador interior y el motor." },
  { marca:"LG", codigo:"CH67 / EF", sig:"Problema del ventilador de la unidad exterior.", check:"Revisa obstrucciones y motor del ventilador exterior." },
  { marca:"LG", codigo:"CH90 / CH91 / F4", sig:"Suele aparecer durante la ejecución de prueba (test run).", check:"Verifica las conexiones de tuberías; consulta al instalador." },
  // DAIKIN
  { marca:"Daikin", codigo:"U4", sig:"Problema de comunicación entre unidades interior y exterior.", check:"Revisa el cableado de interconexión entre unidades." },
];

const marcas = ["Todas", ...Object.keys(soporteOficial)];

// Guía universal de prefijos (bien documentada en el rubro)
const prefijos = [
  { l:"E", d:"Error general del sistema" },
  { l:"F", d:"Fallo de sensores o ventiladores" },
  { l:"U", d:"Unidad exterior / comunicación" },
  { l:"P", d:"Problemas de presión o protección" },
  { l:"A", d:"Unidad interior" },
  { l:"C / CH", d:"Comunicación o condensador" },
];
---
<Layout title="Buscador de Códigos de Error HVAC-R">
  <Navbar />
  <main class="pt-28 md:pt-32 pb-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="mb-8">
        <a href="/recursos" class="text-sm text-navy-400 hover:text-cyan-600 transition-colors">← Recursos</a>
        <h1 class="font-display text-3xl md:text-5xl font-extrabold text-navy-900 tracking-tight mt-3 mb-3 text-balance">
          Buscador de códigos de error
        </h1>
        <p class="text-lg text-navy-500 max-w-2xl text-balance">
          Busca qué significa un código por marca y qué revisar en terreno antes de desarmar el equipo.
        </p>
      </div>

      <!-- Aviso -->
      <div class="flex gap-3 bg-amber-50 border border-amber-200 rounded-xl p-4 mb-8">
        <svg class="w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M12 3l9 16H3l9-16z"/></svg>
        <p class="text-sm text-amber-800 leading-relaxed">
          <b>Un mismo código cambia de significado según la marca y la serie del equipo.</b> Esta base es una referencia de campo: confirma siempre con el manual de servicio del modelo específico antes de intervenir.
        </p>
      </div>

      <!-- Buscador -->
      <div class="mb-6">
        <input type="text" id="cod-search" placeholder="Escribe un código (ej. E1, CH05) o una palabra (ej. comunicación)" class="w-full px-4 py-3 border border-navy-200 rounded-xl focus:ring-2 focus:ring-cyan-500 outline-none" />
      </div>
      <div class="flex flex-wrap gap-2 mb-8">
        {marcas.map((m, i) => (
          <button data-marca={m} class={`marca-btn px-4 py-2 rounded-full text-sm font-semibold transition-all ${i===0?"bg-navy-800 text-white":"bg-white text-navy-600 border border-navy-200 hover:border-navy-300"}`}>{m}</button>
        ))}
      </div>

      <!-- Resultados -->
      <div id="cod-grid" class="space-y-3">
        {codigos.map((c) => (
          <div class="cod-card border border-navy-100 rounded-xl p-5 hover:border-cyan-300 transition-all" data-marca={c.marca} data-text={`${c.codigo} ${c.sig}`.toLowerCase()}>
            <div class="flex flex-wrap items-center gap-3 mb-2">
              <span class="font-display text-lg font-bold text-navy-900">{c.codigo}</span>
              <span class="text-[11px] font-semibold uppercase tracking-wide text-cyan-700 bg-cyan-50 px-2 py-0.5 rounded">{c.marca}</span>
            </div>
            <p class="text-navy-700 text-sm mb-2">{c.sig}</p>
            <p class="text-sm text-navy-500"><span class="font-semibold text-navy-700">Qué revisar:</span> {c.check}</p>
            <a href={soporteOficial[c.marca]} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-xs font-semibold text-cyan-600 hover:text-cyan-700 mt-3">
              Manual oficial {c.marca}
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>
        ))}
      </div>
      <p id="cod-empty" class="hidden text-center text-navy-400 py-10">No encontramos ese código en nuestra base todavía. Revisa el manual oficial del equipo.</p>

      <!-- Guía de prefijos -->
      <section class="mt-14 bg-navy-50 border border-navy-100 rounded-2xl p-6 md:p-8">
        <h2 class="font-display text-xl font-bold text-navy-900 mb-1">Cómo leer un código por su letra</h2>
        <p class="text-navy-500 text-sm mb-6">Orientación general cuando no encuentras el código exacto.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {prefijos.map((p) => (
            <div class="flex items-center gap-3 bg-white rounded-lg border border-navy-100 p-3">
              <span class="font-display font-bold text-cyan-600 w-12 text-center flex-shrink-0">{p.l}</span>
              <span class="text-sm text-navy-700">{p.d}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <div class="mt-12 bg-navy-900 rounded-2xl p-8 text-center">
        <h3 class="font-display text-2xl font-bold text-white mb-2 text-balance">Registra cada falla en el historial del equipo</h3>
        <p class="text-navy-300 mb-6 max-w-xl mx-auto text-balance">Con Lissi, cada código y reparación queda en la hoja de vida del activo. La próxima vez sabes al instante qué pasó antes.</p>
        <a href={SIGNUP_URL} class="inline-flex items-center gap-2 px-7 py-3.5 bg-white text-navy-900 rounded-xl font-semibold hover:bg-cyan-50 transition-all">
          Empieza gratis
          <svg class="w-4 h-4 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<script>
  function initCodigos() {
    const grid = document.getElementById('cod-grid');
    if (!grid || grid.dataset.init) return;
    grid.dataset.init = '1';
    const cards = Array.from(grid.querySelectorAll('.cod-card'));
    const search = document.getElementById('cod-search');
    const empty = document.getElementById('cod-empty');
    let marca = 'Todas';

    function apply() {
      const q = search.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((c) => {
        const okMarca = marca === 'Todas' || c.getAttribute('data-marca') === marca;
        const okText = q === '' || c.getAttribute('data-text').includes(q);
        const show = okMarca && okText;
        c.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      empty.classList.toggle('hidden', visible > 0);
    }

    search.addEventListener('input', apply);
    document.querySelectorAll('.marca-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        marca = btn.getAttribute('data-marca');
        document.querySelectorAll('.marca-btn').forEach((b) => {
          const on = b === btn;
          b.classList.toggle('bg-navy-800', on);
          b.classList.toggle('text-white', on);
          b.classList.toggle('bg-white', !on);
          b.classList.toggle('text-navy-600', !on);
          b.classList.toggle('border', !on);
          b.classList.toggle('border-navy-200', !on);
        });
        apply();
      });
    });
  }
  initCodigos();
  document.addEventListener('astro:page-load', initCodigos);
</script>