---
// src/components/Logos.astro
---
<section class="py-16 border-y border-slate-100 bg-white relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <p class="text-center text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] mb-12">
      Infraestructura de Clase Mundial
    </p>
    
    <div class="grid grid-cols-2 md:grid-cols-5 gap-12 items-center justify-items-center opacity-50 grayscale hover:opacity-100 transition-all duration-700">
      
      <div class="flex justify-center items-center h-12 w-full">
        <img 
          src="https://www.vectorlogo.zone/logos/flutterio/flutterio-ar21.svg" 
          alt="Flutter" 
          class="h-8 md:h-9 w-auto object-contain"
        />
      </div>

      <div class="flex justify-center items-center h-12 w-full">
        <img 
          src="https://www.vectorlogo.zone/logos/google_cloud/google_cloud-ar21.svg" 
          alt="Google Cloud" 
          class="h-9 md:h-10 w-auto object-contain" 
        />
      </div>

      <div class="flex justify-center items-center h-12 w-full">
         <span class="text-2xl font-black text-slate-900 tracking-tighter uppercase">Anthropic</span>
      </div>

      <div class="flex justify-center items-center h-12 w-full">
         <span class="text-xl font-extrabold text-[#009EE3] tracking-tight flex items-center gap-1">
           mercado <span class="font-light italic">pago</span>
         </span>
      </div>

      <div class="flex justify-center items-center h-12 w-full">
         <img 
           src="https://www.vectorlogo.zone/logos/paypal/paypal-ar21.svg" 
           alt="PayPal" 
           class="h-8 md:h-9 w-auto object-contain"
         />
      </div>

    </div>
  </div>
</section>