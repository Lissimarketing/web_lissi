---
// src/components/Bento.astro
---
<section id="soluciones" class="py-24 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-5xl md:text-6xl font-black text-slate-900 tracking-tight mb-8">
        Deja de perder <span class="text-blue-600"> información y dinero.</span>
      </h2>
      <p class="text-lg md:text-xl text-slate-500 font-medium leading-relaxed">
        Diseñado por expertos HVAC-R para digitalizar la operación técnica con estándares ASHRAE.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[480px]">
      
      <div class="md:col-span-2 relative group rounded-[3rem] bg-slate-50 border border-slate-200 overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500">
        <div class="relative z-10 h-full p-10 flex flex-col md:flex-row items-center gap-10">
            <div class="flex-1">
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-blue-600 text-white rounded-lg text-[10px] font-black mb-6 uppercase tracking-widest">
                    Asset Management
                </div>
                <h3 class="text-4xl font-black text-slate-900 mb-4 tracking-tighter">Hoja de Vida de Equipos</h3>
                <p class="text-slate-500 text-lg leading-snug font-medium">Trazabilidad total de cada unidad. Registro histórico de parámetros técnicos, componentes y bitácora de intervenciones.</p>
            </div>
            
            <div class="w-full md:w-[320px] bg-slate-900 rounded-[2.5rem] p-8 shadow-2xl border border-slate-800 transform group-hover:-translate-y-2 transition-transform duration-500">
                <div class="space-y-6">
                    <div class="flex justify-between items-center border-b border-white/10 pb-4">
                        <span class="text-[10px] font-mono font-bold text-blue-400 uppercase tracking-tighter italic">ID: CHILLER-04-A</span>
                        <div class="px-2 py-0.5 rounded bg-green-500/20 text-green-400 text-[8px] font-black uppercase">Excelente</div>
                    </div>
                    <div class="space-y-3">
                        <div class="flex justify-between items-center bg-white/5 p-3 rounded-xl border border-white/5">
                          <span class="text-[9px] text-slate-400 font-bold uppercase">Última Intervención</span>
                          <span class="text-[10px] text-white font-mono">12 Ene 2026</span>
                        </div>
                        <div class="flex justify-between items-center bg-blue-600/10 p-3 rounded-xl border border-blue-500/20">
                          <span class="text-[9px] text-blue-300 font-bold uppercase">Próximo Mtto.</span>
                          <span class="text-[10px] text-white font-mono">12 Feb 2026</span>
                        </div>
                    </div>
                    <button class="w-full py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-[10px] font-black text-white uppercase tracking-widest transition-all">
                        Ver Historial Completo
                    </button>
                </div>
            </div>
        </div>
      </div>

      <div class="md:col-span-1 relative group rounded-[3rem] bg-slate-950 text-white p-10 overflow-hidden shadow-xl border border-slate-800">
        <div class="relative z-10 h-full flex flex-col">
            <h3 class="text-2xl font-black mb-3 tracking-tighter uppercase">Analítica de Datos</h3>
            <p class="text-slate-400 text-sm mb-8 leading-relaxed">Visualiza gráficos sobre Estados de OT, Informes por tipo y Estado de Equipos en tiempo real.</p>
            
            <div class="mt-auto flex items-end gap-3 h-48 px-2">
                <div class="flex-1 bg-blue-900/40 rounded-t-2xl h-[20%] group-hover:h-[60%] transition-all duration-[1.2s] ease-[cubic-bezier(0.34,1.56,0.64,1)]"></div>
                <div class="flex-1 bg-blue-700/60 rounded-t-2xl h-[30%] group-hover:h-[85%] transition-all duration-[1.2s] delay-75 ease-[cubic-bezier(0.34,1.56,0.64,1)]"></div>
                <div class="flex-1 bg-blue-500 rounded-t-2xl h-[25%] group-hover:h-[75%] transition-all duration-[1.2s] delay-150 ease-[cubic-bezier(0.34,1.56,0.64,1)] shadow-[0_0_40px_rgba(59,130,246,0.5)]"></div>
                <div class="flex-1 bg-cyan-400 rounded-t-2xl h-[40%] group-hover:h-[100%] transition-all duration-[1.2s] delay-200 ease-[cubic-bezier(0.34,1.56,0.64,1)] shadow-[0_0_40px_rgba(34,211,238,0.5)]"></div>
            </div>
        </div>
      </div>

      <div class="md:col-span-1 relative group rounded-[3rem] bg-white border border-slate-200 overflow-hidden shadow-sm hover:border-blue-500 transition-all duration-500">
         <div class="h-full flex flex-col p-8 md:p-10">
            <div class="flex-none mb-6">
              <h3 class="text-2xl font-black text-slate-900 tracking-tight uppercase mb-2">Reportes Pro</h3>
              <p class="text-xs font-bold text-slate-500 leading-snug">
                Descarga informes automáticos en minutos, con parámetros, fotos y firmas listos para tu cliente.
              </p>
            </div>
            
            <div class="flex-1 bg-slate-50 rounded-[2.5rem] p-6 space-y-4 border border-slate-100 relative group-hover:-translate-y-2 transition-transform duration-500 text-slate-900">
                <div class="space-y-2 border-b border-slate-200 pb-4">
                    <div class="flex items-center justify-between text-[9px] font-black text-slate-400 uppercase tracking-widest">
                      <span>✓ Parámetros Técnicos</span>
                      <span class="text-blue-600">OK</span>
                    </div>
                    <div class="flex items-center justify-between text-[9px] font-black text-slate-400 uppercase tracking-widest">
                      <span>✓ Checklist HVAC-R</span>
                      <span class="text-blue-600">OK</span>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <div class="h-12 bg-slate-200 rounded-xl border border-dashed border-slate-300 flex items-center justify-center text-[8px] font-black text-slate-400 uppercase italic">📸 Fotos</div>
                    <div class="h-12 bg-slate-200 rounded-xl border border-dashed border-slate-300 flex items-center justify-center text-[8px] font-black text-slate-400 uppercase italic">✍️ Firmas</div>
                </div>

                <div class="p-3 bg-white rounded-xl border border-slate-100 shadow-sm">
                   <p class="text-[7px] font-black text-blue-600 uppercase mb-1 leading-none tracking-tighter">Comentarios y Firmas</p>
                   <div class="h-1 w-full bg-slate-100 rounded-full mb-1"></div>
                   <div class="h-1 w-2/3 bg-slate-100 rounded-full"></div>
                </div>
                
                <div class="absolute bottom-6 left-6 right-6">
                  <div class="bg-blue-600 p-4 rounded-2xl flex justify-between items-center shadow-xl shadow-blue-500/30 group-hover:bg-blue-700 transition-colors">
                     <div class="flex flex-col">
                       <span class="text-[8px] text-blue-200 font-black uppercase leading-none">Generación Automática</span>
                       <span class="text-[10px] text-white font-black uppercase tracking-widest">Descargar PDF</span>
                     </div>
                     <svg class="w-5 h-5 text-white animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                        <path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                     </svg>
                  </div>
                </div>
            </div>
         </div>
      </div>

      <div class="md:col-span-2 relative group rounded-[3rem] bg-gradient-to-br from-blue-700 to-slate-950 p-10 overflow-hidden shadow-2xl">
         <div class="relative z-10 flex flex-col md:flex-row items-center gap-10 h-full">
            <div class="flex-1 text-white">
                <div class="w-14 h-14 bg-white/10 rounded-2xl backdrop-blur-xl flex items-center justify-center mb-6 border border-white/20">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <h3 class="text-4xl font-black mb-4 tracking-tighter uppercase">Agenda de Servicios</h3>
                <p class="text-blue-100/80 text-lg leading-relaxed font-medium">
                    Centraliza la programación de mantenciones. Visualiza compromisos programados y disponibilidad técnica en un solo vistazo.
                </p>
            </div>
            
            <div class="w-full md:w-[340px] bg-white rounded-[2.5rem] shadow-2xl p-8 transform group-hover:scale-105 transition-transform duration-500">
                <div class="flex justify-between items-center mb-6 text-slate-900">
                    <span class="text-xs font-black uppercase">Enero 2026</span>
                    <div class="w-3 h-3 rounded-full bg-blue-600 animate-pulse"></div>
                </div>
                <div class="grid grid-cols-7 gap-2">
                    {Array.from({length: 28}).map((_, i) => (
                        <div class={`aspect-square rounded-lg flex items-center justify-center text-[10px] font-bold ${i === 14 ? 'bg-blue-600 text-white shadow-lg' : 'bg-slate-50 text-slate-300'}`}>
                            {i + 1}
                        </div>
                    ))}
                </div>
                <div class="mt-6 p-4 bg-slate-900 rounded-2xl border border-slate-800">
                    <p class="text-[9px] font-black text-blue-400 uppercase mb-1 tracking-widest">Compromiso Programado</p>
                    <p class="text-xs text-white font-bold leading-tight tracking-tight">Mantenimiento: Rack Frio Central</p>
                </div>
            </div>
         </div>
      </div>

    </div>
  </div>
</section>