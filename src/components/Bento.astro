---
// src/components/Bento.astro
const extras = [
  { 
    n: "01", t: "Portal de Cliente", 
    d: "Transparencia total. Tus clientes acceden a un portal privado para descargar informes y ver el estado de sus equipos al instante.", 
    icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z", 
    tag: "Portal VIP" 
  },
  { 
    n: "02", t: "Dictado Inteligente", 
    d: "Manos libres en terreno. El técnico dicta los hallazgos por voz; la IA de Lissi transcribe y estructura la información en el informe.", 
    icon: "M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3zM5 10v2a7 7 0 0014 0v-2M12 19v4", 
    tag: "Motor NLP" 
  },
  { 
    n: "03", t: "Trazabilidad F-Gas", 
    d: "Cumplimiento ambiental automático. Control exacto de carga y recuperación de refrigerantes para tu huella de CO₂.", 
    icon: "M12 2v6m0 0l3-3m-3 3L9 5M5 12a7 7 0 1014 0 7 7 0 00-14 0z", 
    tag: "Normativa RegTech" 
  },
  { 
    n: "04", t: "Lissi IA Copilot", 
    d: "Tu experto técnico 24/7. Un asistente virtual que responde dudas cruzando datos de tus manuales y el historial de intervenciones.", 
    icon: "M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z", 
    tag: "LLM Agent" 
  },
  { 
    n: "05", t: "Control de Flota", 
    d: "Rutas optimizadas. Visualiza en el mapa a tus cuadrillas, asigna urgencias por cercanía y reduce tiempos muertos en traslados.", 
    icon: "M9 19v-6m4 6V9m4 10V5M3 21h18", 
    tag: "Despacho GPS" 
  },
  { 
    n: "06", t: "Visión Artificial (OCR)", 
    d: "Cero tipeo. Captura con la cámara el modelo y número de serie desde la placa del equipo para digitalizarlo en un segundo.", 
    icon: "M3 7V5a2 2 0 012-2h2M17 3h2a2 2 0 012 2v2M21 17v2a2 2 0 01-2 2h-2M7 21H5a2 2 0 01-2-2v-2M7 12h10", 
    tag: "En Beta", 
    soon: true 
  },
];
---
<section id="soluciones" class="relative bg-[#0A0F1C] py-24 md:py-32 overflow-hidden border-t border-slate-800/50">
  
  <div class="absolute inset-0 pointer-events-none opacity-[0.15]"
       style="background-image: linear-gradient(rgba(0,229,255,0.2) 1px, transparent 1px), linear-gradient(90deg, rgba(0,229,255,0.2) 1px, transparent 1px); background-size: 64px 64px; mask-image: radial-gradient(ellipse 100% 60% at 50% 30%, black 20%, transparent 100%);"></div>
  
  <div class="absolute top-0 left-1/4 w-[800px] h-[500px] bg-cyan-600/10 rounded-full blur-[160px] pointer-events-none bento-aurora mix-blend-screen"></div>
  <div class="absolute bottom-1/4 right-0 w-[600px] h-[400px] bg-blue-600/10 rounded-full blur-[150px] pointer-events-none bento-aurora-delayed mix-blend-screen"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <div class="max-w-3xl mb-20">
      <div class="flex items-center gap-2 mb-6">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
        </span>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-cyan-400">Arquitectura de Plataforma</p>
      </div>
      <h2 class="font-display text-4xl md:text-[3.5rem] font-black text-white tracking-tight mb-6 leading-[1.05]">
        Todo tu flujo de trabajo.<br/>
        <span class="bg-gradient-to-r from-cyan-300 via-cyan-400 to-blue-500 bg-clip-text text-transparent">Centralizado y automatizado.</span>
      </h2>
      <p class="text-lg md:text-xl text-slate-400 leading-relaxed max-w-2xl font-light">
        Delega el trabajo administrativo en Lissi. Desde la captura de datos en el cuarto de máquinas hasta el dashboard de tu cliente. Cero fricción, cero papel.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-auto md:auto-rows-[520px]">

      <div data-reveal class="bento-card md:col-span-2 group relative rounded-3xl bg-slate-900/50 border border-slate-700/50 overflow-hidden hover:border-cyan-500/50 transition-all duration-500 shadow-lg hover:shadow-[0_0_40px_rgba(0,229,255,0.1)]">
        <div class="card-glow"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-white/[0.03] to-transparent pointer-events-none"></div>
        <div class="absolute -top-32 -right-32 w-96 h-96 bg-cyan-500/20 rounded-full blur-[120px] pointer-events-none group-hover:bg-cyan-500/30 transition-colors duration-700"></div>
        
        <div class="relative h-full p-8 md:p-12 flex flex-col md:flex-row items-center gap-10">
          <div class="flex-1 relative z-10">
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20 font-mono text-[10px] uppercase tracking-wider text-cyan-400 mb-6">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
              Base de Datos por Activo
            </span>
            <h3 class="font-display text-3xl md:text-4xl font-extrabold text-white mb-5 tracking-tight">El ADN de cada equipo</h3>
            <p class="text-slate-400 leading-relaxed text-lg font-light">Una bitácora inmutable. Registra presiones, cambios de piezas, garantías y fotos. Si un técnico cambia, la información se queda en tu empresa.</p>
          </div>
          
          <div class="w-full md:w-[340px] rounded-2xl bg-[#0A0F1C]/80 backdrop-blur-xl border border-slate-700/80 p-6 shadow-2xl group-hover:-translate-y-2 transition-transform duration-700 ease-out relative z-10">
            <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
            
            <div class="flex justify-between items-center border-b border-slate-800 pb-4 mb-5">
              <div>
                <span class="block font-mono text-xs font-bold text-cyan-400 mb-0.5">CHILLER-04-A</span>
                <span class="block text-[10px] text-slate-500">Clínica Santa Maria</span>
              </div>
              <span class="inline-flex items-center gap-1.5 px-2 py-1 rounded-md bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[10px] font-bold">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>En línea
              </span>
            </div>
            
            <div class="relative pl-6 space-y-5">
              <div class="absolute left-[9px] top-2 bottom-2 w-px bg-gradient-to-b from-cyan-400 via-slate-700 to-transparent"></div>
              
              <div class="relative group/item cursor-default">
                <span class="absolute -left-[23px] top-1.5 w-3 h-3 rounded-full bg-[#0A0F1C] border-2 border-cyan-400 shadow-[0_0_10px_rgba(0,229,255,0.5)]"></span>
                <div class="flex justify-between items-start mb-1">
                  <span class="text-sm text-white font-semibold group-hover/item:text-cyan-300 transition-colors">Mantención preventiva</span>
                  <span class="font-mono text-[10px] text-cyan-500 bg-cyan-500/10 px-1.5 py-0.5 rounded">HOY</span>
                </div>
                <div class="flex items-center gap-2">
                  <div class="w-4 h-4 rounded-full bg-slate-800 flex items-center justify-center text-[8px] font-bold text-slate-300">JR</div>
                  <span class="text-[11px] text-slate-400">J. Ruiz adjuntó 4 fotos · 45 min</span>
                </div>
              </div>
              
              <div class="relative opacity-60">
                <span class="absolute -left-[23px] top-1.5 w-3 h-3 rounded-full bg-[#0A0F1C] border-2 border-slate-600"></span>
                <div class="flex justify-between items-start mb-1">
                  <span class="text-sm text-slate-300">Cambio filtro secador</span>
                  <span class="font-mono text-[10px] text-slate-500">28 NOV</span>
                </div>
                <span class="text-[11px] text-slate-500">Parámetros estabilizados</span>
              </div>
              
              <div class="relative opacity-40">
                <span class="absolute -left-[23px] top-1.5 w-3 h-3 rounded-full bg-[#0A0F1C] border-2 border-slate-700"></span>
                <div class="flex justify-between items-start mb-1">
                  <span class="text-sm text-slate-400">Instalación y Puesta en Marcha</span>
                  <span class="font-mono text-[10px] text-slate-600">03 OCT</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div data-reveal class="bento-card md:col-span-1 group relative rounded-3xl bg-slate-900/50 border border-slate-700/50 p-8 md:p-10 overflow-hidden hover:border-cyan-500/50 transition-all duration-500 shadow-lg flex flex-col">
        <div class="card-glow"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-white/[0.03] to-transparent pointer-events-none"></div>
        
        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 font-mono text-[10px] uppercase tracking-wider text-blue-400 mb-6 relative z-10 w-max">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          Telemetría General
        </span>
        <h3 class="font-display text-3xl font-bold text-white mb-3 tracking-tight relative z-10">Inteligencia Operativa</h3>
        <p class="text-slate-400 text-sm mb-8 leading-relaxed relative z-10 font-light">Cruza datos del rendimiento de tus técnicos, volumen de órdenes y contratos para tomar decisiones que aumenten la rentabilidad.</p>
        
        <div class="relative mt-auto h-40">
          <div class="absolute inset-0 grid grid-cols-4 grid-rows-3 gap-px opacity-10">
             {Array.from({length: 12}).map(() => <div class="border-b border-r border-white"></div>)}
          </div>
          <div class="relative z-10 flex items-baseline gap-2 mb-4">
            <span class="font-display text-4xl font-black text-white group-hover:text-cyan-300 transition-colors">+38%</span>
            <span class="font-mono text-[10px] text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20">↑ Productividad Q3</span>
          </div>
          
          <svg viewBox="0 0 280 100" class="w-full h-full overflow-visible" preserveAspectRatio="none">
            <defs>
              <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(0,229,255,0.3)"/>
                <stop offset="100%" stop-color="rgba(0,229,255,0)"/>
              </linearGradient>
            </defs>
            <path class="transition-all duration-700 group-hover:translate-y-[-2px]" d="M0,80 L40,65 L80,70 L120,45 L160,50 L200,25 L240,20 L280,5 L280,100 L0,100 Z" fill="url(#areaGrad)"/>
            <path class="bento-line drop-shadow-[0_5px_10px_rgba(0,229,255,0.4)]" d="M0,80 L40,65 L80,70 L120,45 L160,50 L200,25 L240,20 L280,5" fill="none" stroke="#00E5FF" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke"/>
            <circle cx="280" cy="5" r="5" fill="#0A0F1C" stroke="#00E5FF" stroke-width="3" class="bento-dot shadow-[0_0_15px_#00E5FF]"/>
          </svg>
        </div>
      </div>

      <div data-reveal class="bento-card md:col-span-1 group relative rounded-3xl bg-slate-900/50 border border-slate-700/50 p-8 md:p-10 overflow-hidden hover:border-cyan-500/50 transition-all duration-500 shadow-lg flex flex-col">
        <div class="card-glow"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-white/[0.03] to-transparent pointer-events-none"></div>
        
        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 font-mono text-[10px] uppercase tracking-wider text-emerald-400 mb-6 relative z-10 w-max">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Motor de Informes
        </span>
        <h3 class="font-display text-3xl font-bold text-white mb-3 tracking-tight relative z-10">Listos en segundos</h3>
        <p class="text-slate-400 text-sm mb-8 leading-relaxed relative z-10 font-light">Compila parámetros, checklist, firmas y fotos. Entregable en formato corporativo sin tocar Excel.</p>
        
        <div class="relative mt-auto rounded-2xl bg-[#0A0F1C]/90 border border-slate-700/80 p-5 group-hover:-translate-y-2 transition-transform duration-700 ease-out shadow-xl z-10">
          <div class="flex items-center gap-3 mb-4 pb-4 border-b border-slate-800">
            <div class="w-10 h-10 rounded-xl bg-slate-800 flex items-center justify-center border border-slate-700">
               <svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm-2.001 17h-2.126l.006-2.999h-1.879v-2.001h1.873l.005-2.001h-1.878v-1.999h1.884l.004-3h2.115l-.004 3h2.004l.005-3h2.122l-.005 3h1.88l.005 1.999h-1.885l-.004 2.001h1.878v2.001h-1.873l-.004 2.999h-2.122l.004-2.999h-2.005l-.004 2.999zm4.129-7.999h-2.004l-.004 2.001h2.004l.004-2.001z"/></svg>
            </div>
            <div class="flex-1">
              <div class="h-2 w-24 bg-slate-700 rounded mb-2"></div>
              <div class="h-1.5 w-16 bg-slate-800 rounded"></div>
            </div>
          </div>
          
          <div class="space-y-3 mb-5">
            {["Levantamiento térmico", "Fotografías (4)", "Firma del cliente"].map((item, i) => (
              <div class="flex items-center justify-between text-[11px]">
                <span class="text-slate-400">{item}</span>
                <div class="flex items-center gap-1.5">
                  <span class="font-mono text-cyan-400">OK</span>
                  <div class="w-3 h-3 rounded-full bg-cyan-500/20 flex items-center justify-center">
                    <svg class="w-2 h-2 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </div>
                </div>
              </div>
            ))}
          </div>
          
          <div class="relative overflow-hidden bg-white hover:bg-slate-100 rounded-xl p-3 flex justify-center items-center gap-2 cursor-pointer transition-colors">
             <div class="absolute left-0 inset-y-0 w-0 bg-cyan-100 group-hover:w-full transition-all duration-700 ease-out z-0"></div>
             <span class="relative z-10 font-bold text-[#0A0F1C] text-[11px] uppercase tracking-wider">Generar Entregable</span>
             <svg class="relative z-10 w-4 h-4 text-[#0A0F1C]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
        </div>
      </div>

      <div data-reveal class="bento-card md:col-span-2 group relative rounded-3xl bg-slate-900/50 border border-slate-700/50 overflow-hidden hover:border-cyan-500/50 transition-all duration-500 shadow-lg flex flex-col md:flex-row">
        <div class="card-glow"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-white/[0.03] to-transparent pointer-events-none"></div>
        <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-blue-500/20 rounded-full blur-[120px] pointer-events-none group-hover:bg-blue-500/30 transition-colors duration-700"></div>
        
        <div class="relative h-full p-8 md:p-12 flex flex-col md:flex-row gap-10 md:items-center z-10 w-full">
          <div class="md:w-2/5 flex-shrink-0">
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-violet-500/10 border border-violet-500/20 font-mono text-[10px] uppercase tracking-wider text-violet-400 mb-6">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Alertas y Oportunidades
            </span>
            <h3 class="font-display text-3xl md:text-4xl font-extrabold text-white mb-5 tracking-tight">Anticípate y vende más</h3>
            <p class="text-slate-400 leading-relaxed text-lg font-light">Lissi controla automáticamente las garantías y el calendario de mantenimientos. Detecta exactamente cuándo un equipo necesita servicio, convirtiendo datos en ventas recurrentes.</p>
          </div>
          
          <div class="w-full md:w-3/5 rounded-2xl bg-[#0A0F1C]/90 backdrop-blur-xl border border-slate-700/80 p-5 md:p-6 shadow-2xl group-hover:-translate-y-2 transition-transform duration-700 ease-out flex flex-col justify-center">
            
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between border-b border-slate-800 pb-4 mb-4 md:mb-5 gap-3 sm:gap-0">
              <div class="flex flex-wrap items-center gap-2 sm:gap-3">
                <span class="font-mono text-[11px] md:text-sm font-bold text-cyan-400">CHILLER-04-A</span>
                <span class="text-[8px] md:text-[10px] uppercase font-bold text-slate-500 bg-slate-800 px-1.5 md:px-2 py-0.5 rounded">Garantía Activa</span>
              </div>
              <span class="font-mono text-[9px] md:text-[10px] text-amber-400 bg-amber-500/10 border border-amber-500/20 px-2 py-1 rounded flex items-center gap-1.5 w-max">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span> Requiere Visita
              </span>
            </div>
            
            <div class="grid grid-cols-3 gap-2 md:gap-4 mb-5">
              <div class="rounded-xl bg-slate-900/80 border border-slate-800 p-2.5 md:p-4 hover:border-cyan-500/30 transition-colors flex flex-col justify-center">
                <p class="text-[8px] md:text-[10px] uppercase font-medium tracking-wider text-slate-500 mb-1 leading-tight">Próx. Mantención</p>
                <p class="font-display text-lg md:text-2xl font-black text-amber-400 leading-none">12<span class="text-[8px] md:text-[11px] font-medium text-amber-400/60 ml-0.5 md:ml-1">Días</span></p>
              </div>
              <div class="rounded-xl bg-slate-900/80 border border-slate-800 p-2.5 md:p-4 hover:border-cyan-500/30 transition-colors flex flex-col justify-center">
                <p class="text-[8px] md:text-[10px] uppercase font-medium tracking-wider text-slate-500 mb-1 leading-tight">Garantía Fab.</p>
                <div class="flex items-center gap-2">
                  <p class="font-display text-base md:text-xl font-black text-white leading-none mt-1">Activa</p>
                </div>
              </div>
              <div class="rounded-xl bg-slate-900/80 border border-slate-800 p-2.5 md:p-4 hover:border-cyan-500/30 transition-colors flex flex-col justify-center">
                <p class="text-[8px] md:text-[10px] uppercase font-medium tracking-wider text-slate-500 mb-1 leading-tight">Salud Equipo</p>
                <p class="font-display text-lg md:text-2xl font-black text-cyan-400 leading-none">85<span class="text-[9px] md:text-[11px] font-medium text-slate-500 ml-0.5 md:ml-1">%</span></p>
              </div>
            </div>
            
            <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-4">
              <div class="flex items-center justify-between mb-3">
                <span class="font-mono text-[8px] md:text-[9px] uppercase font-bold tracking-wider text-slate-400">Oportunidad de Negocio</span>
                <span class="font-mono text-[8px] md:text-[9px] text-amber-400 bg-amber-500/10 px-1.5 py-0.5 rounded">ALTA PROBABILIDAD</span>
              </div>
              <div class="flex flex-col gap-2 w-full">
                <p class="text-[11px] md:text-xs text-white leading-tight">Contrato de mantención preventiva por vencer en 12 días.</p>
                <div class="h-2 w-full bg-slate-800 rounded-full overflow-hidden mt-1">
                  <div class="h-full bg-gradient-to-r from-amber-500 to-amber-300 w-[90%] animate-pulse"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="mt-24">
      <div class="flex items-center gap-6 mb-10">
        <div class="flex items-center gap-2">
           <svg class="w-4 h-4 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
           <p class="font-mono text-sm uppercase tracking-widest text-white font-bold">Módulos del Ecosistema</p>
        </div>
        <div class="h-px flex-1 bg-gradient-to-r from-slate-700 to-transparent"></div>
      </div>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {extras.map((e) => (
          <div data-reveal class={`bento-card group relative rounded-2xl backdrop-blur-sm p-7 overflow-hidden transition-all duration-300 ${e.soon ? 'bg-slate-900 border border-amber-500/40 hover:bg-slate-800 hover:border-amber-400 shadow-[0_0_20px_rgba(245,158,11,0.1)]' : 'bg-slate-900/30 border border-slate-800 hover:bg-slate-800/80 hover:border-cyan-500/40'}`}>
            <div class="card-glow"></div>
            
            {e.soon && <div class="absolute -top-10 -right-10 w-32 h-32 bg-amber-500/10 rounded-full blur-[40px] pointer-events-none group-hover:bg-amber-500/20 transition-colors"></div>}
            
            <div class="relative z-10">
              <div class="flex justify-between items-start mb-6">
                <div class={`w-12 h-12 rounded-xl bg-[#0A0F1C] border flex items-center justify-center transition-all duration-300 ${e.soon ? 'border-amber-500/30 text-amber-400 group-hover:border-amber-400 group-hover:shadow-[0_0_15px_rgba(245,158,11,0.3)]' : 'border-slate-700 text-slate-400 group-hover:border-cyan-500/40 group-hover:bg-cyan-500/10 group-hover:text-cyan-400 group-hover:shadow-[0_0_15px_rgba(0,229,255,0.15)]'}`}>
                  <svg class="w-5 h-5 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d={e.icon}/></svg>
                </div>
                <span class={`font-mono text-[10px] uppercase font-bold tracking-wider transition-colors ${e.soon ? 'text-amber-500' : 'text-slate-500 group-hover:text-cyan-400'}`}>{e.tag}</span>
              </div>
              
              <div class="flex items-center gap-3 mb-3">
                <h4 class={`font-display text-lg font-bold ${e.soon ? 'text-white' : 'text-white'}`}>{e.t}</h4>
                {e.soon && <span class="font-mono text-[9px] font-bold uppercase tracking-widest text-amber-950 bg-amber-400 px-2 py-0.5 rounded shadow-[0_0_10px_rgba(245,158,11,0.4)]">Pronto</span>}
              </div>
              
              <p class="text-sm text-slate-400 leading-relaxed font-light">{e.d}</p>
            </div>
            
            <div class={`absolute bottom-0 inset-x-0 h-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300 ${e.soon ? 'bg-gradient-to-r from-amber-500 to-orange-400' : 'bg-gradient-to-r from-cyan-500 to-blue-500'}`}></div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .bento-aurora { animation: bento-aurora-move 25s ease-in-out infinite alternate; }
  .bento-aurora-delayed { animation: bento-aurora-move 30s ease-in-out infinite alternate-reverse; }
  @keyframes bento-aurora-move { 
    0% { transform: translate(0,0) scale(1); } 
    100% { transform: translate(100px, 50px) scale(1.2); } 
  }

  .card-glow {
    position: absolute; inset: -1px; opacity: 0; transition: opacity .4s ease; pointer-events: none; z-index: 0;
    background: radial-gradient(600px circle at var(--mx,50%) var(--my,50%), rgba(0,229,255,0.12), rgba(16,185,129,0.05) 40%, transparent 70%);
  }
  .bento-card:hover .card-glow { opacity: 1; }

  .bento-line { stroke-dasharray: 800; stroke-dashoffset: 800; }
  .bento-card.is-visible .bento-line, .is-visible .bento-line { animation: bento-draw 2s cubic-bezier(0.22, 1, 0.36, 1) .2s forwards; }
  @keyframes bento-draw { to { stroke-dashoffset: 0; } }
  
  .bento-dot { opacity: 0; transform-origin: center; transform: scale(0.5); }
  .is-visible .bento-dot { animation: bento-dot-in .6s cubic-bezier(0.175, 0.885, 0.32, 1.275) 1.8s forwards; }
  @keyframes bento-dot-in { to { opacity: 1; transform: scale(1); } }

  @media (prefers-reduced-motion: reduce) {
    .bento-aurora, .bento-aurora-delayed { animation: none; }
    .bento-line { stroke-dashoffset: 0; }
    .bento-dot { opacity: 1; transform: scale(1); }
  }
</style>

<script>
  function initBento() {
    document.querySelectorAll('.bento-card').forEach((card) => {
      const el = card as HTMLElement;
      if (el.dataset.glowInit) return;
      el.dataset.glowInit = '1';
      
      el.addEventListener('mousemove', (e) => {
        const r = el.getBoundingClientRect();
        el.style.setProperty('--mx', `${e.clientX - r.left}px`);
        el.style.setProperty('--my', `${e.clientY - r.top}px`);
      });
      el.addEventListener('mouseleave', () => {
         el.style.setProperty('--mx', `50%`);
         el.style.setProperty('--my', `50%`);
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('[data-reveal]').forEach((el) => {
      observer.observe(el);
    });
  }
  
  initBento();
  document.addEventListener('astro:page-load', initBento);
</script>