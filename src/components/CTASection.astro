---
// src/components/CTASection.astro
const SIGNUP_URL = "https://app.lissi.app/signup";
---
<section class="relative bg-[#0A0F1C] py-28 md:py-40 overflow-hidden border-t border-slate-800/50">

  <div class="absolute inset-0 pointer-events-none opacity-[0.15]"
       style="background-image: linear-gradient(rgba(0,229,255,0.2) 1px, transparent 1px), linear-gradient(90deg, rgba(0,229,255,0.2) 1px, transparent 1px); background-size: 64px 64px; mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 80%);">
  </div>

  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[600px] bg-cyan-600/10 rounded-full blur-[160px] pointer-events-none cta-breathe mix-blend-screen z-0"></div>
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-[140px] pointer-events-none mix-blend-screen z-0"></div>

  <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.15] z-0">
    <div class="font-mono text-cyan-400/50 text-[10px] leading-loose tracking-[0.3em] select-none hidden lg:block">
      <p>SYS.STATUS // ONLINE</p>
      <p>UNITS.MONITORED // 12,842</p>
      <p>LATENCY // 12ms</p>
      <p>ENCRYPTION // AES-256</p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">

    <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full border border-cyan-500/20 bg-[#0A0F1C]/50 backdrop-blur-md mb-10 shadow-[0_0_15px_rgba(0,229,255,0.1)]">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500 shadow-[0_0_8px_#00E5FF]"></span>
      </span>
      <span class="font-mono text-[10px] font-bold tracking-widest uppercase text-cyan-300">Lanzamiento Oficial 2026</span>
    </div>

    <h2 class="font-display text-5xl md:text-[5.5rem] font-black text-white tracking-tight leading-[1.05] mb-8">
      Ordena tu operación<br>
      <span class="relative inline-block mt-2">
        <span class="bg-gradient-to-r from-cyan-300 via-cyan-400 to-blue-500 bg-clip-text text-transparent drop-shadow-md">empezando hoy.</span>
        
        <svg class="absolute -bottom-2 md:-bottom-4 left-0 w-full" height="12" viewBox="0 0 300 12" fill="none" preserveAspectRatio="none">
          <path class="cta-underline drop-shadow-[0_2px_4px_rgba(0,229,255,0.5)]" d="M2 8 Q150 2 298 8" stroke="url(#ctaGrad)" stroke-width="3" stroke-linecap="round" fill="none"/>
          <defs>
            <linearGradient id="ctaGrad" x1="0" y1="0" x2="300" y2="0" gradientUnits="userSpaceOnUse">
              <stop stop-color="#00E5FF"/><stop offset="1" stop-color="#3B82F6"/>
            </linearGradient>
          </defs>
        </svg>
      </span>
    </h2>

    <p class="text-lg md:text-xl text-slate-400 mb-12 max-w-2xl mx-auto leading-relaxed font-light">
      Únete a las más de <span class="text-white font-medium">100 empresas HVAC-R</span> que cambiaron el papel y el Excel por el estándar de la industria.
    </p>

    <div class="flex flex-col items-center gap-6">
      
      <a href={SIGNUP_URL} class="group relative inline-flex items-center justify-center gap-3 px-10 py-5 bg-white text-[#0A0F1C] rounded-2xl font-bold text-lg overflow-hidden transition-all hover:scale-[1.02] active:scale-[0.98] shadow-[0_0_40px_rgba(255,255,255,0.15)] hover:shadow-[0_0_50px_rgba(255,255,255,0.25)]">
        <span class="relative z-10 flex items-center gap-2">
          Empieza tus 21 días gratis
          <svg class="w-5 h-5 text-cyan-600 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </span>
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-cyan-100/50 to-transparent opacity-0 group-hover:opacity-100 translate-x-[-100%] group-hover:animate-shine z-0"></div>
      </a>

      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3 font-mono text-[11px] font-medium uppercase tracking-wider text-slate-400">
        <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Sin tarjeta de crédito</span>
        <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Cancela cuando quieras</span>
        <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Setup en 5 minutos</span>
      </div>

      <button onclick="window.openCalendly()" class="mt-4 text-sm font-medium text-slate-500 hover:text-cyan-400 transition-colors cursor-pointer border-b border-transparent hover:border-cyan-400 pb-0.5">
        ¿Operación muy grande? Agenda una demo corporativa
      </button>
      
    </div>

  </div>
</section>

<style>
  /* Respiración del Glow central */
  @keyframes cta-breathe {
    0%, 100% { opacity: 0.3; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.6; transform: translate(-50%, -50%) scale(1.1); }
  }
  .cta-breathe { animation: cta-breathe 8s ease-in-out infinite; }

  /* Subrayado SVG Animado */
  .cta-underline {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
  }
  /* Usa la clase is-visible inyectada por un observer o déjala correr al cargar si la sección ya se ve */
  section.is-visible .cta-underline {
    animation: cta-draw 1.5s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
  }
  @keyframes cta-draw { to { stroke-dashoffset: 0; } }

  /* Brillo del botón */
  @keyframes shine {
    100% { transform: translateX(100%); }
  }
  .animate-shine { animation: shine 1s ease-out forwards; }

  @media (prefers-reduced-motion: reduce) {
    .cta-breathe, .animate-shine { animation: none; }
    .cta-underline { stroke-dashoffset: 0; }
  }
</style>

<script>
  function initCTA() {
    const section = document.querySelector('.cta-underline').closest('section');
    if (!section) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });

    observer.observe(section);
  }
  
  initCTA();
  document.addEventListener('astro:page-load', initCTA);
</script>