---
// src/components/Stats.astro
const stats = [
  { 
    label: "Productividad", 
    value: "+25%", 
    desc: "Más servicios facturables por técnico cada mes."
  },
  { 
    label: "Precisión", 
    value: "99%", 
    desc: "Eliminación de errores en informes y cobros."
  },
  { 
    label: "Ahorro Admin", 
    value: "15h", 
    desc: "Horas recuperadas a la semana en gestión."
  }
];
---

<section class="py-8 md:py-12 bg-white relative overflow-hidden">
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-blue-500/5 rounded-full blur-[80px] -z-10"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-12 max-w-3xl mx-auto">
      <span class="text-blue-600 font-bold tracking-wider uppercase text-xs mb-3 block">
        Retorno de Inversión
      </span>
      
      <h3 class="text-3xl md:text-5xl font-extrabold tracking-tight text-slate-900">
        Resultados tangibles<br class="hidden md:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-700 via-blue-600 to-cyan-500">
          desde el primer mes.
        </span>
      </h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {stats.map((stat) => (
        <div class="group relative p-8 rounded-[2rem] bg-white border border-slate-100 shadow-xl shadow-slate-200/40 hover:shadow-2xl hover:shadow-blue-500/10 hover:-translate-y-1 transition-all duration-500 text-center">
          
          <div class="relative z-10">
            <div class="text-6xl md:text-7xl font-black mb-2 tracking-tighter text-slate-900 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-blue-600 group-hover:to-cyan-500 transition-all duration-500">
              {stat.value}
            </div>
            
            <div class="text-xs font-bold text-blue-600 mb-3 uppercase tracking-widest bg-blue-50 px-3 py-1 rounded-full inline-block">
              {stat.label}
            </div>
            
            <p class="text-slate-500 text-base leading-snug font-medium max-w-[220px] mx-auto text-balance">
              {stat.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>