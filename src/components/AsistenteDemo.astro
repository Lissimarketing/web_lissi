---
// src/components/AsistenteDemo.astro
---
<section class="relative bg-[#0A0F1C] pt-20 md:pt-32 pb-24 md:pb-32 overflow-hidden border-t border-slate-800/50">
  
  <div class="absolute inset-0 pointer-events-none opacity-[0.15]"
       style="background-image: linear-gradient(rgba(0,229,255,0.2) 1px, transparent 1px), linear-gradient(90deg, rgba(0,229,255,0.2) 1px, transparent 1px); background-size: 64px 64px; mask-image: radial-gradient(ellipse 80% 60% at 70% 50%, black 30%, transparent 80%);"></div>
       
  <div class="absolute top-1/2 right-0 lg:right-[10%] -translate-y-1/2 w-[700px] h-[700px] bg-cyan-600/10 rounded-full blur-[160px] pointer-events-none asi-breathe mix-blend-screen"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <div>
        
        <div class="relative w-24 h-24 mb-10 group cursor-default">
          <div class="absolute inset-0 bg-cyan-500/20 rounded-full blur-2xl group-hover:bg-cyan-400/30 transition-colors duration-700"></div>
          <svg viewBox="0 0 100 100" class="w-full h-full relative z-10">
            <defs>
              <linearGradient id="orbCore" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#7df0ff"/>
                <stop offset="50%" stop-color="#00bcd4"/>
                <stop offset="100%" stop-color="#0284c7"/>
              </linearGradient>
              <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                <feGaussianBlur stdDeviation="4" result="blur" />
                <feComposite in="SourceGraphic" in2="blur" operator="over" />
              </filter>
            </defs>
            <ellipse cx="50" cy="50" rx="46" ry="14" fill="none" stroke="rgba(0,229,255,0.2)" stroke-width="1" class="orb-ring orb-ring-1"/>
            <ellipse cx="50" cy="50" rx="46" ry="14" fill="none" stroke="rgba(0,229,255,0.3)" stroke-width="1.5" class="orb-ring orb-ring-2" stroke-dasharray="8 4"/>
            <ellipse cx="50" cy="50" rx="46" ry="14" fill="none" stroke="rgba(16,185,129,0.2)" stroke-width="2" class="orb-ring orb-ring-3" stroke-dasharray="20 10"/>
            
            <g class="orb-nodes opacity-70">
              <circle cx="20" cy="30" r="1.5" fill="#7df0ff" class="node-pulse-1"/>
              <circle cx="80" cy="70" r="1.5" fill="#7df0ff" class="node-pulse-2"/>
              <circle cx="75" cy="25" r="2" fill="#34d399" class="node-pulse-3"/>
              <circle cx="25" cy="75" r="1" fill="#7df0ff" class="node-pulse-1"/>
            </g>

            <circle cx="50" cy="50" r="16" fill="url(#orbCore)" filter="url(#glow)" class="orb-core"/>
            <circle cx="50" cy="50" r="22" fill="none" stroke="rgba(0,229,255,0.4)" stroke-width="0.5" class="orb-core-pulse"/>
          </svg>
        </div>

        <div class="flex items-center gap-2 mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></span>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-cyan-400">Lissi Copilot AI</p>
        </div>
        
        <h2 class="font-display text-4xl md:text-[3.25rem] font-black text-white tracking-tight mb-6 leading-[1.05]">
          Un despachador experto.<br/>
          <span class="text-slate-400 font-light">En tu bolsillo.</span>
        </h2>
        
        <p class="text-lg text-slate-300 leading-relaxed mb-8 max-w-lg font-light">
          No es un simple chatbot. Es un agente autónomo que cruza datos de tu operación en tiempo real. Escríbele o háblale en lenguaje natural y él orquesta el resto.
        </p>
        
        <ul class="space-y-4">
          {[
            { t: "Procesamiento de Lenguaje Natural (NLP)", d: "Entiende jerga técnica y audios con ruido de sala de máquinas." },
            { t: "Recuperación de Contexto", d: "Busca historiales de equipos y técnicos disponibles antes de actuar." },
            { t: "Ejecución Autónoma", d: "Crea la OT, notifica al técnico y actualiza el dashboard." }
          ].map((item) => (
            <li class="flex items-start gap-4 p-4 rounded-xl bg-slate-900/40 border border-slate-800/50 hover:bg-slate-800/60 transition-colors">
              <div class="mt-0.5 w-6 h-6 rounded-full bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <p class="text-sm font-bold text-white mb-0.5">{item.t}</p>
                <p class="text-xs text-slate-400 leading-relaxed">{item.d}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div data-reveal class="relative lg:ml-auto w-full max-w-lg perspective-1000">
        <div class="relative rounded-2xl bg-[#0A0F1C]/95 backdrop-blur-2xl border border-slate-700/80 shadow-2xl shadow-cyan-900/20 overflow-hidden transform rotate-y-[-2deg] rotate-x-[1deg] transition-transform duration-700 hover:rotate-y-0 hover:rotate-x-0">
          
          <div class="absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-transparent via-cyan-400 to-transparent opacity-80"></div>

          <div class="flex items-center justify-between px-5 h-14 border-b border-slate-800 bg-slate-900/50">
            <div class="flex items-center gap-3">
              <div class="flex gap-1.5">
                <span class="w-3 h-3 rounded-full bg-slate-700 border border-slate-600"></span>
                <span class="w-3 h-3 rounded-full bg-slate-700 border border-slate-600"></span>
                <span class="w-3 h-3 rounded-full bg-slate-700 border border-slate-600"></span>
              </div>
            </div>
            
            <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-slate-950 border border-slate-800">
              <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_8px_#34d399]"></span>
              <span class="font-mono text-[10px] text-slate-300 tracking-wider">AGENT_ONLINE</span>
            </div>
          </div>

          <div id="chat-feed" class="p-5 space-y-5 h-[480px] overflow-y-auto flex flex-col justify-start scrollbar-hide relative bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wMykiLz48L3N2Zz4=')]">
            </div>

          <div class="px-5 pb-5 pt-2 bg-gradient-to-t from-[#0A0F1C] to-transparent">
            <div class="flex items-end gap-3 rounded-xl bg-slate-900 border border-slate-700 p-3 shadow-inner">
              <span id="chat-input-text" class="flex-1 text-sm text-white font-mono min-h-[20px] leading-relaxed break-words"></span>
              <span class="w-8 h-8 rounded-lg bg-cyan-500 hover:bg-cyan-400 transition-colors flex items-center justify-center flex-shrink-0 cursor-pointer shadow-[0_0_15px_rgba(0,229,255,0.3)]">
                <svg class="w-4 h-4 text-navy-950 translate-x-[1px] translate-y-[-1px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              </span>
            </div>
            <p class="text-center mt-3 font-mono text-[9px] text-slate-500 uppercase tracking-widest">Lissi LLM · Procesamiento en la nube</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Custom Scrollbar hide */
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

  /* Orb Animations */
  .asi-breathe { animation: asi-breathe 8s ease-in-out infinite alternate; }
  @keyframes asi-breathe { 0% { opacity: 0.4; transform: scale(0.95); } 100% { opacity: 0.7; transform: scale(1.1); } }

  .orb-core { transform-origin: center; animation: orb-pulse 4s cubic-bezier(0.4, 0, 0.2, 1) infinite; }
  .orb-core-pulse { transform-origin: center; animation: core-ring-pulse 2s linear infinite; }
  @keyframes orb-pulse { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.15); opacity: 0.8; } }
  @keyframes core-ring-pulse { 0% { transform: scale(0.8); opacity: 1; } 100% { transform: scale(1.8); opacity: 0; } }

  .orb-ring { transform-origin: center; }
  .orb-ring-1 { animation: orb-spin 8s linear infinite; }
  .orb-ring-2 { transform: rotate(60deg); animation: orb-spin2 12s linear infinite; }
  .orb-ring-3 { transform: rotate(120deg); animation: orb-spin 15s linear infinite reverse; }
  @keyframes orb-spin { from { transform: rotate(0); } to { transform: rotate(360deg); } }
  @keyframes orb-spin2 { from { transform: rotate(60deg); } to { transform: rotate(420deg); } }

  .node-pulse-1 { animation: node-blink 2s infinite; }
  .node-pulse-2 { animation: node-blink 3s infinite 1s; }
  .node-pulse-3 { animation: node-blink 1.5s infinite 0.5s; }
  @keyframes node-blink { 0%, 100% { opacity: 0.2; } 50% { opacity: 1; box-shadow: 0 0 10px #7df0ff; } }

  /* Chat Animations */
  .chat-cursor::after { content: '▍'; color: #00E5FF; animation: blink 1s step-end infinite; margin-left: 2px; text-shadow: 0 0 5px #00E5FF; }
  @keyframes blink { 50% { opacity: 0; } }

  .thinking-step { opacity: 0; animation: step-fade-in 0.3s ease forwards; }
  @keyframes step-fade-in { to { opacity: 1; transform: translateY(0); } }

  @media (prefers-reduced-motion: reduce) {
    .asi-breathe, .orb-core, .orb-core-pulse, .orb-ring, .node-pulse-1, .node-pulse-2, .node-pulse-3 { animation: none; }
  }
</style>

<script>
  function initAsistente() {
    const feed = document.getElementById('chat-feed');
    const inputText = document.getElementById('chat-input-text');
    if (!feed || feed.dataset.init) return;
    feed.dataset.init = '1';

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

    // Guion B2B avanzado simulando RAG y extracción de entidades
    const guion = [
      { side: 'user', text: 'Se reportó una falla de alta presión en el chiller de Clínica Bascur.' },
      { 
        side: 'bot', 
        steps: ['Analizando intención de mantenimiento', 'Buscando historial de "Clínica Bascur"', 'Cruzando datos con telemetría de activos'], 
        text: 'He detectado que el Chiller-04-A de esa sede tuvo la misma falla hace 3 meses. El técnico más cercano es César (a 12 min). ¿Le asigno una visita de emergencia?' 
      },
      { side: 'user', text: 'Sí, despáchalo urgente y adjúntale el manual del equipo a la orden.' },
      { 
        side: 'bot', 
        steps: ['Generando OT-8492', 'Adjuntando PDF: Manual_Daikin_Scroll.pdf', 'Notificando a César vía App'],
        card: true, 
        text: 'Orden de emergencia despachada y notificada.', 
        meta: { id: 'OT-8492', cliente: 'Clínica Bascur', tech: 'César', status: 'Despachado' }
      },
    ];

    function makeRow(side) {
      const row = document.createElement('div');
      row.className = 'flex w-full ' + (side === 'user' ? 'justify-end' : 'justify-start');
      return row;
    }

    // El nuevo "Thinking Bubble" estilo motor de búsqueda IA
    async function showThinkingSteps(steps) {
      const row = makeRow('bot');
      const container = document.createElement('div');
      container.className = 'max-w-[85%] rounded-2xl bg-slate-900/50 border border-slate-800 px-4 py-3 text-[11px] font-mono text-slate-400 space-y-2';
      row.appendChild(container);
      feed.appendChild(row);
      feed.scrollTop = feed.scrollHeight;

      for (let i = 0; i < steps.length; i++) {
        const stepEl = document.createElement('div');
        stepEl.className = 'flex items-center gap-2 thinking-step translate-y-1';
        stepEl.innerHTML = `<svg class="w-3 h-3 text-cyan-500 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <span>${steps[i]}...</span>`;
        container.appendChild(stepEl);
        feed.scrollTop = feed.scrollHeight;
        await sleep(reduce ? 200 : 700 + Math.random() * 400); // Tiempos variables para simular procesamiento
        
        // Convertir spinner a check
        stepEl.innerHTML = `<svg class="w-3 h-3 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> <span class="text-slate-300">${steps[i]}</span>`;
      }
      
      await sleep(400);
      row.remove(); // Quita el bloque de pensamiento para dar paso a la respuesta
    }

    async function typeInto(el, text, speed) {
      for (let i = 0; i < text.length; i++) {
        el.textContent = text.slice(0, i + 1);
        feed.scrollTop = feed.scrollHeight;
        await sleep(speed);
      }
    }

    async function userMessage(text) {
      inputText.classList.add('chat-cursor');
      for (let i = 0; i < text.length; i++) {
        inputText.textContent = text.slice(0, i + 1);
        await sleep(reduce ? 0 : 25 + Math.random() * 20); // Tipado humano irregular
      }
      await sleep(reduce ? 0 : 300);
      inputText.classList.remove('chat-cursor');
      inputText.textContent = '';
      
      const row = makeRow('user');
      const b = document.createElement('div');
      b.className = 'max-w-[85%] rounded-2xl rounded-tr-sm bg-gradient-to-br from-cyan-600 to-blue-600 text-white px-4 py-3 text-sm shadow-[0_4px_15px_rgba(0,229,255,0.2)]';
      b.textContent = text;
      b.style.opacity = '0'; b.style.transform = 'translateY(10px) scale(.98)';
      row.appendChild(b);
      feed.appendChild(row);
      
      requestAnimationFrame(() => {
        b.style.transition = 'all .4s cubic-bezier(0.16,1,0.3,1)';
        b.style.opacity = '1'; b.style.transform = 'none';
      });
      feed.scrollTop = feed.scrollHeight;
    }

    async function botMessage(msg) {
      if (msg.steps) {
        await showThinkingSteps(msg.steps);
      }

      const row = makeRow('bot');
      
      if (msg.card) {
        // Tarjeta de sistema compleja (Bento style)
        const c = document.createElement('div');
        c.className = 'w-full max-w-[90%] rounded-2xl rounded-tl-sm bg-[#0A0F1C] border border-cyan-500/30 overflow-hidden shadow-lg';
        
        c.innerHTML = `
          <div class="p-4 bg-slate-900/50 border-b border-slate-800">
            <div class="flex items-center gap-2 mb-2">
              <span class="w-6 h-6 rounded-full bg-emerald-500/20 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              <span class="text-sm font-bold text-white check-text"></span>
            </div>
            <p class="text-[11px] text-slate-400 font-mono">Tarea ejecutada por Lissi AI</p>
          </div>
          <div class="p-4 grid grid-cols-2 gap-2 bg-[#0A0F1C]">
            <div class="bg-slate-900/80 rounded border border-slate-800 p-2">
              <p class="text-[9px] uppercase tracking-wider text-slate-500 mb-0.5">Nº Orden</p>
              <p class="font-mono text-xs text-cyan-400 font-bold">${msg.meta.id}</p>
            </div>
            <div class="bg-slate-900/80 rounded border border-slate-800 p-2">
              <p class="text-[9px] uppercase tracking-wider text-slate-500 mb-0.5">Estado</p>
              <p class="text-xs text-emerald-400 font-bold flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>${msg.meta.status}</p>
            </div>
            <div class="col-span-2 bg-slate-900/80 rounded border border-slate-800 p-2 mt-1">
              <p class="text-[9px] uppercase tracking-wider text-slate-500 mb-0.5">Asignación Terreno</p>
              <p class="text-xs text-white">${msg.meta.cliente} <span class="text-slate-500 mx-1">→</span> Téc. ${msg.meta.tech}</p>
            </div>
          </div>
        `;
        c.style.opacity = '0'; c.style.transform = 'translateY(10px)';
        row.appendChild(c);
        feed.appendChild(row);
        
        requestAnimationFrame(() => {
          c.style.transition = 'all .5s cubic-bezier(0.16,1,0.3,1)';
          c.style.opacity = '1'; c.style.transform = 'none';
        });
        await typeInto(c.querySelector('.check-text'), msg.text, reduce ? 0 : 20);
      } else {
        // Mensaje de texto normal del bot
        const b = document.createElement('div');
        b.className = 'max-w-[85%] rounded-2xl rounded-tl-sm bg-slate-800/80 backdrop-blur-sm text-slate-200 px-4 py-3 text-sm border border-slate-700 leading-relaxed';
        b.classList.add('chat-cursor');
        row.appendChild(b);
        feed.appendChild(row);
        await typeInto(b, msg.text, reduce ? 0 : 18);
        b.classList.remove('chat-cursor');
      }
      feed.scrollTop = feed.scrollHeight;
    }

    async function run() {
      feed.innerHTML = '';
      inputText.textContent = '';
      await sleep(600);
      for (const msg of guion) {
        if (msg.side === 'user') { await userMessage(msg.text); }
        else { await botMessage(msg); }
        await sleep(reduce ? 200 : 800);
      }
      await sleep(6000);
      run(); // Loop
    }

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !feed.dataset.running) {
          feed.dataset.running = '1';
          run();
          io.unobserve(feed);
        }
      });
    }, { threshold: 0.2 });
    
    // Iniciar con un pequeño delay de la animación del orbe
    setTimeout(() => io.observe(feed), 500);
  }
  
  initAsistente();
  document.addEventListener('astro:page-load', initAsistente);
</script>