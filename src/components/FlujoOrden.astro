---
// src/components/FlujoOrden.astro
const pasos = [
  { n: "01", t: "Llega la solicitud", d: "Un cliente pide servicio. Entra a Lissi y queda registrada al instante, sin perderse en WhatsApp ni correos." },
  { n: "02", t: "Se crea la orden", d: "Asignas técnico, cliente y equipos en segundos — o se lo dictas al Asistente Lissi y la arma por ti." },
  { n: "03", t: "El técnico va a terreno", d: "Recibe la orden en su teléfono. Funciona sin señal, escanea el equipo y registra todo en el lugar." },
  { n: "04", t: "Genera el informe", d: "Con parámetros, fotos y firma del cliente. El PDF profesional sale en minutos, listo para enviar." },
  { n: "05", t: "Queda en el historial", d: "Todo se guarda en la hoja de vida del equipo. La próxima vez sabes al instante qué pasó antes." },
];
---
<section class="relative bg-navy-950 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none opacity-[0.13]"
       style="background-image: linear-gradient(rgba(0,188,212,0.4) 1px, transparent 1px), linear-gradient(90deg, rgba(0,188,212,0.4) 1px, transparent 1px); background-size: 56px 56px; mask-image: radial-gradient(ellipse 80% 50% at 50% 50%, black 30%, transparent 90%);"></div>
  <div id="flujo-aura" class="absolute top-1/2 right-[8%] -translate-y-1/2 w-[600px] h-[600px] rounded-full blur-[150px] pointer-events-none transition-colors duration-1000" style="background: rgba(0,188,212,0.10);"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">

    <div class="pt-24 md:pt-32 pb-12 max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-cyan-400 mb-4">// El ciclo completo</p>
      <h2 class="font-display text-4xl md:text-5xl font-extrabold text-white tracking-[-0.02em] mb-5 text-balance">
        De la solicitud al historial, sin perder un dato.
      </h2>
      <p class="text-lg text-navy-300 leading-relaxed">
        Así fluye una orden de trabajo en Lissi. Cada paso conectado con el siguiente.
      </p>
    </div>

    <!-- DESKTOP -->
    <div id="flujo-wrap" class="hidden lg:grid grid-cols-[1fr_1.1fr] gap-16 pb-24">

      <!-- Pasos -->
      <div class="flex flex-col justify-center gap-1 py-[18vh]">
        {pasos.map((p, i) => (
          <div class="flujo-step group relative pl-10 py-5 cursor-default" data-step={i}>
            <span class="absolute left-0 top-0 bottom-0 w-px bg-navy-800"></span>
            <span class="flujo-bar absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-0 bg-gradient-to-b from-cyan-300 to-cyan-500 transition-all duration-500 rounded-full shadow-[0_0_12px_rgba(0,188,212,0.6)]"></span>
            <div class="flex items-center gap-3 mb-1.5">
              <span class="flujo-num font-mono text-xs text-navy-600 transition-colors duration-500">{p.n}</span>
              <h3 class="flujo-title font-display text-2xl font-bold text-navy-600 transition-all duration-500">{p.t}</h3>
            </div>
            <p class="flujo-desc text-sm text-navy-700 leading-relaxed transition-all duration-500 max-w-md max-h-0 opacity-0 overflow-hidden">{p.d}</p>
          </div>
        ))}
      </div>

      <!-- Panel pegado -->
      <div class="relative">
        <div class="sticky top-0 h-screen flex items-center">
          <div class="w-full">
            <div class="relative rounded-3xl bg-navy-900/70 backdrop-blur-xl border border-navy-700/60 shadow-2xl shadow-cyan-500/10 overflow-hidden">
              <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-400/70 to-transparent"></div>

              <!-- barra de progreso superior -->
              <div class="h-1 bg-navy-800/60">
                <div id="flujo-progress" class="h-full bg-gradient-to-r from-cyan-400 to-cyan-500 transition-all duration-500" style="width:20%"></div>
              </div>

              <!-- header del panel -->
              <div class="flex items-center justify-between px-6 h-14 border-b border-navy-800">
                <div class="flex items-center gap-2">
                  <span id="flujo-step-label" class="font-mono text-xs text-cyan-400">PASO 01 / 05</span>
                </div>
                <div class="flex gap-1.5">
                  {pasos.map((_, i) => (
                    <span class="flujo-dot w-1.5 h-1.5 rounded-full bg-navy-700 transition-all duration-300" data-dot={i}></span>
                  ))}
                </div>
              </div>

              <!-- viewport del panel -->
              <div class="relative h-[360px]">
                <span id="flujo-bignum" class="absolute -bottom-8 right-2 font-display text-[180px] leading-none font-extrabold text-navy-800/30 select-none pointer-events-none transition-all duration-500">01</span>

                <!-- PANEL 0 -->
                <div class="flujo-panel absolute inset-0 p-8 flex flex-col justify-center" data-panel="0">
                  <div class="fp-item flex items-start gap-4 rounded-2xl bg-navy-950/80 border border-navy-700/60 p-5 shadow-xl">
                    <div class="relative w-11 h-11 rounded-xl bg-cyan-500/15 flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.4-1.4A2 2 0 0118 14.2V11a6 6 0 00-4-5.7V5a2 2 0 10-4 0v.3C7.7 6.2 6 8.4 6 11v3.2c0 .5-.2 1-.6 1.4L4 17h5m6 0v1a3 3 0 11-6 0v-1"/></svg>
                      <span class="fp-ping absolute -top-1 -right-1 w-3 h-3 rounded-full bg-cyan-400 ring-2 ring-navy-950"></span>
                    </div>
                    <div class="flex-1">
                      <div class="flex justify-between items-center mb-1">
                        <span class="text-sm font-semibold text-white">Nueva solicitud</span>
                        <span class="font-mono text-[10px] text-cyan-400">AHORA</span>
                      </div>
                      <p class="text-xs text-navy-300">Clínica Bascur, Concepción — falla en climatización sala 3.</p>
                    </div>
                  </div>
                  <div class="fp-item mt-3 flex items-center gap-3 rounded-xl bg-navy-950/50 border border-navy-800 px-4 py-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-cyan-400"></span>
                    <span class="text-xs text-navy-300 flex-1">Registrada automáticamente</span>
                    <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </div>
                </div>

                <!-- PANEL 1 -->
                <div class="flujo-panel absolute inset-0 p-8 flex flex-col justify-center opacity-0" data-panel="1">
                  <div class="rounded-2xl bg-navy-950/80 border border-navy-700/60 p-5 shadow-xl">
                    <div class="flex justify-between items-center mb-4">
                      <span class="font-mono text-xs text-cyan-400">OT-2026-014</span>
                      <span class="font-mono text-[10px] text-navy-500">Creando…</span>
                    </div>
                    <div class="space-y-3">
                      <div class="fp-row flex justify-between text-sm"><span class="text-navy-400">Tipo</span><span class="text-white font-medium">Mantenimiento preventivo</span></div>
                      <div class="fp-row flex justify-between text-sm"><span class="text-navy-400">Cliente</span><span class="text-white font-medium">Clínica Bascur</span></div>
                      <div class="fp-row flex justify-between text-sm"><span class="text-navy-400">Técnico</span><span class="text-white font-medium">Samuel A.</span></div>
                      <div class="fp-row flex justify-between text-sm"><span class="text-navy-400">Equipos</span><span class="text-cyan-400 font-mono">8 unidades</span></div>
                    </div>
                    <div class="fp-confirm mt-4 py-2.5 bg-gradient-to-r from-cyan-500 to-cyan-400 rounded-xl text-center text-xs font-bold text-navy-950 shadow-lg shadow-cyan-500/30">Orden asignada ✓</div>
                  </div>
                </div>

                <!-- PANEL 2 -->
                <div class="flujo-panel absolute inset-0 p-8 flex items-center justify-center opacity-0" data-panel="2">
                  <div class="relative w-48 rounded-[2rem] bg-navy-900 border-[5px] border-navy-700 shadow-2xl overflow-hidden">
                    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-14 h-4 bg-navy-700 rounded-b-2xl z-20"></div>
                    <div class="fp-scan absolute inset-x-0 h-0.5 bg-cyan-400 shadow-[0_0_12px_rgba(0,188,212,0.9)] z-10"></div>
                    <div class="px-4 pt-7 pb-4">
                      <p class="font-mono text-[8px] text-navy-500 mb-1">OT-2026-014</p>
                      <p class="text-xs text-white font-semibold mb-3">Visita técnica</p>
                      <div class="w-full py-2.5 bg-gradient-to-r from-cyan-500 to-cyan-400 rounded-xl flex items-center justify-center gap-1.5 mb-3 shadow-lg shadow-cyan-500/30">
                        <svg class="w-3.5 h-3.5 text-navy-950" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2M6 16H4m9-9v3m0 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/></svg>
                        <span class="text-[11px] font-semibold text-navy-950">Escaneando…</span>
                      </div>
                      <div class="bg-navy-950/60 rounded-lg p-2.5 border border-navy-800">
                        <span class="text-[8px] font-mono text-cyan-400 bg-cyan-500/10 px-1.5 py-0.5 rounded">SIN SEÑAL · OK</span>
                        <div class="h-1.5 w-3/4 bg-navy-700 rounded mt-2 mb-1.5"></div>
                        <div class="h-1.5 w-1/2 bg-navy-800 rounded"></div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- PANEL 3 -->
                <div class="flujo-panel absolute inset-0 p-8 flex flex-col justify-center opacity-0" data-panel="3">
                  <div class="rounded-2xl bg-navy-950/80 border border-navy-700/60 p-5 shadow-xl">
                    <div class="flex items-center gap-2 mb-4 pb-3 border-b border-navy-800">
                      <div class="w-8 h-8 rounded-lg bg-cyan-500/15 flex items-center justify-center">
                        <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.6a1 1 0 01.7.3l5.4 5.4a1 1 0 01.3.7V19a2 2 0 01-2 2z"/></svg>
                      </div>
                      <span class="text-sm font-semibold text-white">Informe de servicio</span>
                    </div>
                    <div class="space-y-2.5">
                      <div class="fp-check flex justify-between text-xs"><span class="text-navy-300">Parámetros técnicos</span><span class="text-cyan-400 font-mono">✓</span></div>
                      <div class="fp-check flex justify-between text-xs"><span class="text-navy-300">Checklist HVAC-R</span><span class="text-cyan-400 font-mono">✓</span></div>
                      <div class="fp-check flex justify-between text-xs"><span class="text-navy-300">Fotos y firma</span><span class="text-cyan-400 font-mono">✓</span></div>
                    </div>
                    <div class="fp-confirm mt-4 py-2.5 bg-white rounded-xl text-center text-xs font-bold text-navy-950">PDF generado</div>
                  </div>
                </div>

                <!-- PANEL 4 -->
                <div class="flujo-panel absolute inset-0 p-8 flex flex-col justify-center opacity-0" data-panel="4">
                  <div class="rounded-2xl bg-navy-950/80 border border-navy-700/60 p-5 shadow-xl">
                    <div class="flex justify-between items-center border-b border-navy-800 pb-3 mb-4">
                      <span class="font-mono text-xs text-cyan-400">CHILLER-04-A</span>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-cyan-500/15 text-cyan-300 text-[10px] font-semibold"><span class="w-1.5 h-1.5 rounded-full bg-cyan-400"></span>Actualizado</span>
                    </div>
                    <div class="relative pl-5 space-y-3">
                      <div class="absolute left-[5px] top-1 bottom-1 w-px bg-gradient-to-b from-cyan-400/60 to-navy-800"></div>
                      <div class="fp-hist relative"><span class="absolute -left-[18px] top-1 w-2.5 h-2.5 rounded-full bg-cyan-400 ring-4 ring-cyan-400/15"></span><div class="flex justify-between"><span class="text-xs text-white">Mantención preventiva</span><span class="font-mono text-[10px] text-cyan-400">HOY</span></div></div>
                      <div class="fp-hist relative"><span class="absolute -left-[18px] top-1 w-2.5 h-2.5 rounded-full bg-navy-600 ring-4 ring-navy-800"></span><div class="flex justify-between"><span class="text-xs text-navy-300">Cambio de filtro</span><span class="font-mono text-[10px] text-navy-500">28 NOV</span></div></div>
                      <div class="fp-hist relative"><span class="absolute -left-[18px] top-1 w-2.5 h-2.5 rounded-full bg-navy-600 ring-4 ring-navy-800"></span><div class="flex justify-between"><span class="text-xs text-navy-300">Carga R-410A</span><span class="font-mono text-[10px] text-navy-500">03 OCT</span></div></div>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- MÓVIL -->
    <div class="lg:hidden pb-20 space-y-4">
      {pasos.map((p) => (
        <div data-reveal class="rounded-2xl bg-navy-900/60 border border-navy-700/60 p-6">
          <div class="flex items-center gap-3 mb-2">
            <span class="font-mono text-xs text-cyan-400">{p.n}</span>
            <h3 class="font-display text-xl font-bold text-white">{p.t}</h3>
          </div>
          <p class="text-navy-300 leading-relaxed text-sm">{p.d}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .flujo-panel { transition: opacity .55s cubic-bezier(0.16,1,0.3,1), transform .55s cubic-bezier(0.16,1,0.3,1); transform: translateY(14px); pointer-events: none; }
  .flujo-panel.active { transform: translateY(0); }

  .fp-ping::after { content:''; position:absolute; inset:0; border-radius:9999px; background:rgba(0,188,212,.6); animation: fp-ping 1.6s ease-out infinite; }
  @keyframes fp-ping { 0%{transform:scale(1);opacity:.7;} 100%{transform:scale(2.4);opacity:0;} }

  .flujo-panel.active .fp-item { animation: fp-rise .5s ease both; }
  .flujo-panel.active .fp-item:nth-child(2) { animation-delay: .12s; }
  .flujo-panel.active .fp-row { animation: fp-rise .45s ease both; }
  .flujo-panel.active .fp-row:nth-child(1){animation-delay:.05s;}
  .flujo-panel.active .fp-row:nth-child(2){animation-delay:.13s;}
  .flujo-panel.active .fp-row:nth-child(3){animation-delay:.21s;}
  .flujo-panel.active .fp-row:nth-child(4){animation-delay:.29s;}
  .flujo-panel.active .fp-confirm { animation: fp-pop .5s cubic-bezier(0.34,1.56,0.64,1) .42s both; }
  .flujo-panel.active .fp-check { animation: fp-rise .4s ease both; }
  .flujo-panel.active .fp-check:nth-child(1){animation-delay:.1s;}
  .flujo-panel.active .fp-check:nth-child(2){animation-delay:.22s;}
  .flujo-panel.active .fp-check:nth-child(3){animation-delay:.34s;}
  .flujo-panel.active .fp-hist { animation: fp-rise .45s ease both; }
  .flujo-panel.active .fp-hist:nth-child(2){animation-delay:.1s;}
  .flujo-panel.active .fp-hist:nth-child(3){animation-delay:.2s;}
  .flujo-panel.active .fp-hist:nth-child(4){animation-delay:.3s;}

  @keyframes fp-rise { from{opacity:0;transform:translateY(10px);} to{opacity:1;transform:translateY(0);} }
  @keyframes fp-pop { from{opacity:0;transform:scale(.92);} to{opacity:1;transform:scale(1);} }

  .flujo-panel.active .fp-scan { animation: fp-scan 2.2s ease-in-out infinite; }
  @keyframes fp-scan { 0%{top:18%;opacity:0;} 20%{opacity:1;} 80%{opacity:1;} 100%{top:82%;opacity:0;} }

  @media (prefers-reduced-motion: reduce) {
    .flujo-panel, .fp-item, .fp-row, .fp-confirm, .fp-check, .fp-hist, .fp-ping::after, .fp-scan { animation: none !important; transition: opacity .2s !important; transform: none !important; }
  }
</style>

<script>
  function initFlujo() {
    const wrap = document.getElementById('flujo-wrap');
    if (!wrap || wrap.dataset.init) return;
    wrap.dataset.init = '1';

    const steps = Array.from(wrap.querySelectorAll('.flujo-step'));
    const panels = Array.from(wrap.querySelectorAll('.flujo-panel'));
    const dots = Array.from(wrap.querySelectorAll('.flujo-dot'));
    const progress = document.getElementById('flujo-progress');
    const bignum = document.getElementById('flujo-bignum');
    const label = document.getElementById('flujo-step-label');
    const aura = document.getElementById('flujo-aura');
    let current = -1;
    const total = steps.length;

    function setActive(idx) {
      if (idx === current) return;
      current = idx;
      steps.forEach((s, i) => {
        const on = i === idx;
        s.querySelector('.flujo-bar').style.height = on ? '60%' : '0';
        const num = s.querySelector('.flujo-num');
        const title = s.querySelector('.flujo-title');
        const desc = s.querySelector('.flujo-desc');
        num.classList.toggle('text-cyan-400', on);
        num.classList.toggle('text-navy-600', !on);
        title.classList.toggle('text-white', on);
        title.classList.toggle('text-navy-600', !on);
        title.style.transform = on ? 'translateX(4px)' : 'translateX(0)';
        desc.style.maxHeight = on ? '100px' : '0';
        desc.style.opacity = on ? '1' : '0';
        desc.classList.toggle('text-navy-300', on);
      });
      panels.forEach((p, i) => {
        const on = i === idx;
        p.style.opacity = on ? '1' : '0';
        p.classList.toggle('active', on);
      });
      dots.forEach((d, i) => {
        d.classList.toggle('bg-cyan-400', i === idx);
        d.classList.toggle('w-4', i === idx);
        d.classList.toggle('bg-navy-700', i !== idx);
      });
      if (progress) progress.style.width = ((idx + 1) / total * 100) + '%';
      if (bignum) bignum.textContent = String(idx + 1).padStart(2, '0');
      if (label) label.textContent = `PASO ${String(idx + 1).padStart(2,'0')} / 0${total}`;
      if (aura) aura.style.background = `rgba(0,188,212,${0.08 + idx * 0.02})`;
    }

    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) setActive(parseInt(entry.target.dataset.step, 10));
      });
    }, { rootMargin: '-45% 0px -45% 0px', threshold: 0 });

    steps.forEach((s) => io.observe(s));
    setActive(0);
  }
  initFlujo();
  document.addEventListener('astro:page-load', initFlujo);
</script>