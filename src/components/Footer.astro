---
// src/components/Footer.astro
const year = new Date().getFullYear();
const LOGIN_URL = "https://app.lissi.app/login";
---
<footer class="bg-[#0A0F1C] pt-20 pb-8 border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">

      <div class="col-span-1 md:col-span-1">
        <img src="/logo_lissi.png" alt="Lissi" class="h-8 w-auto mb-6 brightness-0 invert opacity-80" />
        <p class="text-slate-500 text-xs leading-relaxed max-w-xs font-light">
          La plataforma que ordena la operación de las empresas HVAC-R. Hecho en Chile.
        </p>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-6 tracking-wide">Plataforma</h4>
        <ul class="space-y-4 text-sm text-slate-400 font-light">
          <li><a href="/#soluciones" class="hover:text-cyan-400 transition-colors">Funcionalidades</a></li>
          <li><a href="/#testimonios" class="hover:text-cyan-400 transition-colors">Clientes</a></li>
          <li><a href="/#precios" class="hover:text-cyan-400 transition-colors">Precios</a></li>
        </ul>
      </div>

      <div>
        <a href="/recursos" class="text-white font-semibold mb-6 tracking-wide block hover:text-cyan-400 transition-colors">Recursos</a>
        <ul class="space-y-4 text-sm text-slate-400 font-light">
          <li><a href="/recursos/decodificador" class="hover:text-cyan-400 transition-colors">Códigos de error</a></li>
          <li><a href="/recursos/pautas" class="hover:text-cyan-400 transition-colors">Pautas de mantención</a></li>
          <li><a href="/recursos" class="hover:text-cyan-400 transition-colors">Ver todos los recursos</a></li>
          <li><a href={LOGIN_URL} class="hover:text-white transition-colors font-medium text-cyan-400 pt-2 block">Iniciar sesión →</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-6 tracking-wide">Hablemos</h4>
        <ul class="space-y-4 text-sm text-slate-400 font-light">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-slate-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <a href="mailto:samuel@lissi.cl" class="hover:text-white transition-colors">samuel@lissi.cl</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-slate-600 mt-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            <a href="https://wa.me/56963192849" target="_blank" class="hover:text-white transition-colors">WhatsApp soporte</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-600 text-xs font-light">© {year} Lissi SpA. Todos los derechos reservados.</p>

      <div class="flex flex-wrap justify-center items-center gap-x-5 gap-y-2 text-xs">
        <a href="/terminos" class="text-slate-500 hover:text-cyan-400 transition-colors font-light">Términos y Condiciones</a>
        <a href="/privacidad" class="text-slate-500 hover:text-cyan-400 transition-colors font-light">Política de Privacidad</a>
        <a href="/cookies" class="text-slate-500 hover:text-cyan-400 transition-colors font-light">Cookies</a>
      </div>

      <div class="flex gap-2 items-center text-slate-600 text-xs font-medium">
        <span>Santiago, Chile</span>
        <img src="https://flagcdn.com/20x15/cl.png" width="20" height="15" alt="Chile" class="opacity-30" />
      </div>
    </div>
  </div>
</footer>