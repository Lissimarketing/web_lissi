---
// src/components/Navbar.astro
---
<nav class="fixed top-0 left-0 right-0 z-[100] bg-white/80 backdrop-blur-xl border-b border-slate-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="group">
          <img 
            src="/logo_lissi.png" 
            alt="Lissi Logo" 
            class="h-10 md:h-12 w-auto transition-transform duration-300 group-hover:scale-105"
          />
        </a>
      </div>

      <div class="hidden md:flex items-center gap-10">
        <div class="flex gap-8 text-sm font-bold text-slate-500">
          <a href="#soluciones" class="hover:text-blue-600 transition-colors">Plataforma</a>
          <a href="#testimonios" class="hover:text-blue-600 transition-colors">Clientes</a>
          <a href="#precios" class="hover:text-blue-600 transition-colors">Precios</a>
        </div>

        <div class="h-6 w-px bg-slate-200"></div>

        <div class="flex items-center gap-6">
          <button 
            onclick="window.openCalendly()"
            class="text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors cursor-pointer"
          >
            Agendar Reunión
          </button>
          
          <a 
            href="https://wa.me/56963192849?text=Hola,%20vi%20la%20web%20y%20quiero%20hablar%20con%20un%20ingeniero." 
            target="_blank"
            class="px-6 py-3 bg-blue-600 text-white text-sm font-bold rounded-xl hover:bg-blue-700 shadow-lg shadow-blue-500/20 transition-all active:scale-95 flex items-center gap-2"
          >
            Hablemos por WhatsApp
          </a>
        </div>
      </div>

      <div class="md:hidden">
        <button class="text-slate-600 p-2">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/></svg>
        </button>
      </div>
    </div>
  </div>
</nav>