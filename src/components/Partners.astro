---
// src/components/Partners.astro
const brands = ["DAIKIN", "CARRIER", "SAMSUNG", "LG", "ANWO", "TRANE", "YORK", "LENNOX", "MITSUBISHI"];
const fila = [...brands, ...brands, ...brands]; // Triplicado para asegurar un loop fluido en pantallas ultra anchas
---
<section class="bg-[#0A0F1C] py-10 md:py-12 border-y border-white/5 overflow-hidden flex flex-col md:flex-row items-center relative">

  <div class="absolute inset-y-0 left-0 w-24 md:w-40 bg-gradient-to-r from-[#0A0F1C] to-transparent z-10 pointer-events-none"></div>
  <div class="absolute inset-y-0 right-0 w-24 md:w-40 bg-gradient-to-l from-[#0A0F1C] to-transparent z-10 pointer-events-none"></div>

  <div class="relative z-20 px-4 md:px-8 mb-6 md:mb-0 md:border-r border-slate-800 flex-shrink-0 flex items-center justify-center">
    <p class="font-mono text-[10px] uppercase tracking-widest text-slate-500 whitespace-nowrap">
      Compatibilidad<br/><span class="text-cyan-500 font-bold">Universal</span>
    </p>
  </div>

  <div class="relative flex overflow-hidden w-full" style="-webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);">
    <div class="flex items-center gap-12 md:gap-20 animate-marquee whitespace-nowrap pl-12 md:pl-20">
      {fila.map((brand) => (
        <span class="font-display text-2xl md:text-3xl font-black text-slate-800 hover:text-slate-600 transition-colors duration-500 select-none tracking-tight">
          {brand}
        </span>
      ))}
    </div>
  </div>

</section>

<style>
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.33%); /* Al estar triplicado, movemos un tercio */ }
  }
  .animate-marquee:hover {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-marquee { animation: none; }
  }
</style>