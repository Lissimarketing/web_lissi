---
// src/components/PricingUSD.astro (Versión Internacional)
---
<section id="precios" class="py-24 bg-white relative overflow-hidden">
  
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[500px] bg-blue-500/5 rounded-full blur-[120px] -z-10"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 tracking-tight">
        Planes que <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-700 via-blue-600 to-cyan-500">escalan contigo.</span>
      </h2>
      <p class="text-lg text-slate-500 font-medium">
        Precios en Dólares (USD). Elige la potencia que tu operación necesita.
      </p>
    </div>

    <div class="flex justify-center items-center gap-4 mb-16">
      <span class="text-sm font-bold text-slate-900 transition-colors" id="label-monthly">Mensual</span>
      
      <button id="billing-toggle" class="relative w-14 h-8 rounded-full bg-slate-200 transition-colors focus:outline-none ring-offset-2 focus:ring-2 ring-blue-500" aria-pressed="false">
        <span id="toggle-circle" class="absolute top-1 left-1 w-6 h-6 rounded-full bg-white shadow-sm transition-transform duration-300 ease-spring"></span>
      </button>

      <span class="text-sm font-medium text-slate-500 transition-colors flex items-center gap-2" id="label-annual">
        Anual
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-cyan-100 text-cyan-700 uppercase tracking-wide">
          Ahorra 25%
        </span>
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 max-w-full mx-auto items-stretch mb-16">
      
      <div class="flex flex-col h-full bg-white border border-slate-200 rounded-[2rem] p-6 hover:shadow-xl hover:shadow-blue-500/5 hover:-translate-y-2 transition-all duration-300 group">
        <div class="mb-4">
            <span class="inline-block px-3 py-1 bg-slate-100 text-slate-500 text-[10px] font-bold tracking-wider rounded-full uppercase">
                Para Independientes
            </span>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-2">Freelance</h3>
        <p class="text-slate-500 text-sm mb-6">Gestiona tus propios servicios.</p>
        
        <div class="mb-6 h-[80px]">
           <div class="flex items-baseline gap-1">
             <span class="text-4xl font-black text-slate-900 transition-all duration-500 price-value" data-monthly="27" data-annual="21">$27 USD</span>
           </div>
           <span class="text-slate-400 text-xs block mt-1 billing-period">+ IVA / mes</span>
        </div>

        <div class="mt-auto">
            <button onclick="openModal()" class="w-full py-3 px-4 bg-slate-50 text-slate-600 font-bold rounded-xl hover:bg-slate-100 border border-slate-200 transition-all text-sm group-hover:border-blue-200 group-hover:text-blue-600">
                Unirse a Lista de Espera
            </button>
        </div>
      </div>

      <div class="flex flex-col h-full bg-white rounded-[2rem] p-8 border border-slate-200 shadow-lg shadow-slate-200/50 hover:shadow-2xl hover:shadow-blue-500/20 hover:border-blue-300 hover:-translate-y-2 transition-all duration-300 relative overflow-hidden group">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-400 to-cyan-400"></div>

        <h3 class="text-xl font-bold text-slate-900 mb-2">Pequeña Empresa</h3>
        <p class="text-slate-500 text-sm mb-6">Digitaliza tu operación base.</p>
        
        <div class="mb-6 h-[80px]">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-black text-slate-900 transition-all duration-500 price-value" data-monthly="97" data-annual="76">$97 USD</span>
          </div>
          <span class="text-slate-400 text-xs block mt-1 billing-period">/ mes</span>
        </div>
        
        <div class="text-sm font-bold text-blue-700 bg-blue-50 border border-blue-100 px-3 py-1.5 rounded-lg inline-block mb-6 text-center w-full">
            Hasta 5 Usuarios
        </div>
        
        <ul class="space-y-4 text-sm text-slate-600 mb-8 flex-1">
          <li class="flex items-start"><span class="mr-2 text-cyan-500 font-bold">✓</span> <span>Base de Datos: <b>1.000 Equipos</b></span></li>
          <li class="flex items-start"><span class="mr-2 text-cyan-500 font-bold">✓</span> <span>Cartera: <b>100 Clientes</b></span></li>
          <li class="flex items-start"><span class="mr-2 text-cyan-500 font-bold">✓</span> <span>Soporte: <b>48 Horas</b></span></li>
          <li class="flex items-start"><span class="mr-2 text-cyan-500 font-bold">✓</span> <span>Incluye Capacitación</span></li>
        </ul>

        <a href="https://wa.me/56963192849?text=Hola%20Samuel,%20vi%20la%20demo%20y%20quiero%20saber%20si%20Lissi%20sirve%20para%20mi%20empresa%20(Plan%20Pyme%20USD)." target="_blank" class="block w-full py-3 px-4 bg-white border-2 border-slate-900 text-slate-900 font-bold text-center rounded-xl hover:bg-slate-50 transition-colors">
          Solicitar Plan
        </a>
      </div>

      <div class="flex flex-col h-full bg-slate-900 rounded-[2rem] p-8 border border-slate-800 shadow-2xl relative overflow-hidden transform hover:-translate-y-2 transition-all duration-300">
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 bg-blue-600 blur-[80px] opacity-40 pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-64 h-64 bg-cyan-500 blur-[80px] opacity-20 pointer-events-none"></div>
        
        <div class="flex justify-between items-start mb-2 relative z-10">
            <h3 class="text-xl font-bold text-white">Crecimiento</h3>
            <span class="bg-gradient-to-r from-blue-600 to-cyan-500 text-white text-[10px] font-bold px-2 py-1 rounded-md uppercase tracking-wider shadow-lg shadow-blue-500/40">
                Popular
            </span>
        </div>
        <p class="text-slate-400 text-sm mb-6 relative z-10">Para equipos en expansión.</p>
        
        <div class="mb-6 h-[80px] relative z-10">
          <div class="flex items-baseline gap-1">
             <span class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white to-blue-200 transition-all duration-500 price-value" data-monthly="197" data-annual="153">$197 USD</span>
          </div>
          <span class="text-slate-400 text-xs block mt-1 billing-period">/ mes</span>
        </div>

        <div class="text-sm font-bold text-cyan-300 bg-cyan-950/40 border border-cyan-900/50 px-3 py-1.5 rounded-lg inline-block mb-6 text-center w-full relative z-10">
            Hasta 12 Usuarios
        </div>

        <ul class="space-y-4 text-sm text-slate-300 mb-8 flex-1 relative z-10">
          <li class="flex items-start"><span class="mr-2 text-blue-400 font-bold">✓</span> <span>Base de Datos: <b>5.000 Equipos</b></span></li>
          <li class="flex items-start"><span class="mr-2 text-blue-400 font-bold">✓</span> <span>Cartera: <b>500 Clientes</b></span></li>
          <li class="flex items-start"><span class="mr-2 text-blue-400 font-bold">✓</span> <span>Soporte Prioritario <b>24 Horas</b></span></li>
          <li class="flex items-start"><span class="mr-2 text-blue-400 font-bold">✓</span> <span>Portal Cliente: <b>3 Accesos</b></span></li>
        </ul>

        <a href="https://wa.me/56963192849?text=Hola%20Samuel,%20vi%20la%20demo%20y%20quiero%20saber%20si%20Lissi%20sirve%20para%20mi%20empresa%20(Plan%20Crecimiento%20USD)." target="_blank" class="block w-full py-4 px-6 bg-gradient-to-r from-blue-600 to-cyan-500 text-white font-bold text-center rounded-xl hover:shadow-lg hover:shadow-blue-500/40 transition-all relative z-10">
          Empezar Ahora
        </a>
      </div>

      <div class="flex flex-col h-full bg-white rounded-[2rem] p-8 border border-slate-200 shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 group">
        <h3 class="text-xl font-bold text-slate-900 mb-2">Corporativo</h3>
        <p class="text-slate-500 text-sm mb-6">Operaciones a gran escala.</p>
        
        <div class="mb-6 flex items-center h-[80px]">
          <span class="text-3xl font-black text-slate-900">A medida</span>
        </div>

        <div class="text-sm font-bold text-slate-600 bg-slate-100 border border-slate-200 px-3 py-1.5 rounded-lg inline-block mb-6 text-center w-full">
            +12 Usuarios
        </div>

        <ul class="space-y-4 text-sm text-slate-600 mb-8 flex-1">
          <li class="flex items-start"><span class="mr-2 text-green-500 font-bold">✓</span> <span>Usuarios Ilimitados</span></li>
          <li class="flex items-start"><span class="mr-2 text-green-500 font-bold">✓</span> <span>Base de Datos <b>Ilimitada</b></span></li>
          <li class="flex items-start"><span class="mr-2 text-green-500 font-bold">✓</span> <span>Onboarding VIP</span></li>
          <li class="flex items-start"><span class="mr-2 text-green-500 font-bold">✓</span> <span>Capacitación Presencial/Remota</span></li>
        </ul>
        
        <a href="mailto:ventas@lissi.app" class="block w-full py-3 px-4 bg-white border border-slate-200 text-slate-600 font-bold text-center rounded-xl hover:bg-slate-50 transition-colors">
          Contactar Ventas
        </a>
      </div>
    </div>

    <div class="text-center border-t border-slate-200 pt-10 max-w-4xl mx-auto">
      <p class="text-slate-500 text-sm mb-4 font-bold uppercase tracking-widest">Tu inversión está protegida</p>
      <div class="flex flex-col md:flex-row justify-center gap-8 text-slate-600 text-sm">
        <div class="flex items-center justify-center gap-2">
          <span class="text-2xl">🔒</span>
          <span><b>Sin contratos forzosos.</b> Cancela cuando quieras.</span>
        </div>
        <div class="flex items-center justify-center gap-2">
          <span class="text-2xl">🛡️</span>
          <span><b>Garantía de 30 días.</b> Si no te sirve, te devolvemos el dinero.</span>
        </div>
      </div>
    </div>

  </div>

  <div id="waitlist-modal" class="fixed inset-0 z-[200] hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity" onclick="closeModal()"></div>
    
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-8 transform transition-all scale-100">
        <button onclick="closeModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        
        <div class="text-center mb-6">
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl">🚀</span>
            </div>
            <h3 class="text-2xl font-bold text-slate-900">Únete al Plan Freelance</h3>
            <p class="text-slate-500 mt-2 text-sm">Estamos liberando cupos gradualmente. Déjanos tus datos y te avisaremos apenas puedas entrar.</p>
        </div>

        <form class="space-y-4" onsubmit="event.preventDefault(); alert('¡Gracias! Te avisaremos pronto.'); closeModal();">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Nombre</label>
                <input type="text" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="Tu nombre" required>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Correo Electrónico</label>
                <input type="email" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="hola@tuempresa.com" required>
            </div>
            <button type="submit" class="w-full py-3 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-colors shadow-lg shadow-blue-500/30">
                Avísenme cuando esté listo
            </button>
        </form>
    </div>
  </div>

</section>

<script>
  // Lógica del Toggle
  const toggleBtn = document.getElementById('billing-toggle');
  const toggleCircle = document.getElementById('toggle-circle');
  const prices = document.querySelectorAll('.price-value');
  const billingPeriods = document.querySelectorAll('.billing-period');
  const labelMonthly = document.getElementById('label-monthly');
  const labelAnnual = document.getElementById('label-annual');

  let isAnnual = false;

  if(toggleBtn) {
    toggleBtn.addEventListener('click', () => {
      isAnnual = !isAnnual;
      
      if(isAnnual) {
        toggleBtn.classList.replace('bg-slate-200', 'bg-blue-600');
        toggleCircle.style.transform = 'translateX(24px)';
        labelAnnual.classList.add('text-slate-900');
        labelAnnual.classList.remove('text-slate-500');
        labelMonthly.classList.remove('text-slate-900');
        labelMonthly.classList.add('text-slate-400');
      } else {
        toggleBtn.classList.replace('bg-blue-600', 'bg-slate-200');
        toggleCircle.style.transform = 'translateX(0)';
        labelMonthly.classList.add('text-slate-900');
        labelMonthly.classList.remove('text-slate-400');
        labelAnnual.classList.remove('text-slate-900');
        labelAnnual.classList.add('text-slate-500');
      }

      prices.forEach(price => {
        price.style.opacity = '0';
        setTimeout(() => {
          if(isAnnual) {
            price.innerText = '$' + price.dataset.annual + ' USD';
          } else {
            price.innerText = '$' + price.dataset.monthly + ' USD';
          }
          price.style.opacity = '1';
        }, 200);
      });

      billingPeriods.forEach(period => {
         if(isAnnual) {
             period.innerHTML = '/ mes <br><span class="text-green-500 font-bold">facturado anualmente</span>';
         } else {
             period.innerHTML = '/ mes';
         }
      });
    });
  }

  // Lógica del Modal
  window.openModal = function() {
    const modal = document.getElementById('waitlist-modal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  window.closeModal = function() {
    const modal = document.getElementById('waitlist-modal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }
</script>

<style>
    .ease-spring {
        transition-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
    }
</style>