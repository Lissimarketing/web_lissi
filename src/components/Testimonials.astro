---
// src/components/Testimonios.astro
const testimonios = [
  {
    id: 1,
    name: "Javier Morales",
    role: "Director de Operaciones",
    company: "Climatización Sur",
    content: "Lissi nos ahorró semanas de desorden administrativo. La trazabilidad offline de los equipos en terreno es impecable, y los reportes PDF automáticos nos han ayudado a cerrar más contratos.",
    rating: 5,
    avatar: "https://randomuser.me/api/portraits/men/32.jpg",
  },
  {
    id: 2,
    name: "Carolina Rojas",
    role: "Gerente General",
    company: "HVAC Corp Chile",
    content: "He usado muchos ERPs y plataformas, pero esta destaca por su arquitectura limpia y enfoque en el negocio. La capacidad de generar presupuestos al instante en terreno no tiene precio.",
    rating: 5,
    avatar: "https://randomuser.me/api/portraits/women/44.jpg",
  },
  {
    id: 3,
    name: "Roberto Méndez",
    role: "Jefe Técnico",
    company: "FrioMax",
    content: "Pudimos estandarizar a nuestros 15 técnicos en tiempo récord gracias a las pautas generadas. El flujo de diagnóstico e historial funciona perfecto desde el primer día. Totalmente recomendado.",
    rating: 5,
    avatar: "https://randomuser.me/api/portraits/men/46.jpg",
  },
];

---
<section id="testimonios" class="py-24 md:py-32 overflow-hidden bg-[#0A0F1C] relative border-t border-slate-800/50">
  
  <div class="absolute top-1/2 left-0 -translate-y-1/2 w-[600px] h-[600px] bg-cyan-500/5 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-20 items-center">
      
      <div class="lg:col-span-5 flex flex-col justify-center">
        <div class="space-y-6">
          
          <div class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 shadow-[0_0_15px_rgba(0,229,255,0.1)]">
            <svg class="mr-2 h-4 w-4 text-cyan-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Validados por la industria
          </div>

          <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tight leading-[1.05]">
            Amado por la<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">comunidad técnica</span>
          </h2>

          <p class="max-w-[480px] text-slate-400 text-lg md:text-xl font-light leading-relaxed">
            No te quedes solo con nuestra palabra. Mira lo que gerentes y jefes de terreno dicen sobre Lissi tras digitalizar su operación.
          </p>

          <div class="flex items-center gap-3 pt-6" id="testimonial-controls">
            {testimonios.map((_, index) => (
              <button
                class="testimonial-dot h-2.5 rounded-full transition-all duration-500 ease-out focus:outline-none focus:ring-2 focus:ring-cyan-500/50"
                data-index={index}
                aria-label={`Ver testimonio ${index + 1}`}
              ></button>
            ))}
          </div>
        </div>
      </div>

      <div class="lg:col-span-7 relative w-full h-full min-h-[450px]">
        
        <div class="absolute -bottom-8 -left-8 h-32 w-32 rounded-[2rem] bg-cyan-500/5 border border-cyan-500/10 -z-10 hidden md:block"></div>
        <div class="absolute -top-8 -right-8 h-32 w-32 rounded-[2rem] bg-blue-500/5 border border-blue-500/10 -z-10 hidden md:block"></div>

        <div class="grid w-full h-full" style="grid-template-areas: 'stack';">
          
          {testimonios.map((testimonial, index) => (
            <div 
              class="testimonial-card flex flex-col justify-between"
              style="grid-area: stack;"
              data-index={index}
            >
              <div class="bg-slate-900/90 backdrop-blur-2xl border-t border-l border-slate-700/80 border-r border-b border-slate-800/80 shadow-[0_20px_50px_rgba(0,0,0,0.5)] rounded-[2rem] p-8 md:p-12 h-full flex flex-col relative overflow-hidden group">
                
                <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent opacity-0 group-[.is-active]:opacity-100 transition-opacity duration-1000"></div>

                <svg class="absolute -top-6 -right-4 h-48 w-48 text-slate-800/40 rotate-12 pointer-events-none" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>

                <div class="relative z-10 flex flex-col h-full justify-between">
                  <div>
                    <div class="mb-8 flex gap-1.5">
                      {Array(testimonial.rating).fill(0).map(() => (
                        <svg class="h-6 w-6 text-amber-400 drop-shadow-[0_0_10px_rgba(251,191,36,0.5)]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      ))}
                    </div>

                    <p class="text-xl md:text-[1.35rem] font-medium leading-[1.6] text-white tracking-wide">
                      "{testimonial.content}"
                    </p>
                  </div>

                  <div class="flex items-center gap-5 mt-10 pt-8 border-t border-slate-800/60">
                    <div class="relative h-16 w-16 rounded-full overflow-hidden border-2 border-slate-700 shrink-0 shadow-lg">
                      <img src={testimonial.avatar} alt={testimonial.name} class="h-full w-full object-cover" loading="lazy" />
                    </div>
                    <div class="flex flex-col">
                      <h3 class="font-bold text-white text-lg tracking-tight">{testimonial.name}</h3>
                      <p class="text-sm font-medium text-slate-400 mt-0.5">
                        {testimonial.role}, <span class="text-cyan-400">{testimonial.company}</span>
                      </p>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          ))}
          
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* Animación y Posicionamiento Fluido (Grid Stacking)
    Curva de bezier "Out Expo" para un deslizamiento premium
  */
  .testimonial-card {
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    transform: translateX(3rem) scale(0.95);
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.7s ease;
  }
  
  /* Tarjeta Activa (Entra por la derecha/centro) */
  .testimonial-card.is-active {
    opacity: 1;
    pointer-events: auto;
    z-index: 10;
    transform: translateX(0) scale(1);
  }

  /* Tarjeta Pasada (Se esconde hacia la izquierda) */
  .testimonial-card.is-prev {
    transform: translateX(-3rem) scale(0.95);
  }
  
  /* Controles (Dots) */
  .testimonial-dot { width: 12px; background-color: rgba(148, 163, 184, 0.2); }
  .testimonial-dot:hover { background-color: rgba(148, 163, 184, 0.5); }
  .testimonial-dot.is-active { width: 48px; background-color: #06b6d4; } /* Cyan 500 */
</style>

<script>
  function initTestimonials() {
    const cards = document.querySelectorAll('.testimonial-card');
    const dots = document.querySelectorAll('.testimonial-dot');
    if (cards.length === 0 || dots.length === 0) return;

    let activeIndex = 0;
    let interval: number;
    const rotateDelay = 7000; // 7 segundos para dar tiempo a leer

    function setActive(index: number) {
      activeIndex = index;
      
      // Actualizar lógica de tarjetas (Flujo Direccional)
      cards.forEach((card, i) => {
        card.classList.remove('is-active', 'is-prev');
        
        if (i === activeIndex) {
          card.classList.add('is-active');
        } else if (i < activeIndex) {
          card.classList.add('is-prev'); // Se va a la izquierda
        } 
        // Si i > activeIndex, se queda en el estado base (a la derecha) esperando entrar
      });

      // Actualizar dots
      dots.forEach((dot, i) => {
        if (i === activeIndex) dot.classList.add('is-active');
        else dot.classList.remove('is-active');
      });
    }

    function nextTestimonial() {
      setActive((activeIndex + 1) % cards.length);
    }

    function startAutoRotate() {
      stopAutoRotate();
      interval = window.setInterval(nextTestimonial, rotateDelay);
    }

    function stopAutoRotate() {
      if (interval) clearInterval(interval);
    }

    // Navegación Manual
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        setActive(index);
        startAutoRotate();
      });
    });

    // Pausar si el usuario está leyendo
    const container = document.querySelector('#testimonios');
    container?.addEventListener('mouseenter', stopAutoRotate);
    container?.addEventListener('mouseleave', startAutoRotate);

    // Boot inicial
    setActive(0);
    startAutoRotate();
  }

  initTestimonials();
  document.addEventListener('astro:page-load', initTestimonials);
</script>