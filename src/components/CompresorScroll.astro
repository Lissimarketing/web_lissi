---
// src/components/CompresorScroll.astro
---
<section id="compresor-scroll" class="relative bg-navy-950 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none opacity-[0.12]"
       style="background-image: linear-gradient(rgba(0,188,212,0.4) 1px, transparent 1px), linear-gradient(90deg, rgba(0,188,212,0.4) 1px, transparent 1px); background-size: 56px 56px; mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 30%, transparent 85%);"></div>

  <!-- El alto extra de esta sección genera el "scroll" que mueve la escena -->
  <div id="cs-track" class="relative h-[320vh]">
    <!-- Escena pegada -->
    <div class="sticky top-0 h-screen flex items-center justify-center overflow-hidden">

      <!-- glow central que late -->
      <div id="cs-glow" class="absolute w-[600px] h-[600px] rounded-full blur-[140px] pointer-events-none" style="background: rgba(0,188,212,0.12);"></div>

      <!-- Encabezado superior -->
      <div class="absolute top-[12%] left-1/2 -translate-x-1/2 text-center px-4 z-20 w-full max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-cyan-400 mb-3">// Monitoreo en vivo</p>
        <h2 class="font-display text-3xl md:text-5xl font-extrabold text-white tracking-[-0.02em] text-balance">
          El corazón de cada equipo, bajo control.
        </h2>
      </div>

      <!-- COMPRESOR central -->
      <div class="relative" style="perspective: 1200px;">
        <div id="cs-compressor" class="relative w-64 h-64 md:w-80 md:h-80" style="transform-style: preserve-3d;">
          <svg viewBox="0 0 320 320" class="w-full h-full drop-shadow-[0_20px_60px_rgba(0,0,0,0.6)]">
            <defs>
              <linearGradient id="csBody" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#1a3a52"/>
                <stop offset="45%" stop-color="#102a3f"/>
                <stop offset="100%" stop-color="#0a1f30"/>
              </linearGradient>
              <linearGradient id="csTop" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#2a5f7a"/>
                <stop offset="100%" stop-color="#14405c"/>
              </linearGradient>
              <linearGradient id="csShine" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="rgba(255,255,255,0)"/>
                <stop offset="45%" stop-color="rgba(125,240,255,0.25)"/>
                <stop offset="55%" stop-color="rgba(125,240,255,0.25)"/>
                <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
              </linearGradient>
              <radialGradient id="csCap" cx="50%" cy="35%" r="70%">
                <stop offset="0%" stop-color="#3d7a99"/>
                <stop offset="100%" stop-color="#0f2d44"/>
              </radialGradient>
            </defs>

            <!-- sombra base -->
            <ellipse cx="160" cy="300" rx="95" ry="14" fill="rgba(0,0,0,0.5)"/>

            <!-- cuerpo cilíndrico del compresor -->
            <path d="M70 120 Q70 100 160 100 Q250 100 250 120 L250 250 Q250 275 160 275 Q70 275 70 250 Z" fill="url(#csBody)" stroke="#1e4863" stroke-width="2"/>

            <!-- anillos del cuerpo -->
            <ellipse cx="160" cy="155" rx="90" ry="20" fill="none" stroke="rgba(0,188,212,0.15)" stroke-width="2"/>
            <ellipse cx="160" cy="200" rx="90" ry="20" fill="none" stroke="rgba(0,188,212,0.12)" stroke-width="2"/>
            <ellipse cx="160" cy="245" rx="90" ry="20" fill="none" stroke="rgba(0,188,212,0.1)" stroke-width="2"/>

            <!-- reflejo vertical (da volumen) -->
            <path d="M70 120 Q70 100 160 100 Q250 100 250 120 L250 250 Q250 275 160 275 Q70 275 70 250 Z" fill="url(#csShine)" opacity="0.5"/>

            <!-- tapa superior -->
            <ellipse cx="160" cy="100" rx="90" ry="24" fill="url(#csTop)" stroke="#2a5f7a" stroke-width="2"/>
            <ellipse cx="160" cy="96" rx="58" ry="15" fill="url(#csCap)" stroke="#3d7a99" stroke-width="1.5"/>
            <ellipse cx="160" cy="93" rx="30" ry="8" fill="#0a1f30" stroke="#1e4863" stroke-width="1.5"/>

            <!-- terminal eléctrico -->
            <circle cx="118" cy="92" r="7" fill="#0a1f30" stroke="#3d7a99" stroke-width="1.5"/>
            <circle cx="118" cy="92" r="2.5" fill="#00bcd4"/>

            <!-- puerto de succión/descarga (tubos laterales) -->
            <rect x="244" y="140" width="34" height="14" rx="7" fill="#14405c" stroke="#2a5f7a" stroke-width="1.5"/>
            <rect x="42" y="175" width="34" height="14" rx="7" fill="#14405c" stroke="#2a5f7a" stroke-width="1.5"/>

            <!-- etiqueta -->
            <rect x="120" y="200" width="80" height="36" rx="5" fill="rgba(0,0,0,0.3)" stroke="rgba(0,188,212,0.3)" stroke-width="1"/>
            <text x="160" y="215" text-anchor="middle" fill="#5dcaa5" font-family="monospace" font-size="9">SCROLL · R410A</text>
            <text x="160" y="228" text-anchor="middle" fill="#7df0ff" font-family="monospace" font-size="11" font-weight="bold">COMP-01</text>
          </svg>

          <!-- anillo orbital que rodea el compresor -->
          <div id="cs-orbit-ring" class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="w-[420px] h-[420px] md:w-[480px] md:h-[480px] rounded-full border border-cyan-500/20" style="border-style: dashed;"></div>
          </div>
        </div>
      </div>

      <!-- HUDs orbitando (aparecen por turnos) -->
      <!-- HUD 1: Presión + amperaje -->
      <div class="cs-hud absolute z-30" data-hud="0" style="top: 28%; left: 12%;">
        <div class="rounded-2xl bg-navy-900/90 backdrop-blur-xl border border-cyan-500/30 shadow-2xl shadow-cyan-500/10 p-4 w-52">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></span>
            <span class="font-mono text-[10px] uppercase tracking-wider text-cyan-400">Telemetría</span>
          </div>
          <div class="grid grid-cols-2 gap-2.5">
            <div class="rounded-lg bg-navy-950/60 border border-navy-800 p-2.5">
              <p class="text-[8px] uppercase tracking-wider text-navy-400 mb-0.5">Presión alta</p>
              <p class="font-display text-lg font-bold text-white"><span class="cs-count" data-to="365">0</span> <span class="text-[10px] text-navy-500">psi</span></p>
            </div>
            <div class="rounded-lg bg-navy-950/60 border border-navy-800 p-2.5">
              <p class="text-[8px] uppercase tracking-wider text-navy-400 mb-0.5">Amperaje</p>
              <p class="font-display text-lg font-bold text-cyan-400"><span class="cs-count" data-to="14" data-dec="1">0</span> <span class="text-[10px] text-navy-500">A</span></p>
            </div>
          </div>
        </div>
      </div>

      <!-- HUD 2: Alerta roja -->
      <div class="cs-hud absolute z-30" data-hud="1" style="top: 30%; right: 10%;">
        <div class="rounded-2xl bg-red-950/40 backdrop-blur-xl border border-red-500/40 shadow-2xl shadow-red-500/10 p-4 w-56">
          <div class="flex items-start gap-3">
            <div class="relative w-9 h-9 rounded-xl bg-red-500/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M12 3l9 16H3l9-16z"/></svg>
              <span class="cs-alarm absolute inset-0 rounded-xl border-2 border-red-400"></span>
            </div>
            <div>
              <p class="text-sm font-semibold text-white mb-0.5">Temperatura alta</p>
              <p class="text-[11px] text-red-300/80 leading-snug">Descarga sobre 80°C. Revisar carga.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- HUD 3: Checklist -->
      <div class="cs-hud absolute z-30" data-hud="2" style="bottom: 22%; left: 14%;">
        <div class="rounded-2xl bg-navy-900/90 backdrop-blur-xl border border-cyan-500/30 shadow-2xl shadow-cyan-500/10 p-4 w-56">
          <div class="flex items-center gap-2 mb-3">
            <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            <span class="font-mono text-[10px] uppercase tracking-wider text-cyan-400">Checklist preventivo</span>
          </div>
          <div class="space-y-2">
            <div class="cs-task flex items-center gap-2.5 text-[11px] text-navy-300"><span class="cs-box w-4 h-4 rounded border border-navy-600 flex items-center justify-center flex-shrink-0"></span> Presiones de trabajo</div>
            <div class="cs-task flex items-center gap-2.5 text-[11px] text-navy-300"><span class="cs-box w-4 h-4 rounded border border-navy-600 flex items-center justify-center flex-shrink-0"></span> Amperaje del motor</div>
            <div class="cs-task flex items-center gap-2.5 text-[11px] text-navy-300"><span class="cs-box w-4 h-4 rounded border border-navy-600 flex items-center justify-center flex-shrink-0"></span> Limpieza de condensador</div>
          </div>
        </div>
      </div>

      <!-- HUD 4: Estado OK -->
      <div class="cs-hud absolute z-30" data-hud="3" style="bottom: 24%; right: 13%;">
        <div class="rounded-2xl bg-navy-900/90 backdrop-blur-xl border border-cyan-500/30 shadow-2xl shadow-cyan-500/10 p-4 w-52">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-cyan-500/15 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white">Registro guardado</p>
              <p class="font-mono text-[10px] text-cyan-400">Historial · 12 registros</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .cs-hud { opacity: 0; transform: translateY(20px) scale(0.92); transition: opacity .5s cubic-bezier(0.16,1,0.3,1), transform .5s cubic-bezier(0.16,1,0.3,1); }
  .cs-hud.show { opacity: 1; transform: translateY(0) scale(1); }

  .cs-alarm { animation: cs-alarm 1.2s ease-out infinite; }
  @keyframes cs-alarm { 0%{transform:scale(1);opacity:.8;} 100%{transform:scale(1.5);opacity:0;} }

  .cs-box.done { background: #00bcd4; border-color: #00bcd4; }

  @media (max-width: 1023px) {
    #cs-track { height: auto; }
    #cs-track .sticky { position: relative; height: auto; padding: 6rem 0; flex-direction: column; gap: 2rem; }
    .cs-hud { position: relative !important; opacity: 1; transform: none; top: auto!important; left: auto!important; right: auto!important; bottom: auto!important; margin: 0 auto; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cs-hud { opacity: 1; transform: none; }
    .cs-alarm { animation: none; }
  }
</style>

<script>
  function initCompresorScroll() {
    const track = document.getElementById('cs-track');
    const comp = document.getElementById('cs-compressor');
    const glow = document.getElementById('cs-glow');
    if (!track || !comp || track.dataset.init) return;
    track.dataset.init = '1';

    const huds = Array.from(document.querySelectorAll('.cs-hud'));
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) { huds.forEach(h => h.classList.add('show')); return; }

    const counts = Array.from(document.querySelectorAll('.cs-count'));
    const countDone = new Set();

    function animateCount(el) {
      const to = parseFloat(el.dataset.to);
      const dec = parseInt(el.dataset.dec || '0', 10);
      const dur = 900, start = performance.now();
      function tick(now) {
        const p = Math.min((now - start) / dur, 1);
        const val = (1 - Math.pow(1 - p, 3)) * to;
        el.textContent = dec ? val.toFixed(dec) : Math.floor(val);
        if (p < 1) requestAnimationFrame(tick);
        else el.textContent = dec ? to.toFixed(dec) : to;
      }
      requestAnimationFrame(tick);
    }

    function onScroll() {
      const rect = track.getBoundingClientRect();
      const vh = window.innerHeight;
      const totalScroll = track.offsetHeight - vh;
      const progress = Math.min(Math.max(-rect.top / totalScroll, 0), 1);

      // rota el compresor con el scroll
      comp.style.transform = `rotateY(${progress * 360}deg) rotateX(8deg)`;

      // glow late con el progreso
      if (glow) glow.style.opacity = String(0.6 + Math.sin(progress * Math.PI) * 0.4);

      // muestra HUDs por turnos según progreso
      huds.forEach((hud, i) => {
        const trigger = 0.12 + i * 0.2;
        const show = progress >= trigger;
        hud.classList.toggle('show', show);
        if (show) {
          if (i === 0 && !countDone.has(0)) { countDone.add(0); counts.forEach(animateCount); }
          if (i === 2 && !countDone.has(2)) {
            countDone.add(2);
            const boxes = hud.querySelectorAll('.cs-box');
            boxes.forEach((b, bi) => setTimeout(() => {
              b.classList.add('done');
              b.innerHTML = '<svg class="w-3 h-3 text-navy-950" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
            }, bi * 400));
          }
        } else if (i === 2) {
          countDone.delete(2);
          hud.querySelectorAll('.cs-box').forEach(b => { b.classList.remove('done'); b.innerHTML = ''; });
        } else if (i === 0) {
          countDone.delete(0);
        }
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
  initCompresorScroll();
  document.addEventListener('astro:page-load', initCompresorScroll);
</script>