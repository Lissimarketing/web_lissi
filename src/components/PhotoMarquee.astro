---
// src/components/PhotoMarquee.astro
// Añadimos metadatos que simulan la captura de la app en terreno
const fotos = [
  { src: "/foto1.png", label: "Mantención de chiller", meta: "Climatización", tecnico: "J. Ruiz", status: "Sincronizado" },
  { src: "/foto2.png", label: "Instalación split", meta: "Aire acondicionado", tecnico: "M. Silva", status: "Con firma" },
  { src: "/foto3.png", label: "Inspección en terreno", meta: "Servicio técnico", tecnico: "P. Gómez", status: "Sincronizado" },
  { src: "/foto4.png", label: "Cámara de frío", meta: "Refrigeración", tecnico: "C. Tapia", status: "Offline guardado" },
  { src: "/foto5.png", label: "Diagnóstico de equipo", meta: "Mantención", tecnico: "R. Soto", status: "Sincronizado" },
  { src: "/foto6.png", label: "Sala de máquinas", meta: "Operación", tecnico: "L. Vega", status: "Con firma" },
  { src: "/foto7.png", label: "Trabajo en altura", meta: "Instalación", tecnico: "D. Reyes", status: "Sincronizado" },
  { src: "/foto8.png", label: "Registro digital", meta: "App en terreno", tecnico: "A. Castro", status: "Sincronizado" },
];
const filaA = [...fotos, ...fotos];
const filaB = [...[...fotos].reverse(), ...[...fotos].reverse()];
---
<section class="relative bg-[#0A0F1C] pt-16 md:pt-24 pb-24 md:pb-32 overflow-hidden border-t border-slate-800/50">

  <div class="absolute inset-0 pointer-events-none opacity-[0.15]"
       style="background-image: linear-gradient(rgba(0,229,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(0,229,255,0.3) 1px, transparent 1px); background-size: 64px 64px; mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 30%, transparent 100%);">
  </div>
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] bg-cyan-500/5 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div class="max-w-2xl">
        <div class="flex items-center gap-2 mb-5">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-emerald-400">Stream de Operaciones</p>
        </div>
        <h2 class="font-display text-4xl md:text-[2.75rem] font-extrabold text-white tracking-tight text-balance leading-tight">
          La realidad del terreno,<br>
          <span class="text-slate-400 font-light">ahora visible en tu oficina.</span>
        </h2>
      </div>
      
      <div class="text-left md:text-right">
        <p class="font-display text-3xl font-bold text-white">+50 mil</p>
        <p class="text-sm font-medium text-slate-400 uppercase tracking-widest mt-1">Órdenes Trazadas</p>
        <p class="text-xs text-slate-500 mt-1">De Arica a Punta Arenas.</p>
      </div>
    </div>

    <div class="space-y-6" style="-webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);">
      
      <div class="marquee-row flex gap-6 w-max" data-dir="left">
        {filaA.map((f) => (
          <figure class="marquee-card group relative w-[240px] md:w-[300px] aspect-[4/5] flex-shrink-0 rounded-2xl overflow-hidden bg-slate-900 border border-slate-700/50 shadow-lg">
            <img src={f.src} alt={f.label} loading="lazy" class="w-full h-full object-cover saturate-[0.3] opacity-80 group-hover:opacity-100 group-hover:saturate-100 group-hover:scale-105 transition-all duration-700 ease-out" />
            
            <div class="absolute top-3 right-3 px-2.5 py-1 bg-[#0A0F1C]/80 backdrop-blur-md border border-slate-600/50 rounded-md flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-[-10px] group-hover:translate-y-0">
              <svg class="w-3 h-3 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <span class="text-[10px] font-bold text-slate-200 uppercase tracking-wider">{f.status}</span>
            </div>

            <div class="absolute inset-0 bg-gradient-to-t from-[#0A0F1C] via-[#0A0F1C]/40 to-transparent"></div>
            
            <figcaption class="absolute bottom-0 inset-x-0 p-5 transform transition-transform duration-300">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
                  <span class="font-mono text-[10px] uppercase tracking-wider text-cyan-400">{f.meta}</span>
                </div>
                <span class="font-mono text-[10px] text-slate-500">{f.tecnico}</span>
              </div>
              <p class="text-base font-bold text-white leading-tight mb-1">{f.label}</p>
            </figcaption>
          </figure>
        ))}
      </div>

      <div class="marquee-row flex gap-6 w-max" data-dir="right">
        {filaB.map((f) => (
          <figure class="marquee-card group relative w-[240px] md:w-[300px] aspect-[4/5] flex-shrink-0 rounded-2xl overflow-hidden bg-slate-900 border border-slate-700/50 shadow-lg">
            <img src={f.src} alt={f.label} loading="lazy" class="w-full h-full object-cover saturate-[0.3] opacity-80 group-hover:opacity-100 group-hover:saturate-100 group-hover:scale-105 transition-all duration-700 ease-out" />
            
            <div class="absolute top-3 right-3 px-2.5 py-1 bg-[#0A0F1C]/80 backdrop-blur-md border border-slate-600/50 rounded-md flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-[-10px] group-hover:translate-y-0">
              <svg class="w-3 h-3 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <span class="text-[10px] font-bold text-slate-200 uppercase tracking-wider">{f.status}</span>
            </div>

            <div class="absolute inset-0 bg-gradient-to-t from-[#0A0F1C] via-[#0A0F1C]/40 to-transparent"></div>
            
            <figcaption class="absolute bottom-0 inset-x-0 p-5 transform transition-transform duration-300">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
                  <span class="font-mono text-[10px] uppercase tracking-wider text-cyan-400">{f.meta}</span>
                </div>
                <span class="font-mono text-[10px] text-slate-500">{f.tecnico}</span>
              </div>
              <p class="text-base font-bold text-white leading-tight mb-1">{f.label}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Mismos keyframes, pero más fluidos y lentos para dar sensación de volumen */
  .marquee-row { animation: scroll-left 70s linear infinite; }
  .marquee-row[data-dir="right"] { animation: scroll-right 70s linear infinite; }
  @keyframes scroll-left { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @keyframes scroll-right { from { transform: translateX(-50%); } to { transform: translateX(0); } }
  .marquee-row:hover { animation-play-state: paused; }
  @media (prefers-reduced-motion: reduce) { .marquee-row { animation: none; } }
</style>