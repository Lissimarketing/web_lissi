---
// src/components/Ecosystem.astro
---
<section class="py-24 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center mb-20">
      <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-4 tracking-tight">
        Un ecosistema, <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-700 via-blue-600 to-cyan-500">dos realidades.</span>
      </h2>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto font-medium">
        Conectamos la oficina con el terreno en tiempo real. Sin cables, sin papeles, sin dramas.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <div class="bg-slate-50 rounded-[2.5rem] p-8 md:p-12 border border-slate-200 shadow-sm relative overflow-hidden group hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500">
        
        <div class="relative z-10 mb-12">
          <span class="inline-flex items-center gap-2 px-3 py-1 bg-white border border-slate-200 text-slate-600 text-xs font-bold rounded-full uppercase tracking-wider mb-6 shadow-sm">
            <span class="w-2 h-2 rounded-full bg-blue-600"></span>
            Para la Oficina
          </span>
          <h3 class="text-3xl font-bold text-slate-900 mb-3">Control Centralizado</h3>
          <p class="text-slate-500 text-base leading-relaxed">
            Tu torre de control. Gestiona OTs, clientes y el historial completo de tus activos desde cualquier navegador web.
          </p>
        </div>
        
        <div class="relative rounded-t-xl bg-white border border-slate-200 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.1)] h-72 translate-y-6 group-hover:translate-y-4 transition-transform duration-500 overflow-hidden flex">
             
             <div class="w-16 bg-slate-900 flex flex-col items-center py-4 gap-4 border-r border-slate-800">
                <div class="w-8 h-8 rounded-lg bg-blue-600 mb-4"></div>
                <div class="w-8 h-8 rounded-lg bg-slate-800/50"></div>
                <div class="w-8 h-8 rounded-lg bg-slate-800/50"></div>
                <div class="w-8 h-8 rounded-lg bg-slate-800/50"></div>
             </div>

             <div class="flex-1 bg-slate-50 flex flex-col">
                <div class="h-12 bg-white border-b border-slate-200 flex items-center justify-between px-6">
                    <div class="h-3 w-24 bg-slate-200 rounded-full"></div>
                    <div class="flex gap-2">
                        <div class="h-8 w-24 bg-blue-600 rounded-lg shadow-sm shadow-blue-200"></div>
                    </div>
                </div>

                <div class="p-6">
                    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                        <div class="h-10 border-b border-slate-100 bg-slate-50/50 flex items-center px-4 gap-4">
                            <div class="w-4 h-4 rounded border border-slate-300"></div>
                            <div class="h-2 w-20 bg-slate-200 rounded"></div>
                            <div class="h-2 w-32 bg-slate-200 rounded"></div>
                            <div class="h-2 w-16 bg-slate-200 rounded ml-auto"></div>
                        </div>
                        <div class="h-12 border-b border-slate-50 flex items-center px-4 gap-4 hover:bg-blue-50/50 transition-colors">
                            <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center text-[10px] font-bold">JD</div>
                            <div class="flex-1">
                                <div class="h-2.5 w-32 bg-slate-800 rounded mb-1.5"></div>
                                <div class="h-2 w-20 bg-slate-300 rounded"></div>
                            </div>
                            <div class="px-2 py-1 rounded-md bg-green-100 text-green-700 text-[10px] font-bold">AL DÍA</div>
                        </div>
                        <div class="h-12 border-b border-slate-50 flex items-center px-4 gap-4 hover:bg-blue-50/50 transition-colors">
                            <div class="w-8 h-8 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center text-[10px] font-bold">MT</div>
                            <div class="flex-1">
                                <div class="h-2.5 w-24 bg-slate-800 rounded mb-1.5"></div>
                                <div class="h-2 w-16 bg-slate-300 rounded"></div>
                            </div>
                            <div class="px-2 py-1 rounded-md bg-blue-100 text-blue-700 text-[10px] font-bold">EN RUTA</div>
                        </div>
                        <div class="h-12 flex items-center px-4 gap-4 hover:bg-blue-50/50 transition-colors">
                            <div class="w-8 h-8 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center text-[10px] font-bold">AS</div>
                            <div class="flex-1">
                                <div class="h-2.5 w-28 bg-slate-800 rounded mb-1.5"></div>
                                <div class="h-2 w-24 bg-slate-300 rounded"></div>
                            </div>
                            <div class="px-2 py-1 rounded-md bg-slate-100 text-slate-500 text-[10px] font-bold">PENDIENTE</div>
                        </div>
                    </div>
                </div>
             </div>
        </div>
      </div>

      <div class="bg-[#0f172a] rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden group hover:shadow-blue-500/20 transition-all duration-500">
         <div class="absolute top-0 right-0 w-80 h-80 bg-blue-600/20 rounded-full blur-[100px] -mr-20 -mt-20 pointer-events-none"></div>
        
        <div class="relative z-10 mb-12">
          <span class="inline-flex items-center gap-2 px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-300 text-xs font-bold rounded-full uppercase tracking-wider mb-6">
            <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
            Para el Técnico
          </span>
          <h3 class="text-3xl font-bold text-white mb-3">App Móvil Nativa</h3>
          <p class="text-slate-400 text-base leading-relaxed">
            La herramienta de bolsillo definitiva. Funciona offline, escanea códigos QR, permite subir fotos y firma digital en pantalla.
          </p>
        </div>

        <div class="relative mx-auto w-64 rounded-t-[2.5rem] bg-slate-900 border-[6px] border-slate-800 shadow-2xl h-72 translate-y-6 group-hover:translate-y-4 transition-transform duration-500 overflow-hidden flex flex-col">
             <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-5 bg-slate-800 rounded-b-xl z-20"></div>
             
             <div class="flex-1 bg-slate-950 p-5 pt-10 flex flex-col">
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <div class="h-2 w-16 bg-slate-700 rounded mb-1"></div>
                        <div class="h-3 w-24 bg-white rounded"></div>
                    </div>
                    <div class="w-8 h-8 rounded-full bg-blue-600 border-2 border-slate-800"></div>
                </div>

                <div class="w-full h-12 bg-gradient-to-r from-blue-600 to-cyan-500 rounded-xl flex items-center justify-center gap-2 mb-6 shadow-lg shadow-blue-900/50">
                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" /></svg>
                    <span class="text-xs font-bold text-white">Escanear Equipo</span>
                </div>

                <div class="bg-slate-900 rounded-xl p-3 border border-slate-800">
                    <div class="flex justify-between items-start mb-2">
                        <span class="text-[10px] font-bold text-orange-400 bg-orange-400/10 px-2 py-0.5 rounded">URGENTE</span>
                        <span class="text-[10px] text-slate-500">10:30 AM</span>
                    </div>
                    <div class="h-3 w-3/4 bg-slate-200 rounded mb-2"></div>
                    <div class="h-2 w-1/2 bg-slate-600 rounded"></div>
                </div>
             </div>
             
             <div class="h-12 bg-slate-900 border-t border-slate-800 flex justify-around items-center px-2">
                 <div class="w-6 h-6 rounded bg-blue-500"></div>
                 <div class="w-6 h-6 rounded bg-slate-800"></div>
                 <div class="w-6 h-6 rounded bg-slate-800"></div>
             </div>
        </div>
      </div>

    </div>
  </div>
</section>