---
// src/components/LegalLayout.astro
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';

interface Props {
  titulo: string;
  actualizado: string;
  descripcion?: string;
}
const { titulo, actualizado, descripcion } = Astro.props;
---
<Layout title={`${titulo} | Lissi`} description={descripcion}>
  <Navbar />

  <main class="relative bg-[#0A0F1C] min-h-screen pt-28 pb-24 font-sans overflow-hidden">

    <div class="absolute top-0 left-0 w-full h-[400px] bg-gradient-to-b from-cyan-900/10 to-transparent pointer-events-none"></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

      <a href="/" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-cyan-400 transition-colors group mb-8">
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Volver al inicio
      </a>

      <header class="mb-12 pb-8 border-b border-slate-800">
        <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-black text-white tracking-tight mb-4">{titulo}</h1>
        <p class="font-mono text-xs text-slate-500">Última actualización: {actualizado}</p>
      </header>

      <div class="lg:grid lg:grid-cols-[1fr_3fr] lg:gap-12">

        <!-- Índice lateral (se llena solo desde los h2) -->
        <aside class="hidden lg:block">
          <nav id="toc" class="sticky top-28 space-y-2"></nav>
        </aside>

        <!-- Contenido -->
        <article id="legal-content" class="legal-prose max-w-none">
          <slot />
        </article>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  .legal-prose { color: #cbd5e1; font-size: 0.95rem; line-height: 1.75; }
  .legal-prose h2 {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    color: #fff; font-size: 1.4rem; font-weight: 800; letter-spacing: -0.01em;
    margin-top: 2.75rem; margin-bottom: 1rem; scroll-margin-top: 7rem;
    padding-top: 1.5rem; border-top: 1px solid rgba(30,41,59,0.6);
  }
  .legal-prose h2:first-of-type { border-top: none; padding-top: 0; margin-top: 0; }
  .legal-prose h3 { color: #f1f5f9; font-size: 1.05rem; font-weight: 700; margin-top: 1.75rem; margin-bottom: 0.6rem; }
  .legal-prose p { margin-bottom: 1rem; }
  .legal-prose ul { margin: 0.5rem 0 1.25rem; padding-left: 1.25rem; list-style: none; }
  .legal-prose ul li { position: relative; margin-bottom: 0.6rem; padding-left: 1rem; }
  .legal-prose ul li::before { content: "→"; position: absolute; left: 0; color: #06b6d4; }
  .legal-prose strong { color: #f1f5f9; font-weight: 600; }
  .legal-prose a { color: #22d3ee; text-decoration: underline; text-underline-offset: 2px; }
  .legal-prose a:hover { color: #67e8f9; }
  .legal-prose .lead { font-size: 1.05rem; color: #94a3b8; margin-bottom: 2rem; }
  .legal-prose .callout {
    background: rgba(245,158,11,0.05); border: 1px solid rgba(245,158,11,0.2);
    border-radius: 0.75rem; padding: 1rem 1.25rem; margin: 1.5rem 0;
    font-size: 0.85rem; color: rgba(253,230,138,0.85);
  }
  .legal-prose table { width: 100%; border-collapse: collapse; margin: 1.25rem 0; font-size: 0.85rem; }
  .legal-prose th, .legal-prose td { text-align: left; padding: 0.65rem 0.75rem; border: 1px solid rgba(30,41,59,0.8); }
  .legal-prose th { background: rgba(15,23,42,0.6); color: #e2e8f0; font-weight: 600; font-family: var(--font-mono, monospace); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .toc-link { display: block; font-size: 0.8rem; color: #64748b; padding: 0.35rem 0; border-left: 2px solid transparent; padding-left: 0.75rem; transition: all 0.15s; }
  .toc-link:hover, .toc-link.active { color: #22d3ee; border-left-color: #06b6d4; }
</style>

<script is:inline>
  function initTOC() {
    const content = document.getElementById('legal-content');
    const toc = document.getElementById('toc');
    if (!content || !toc || toc.dataset.init) return;
    toc.dataset.init = '1';
    const headings = content.querySelectorAll('h2');
    headings.forEach((h, i) => {
      const id = 'sec-' + i;
      h.id = id;
      const link = document.createElement('a');
      link.href = '#' + id;
      link.className = 'toc-link';
      link.textContent = h.textContent;
      toc.appendChild(link);
    });
  }
  initTOC();
  document.addEventListener('astro:page-load', initTOC);
</script>