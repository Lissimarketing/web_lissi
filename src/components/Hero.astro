---
// src/components/Hero.astro
---
<section class="relative pt-32 pb-8 lg:pt-48 lg:pb-12 overflow-hidden bg-white selection:bg-blue-600 selection:text-white">
  
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none opacity-40">
    <div class="absolute inset-0" style="background-image: radial-gradient(#e2e8f0 1.5px, transparent 1.5px); background-size: 40px 40px;"></div>
    <div class="absolute inset-0" style="background-image: linear-gradient(#f1f5f9 1px, transparent 1px), linear-gradient(90deg, #f1f5f9 1px, transparent 1px); background-size: 200px 200px;"></div>
    <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[120px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center max-w-5xl mx-auto">
      
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-900 text-white shadow-xl mb-8 hover:scale-105 transition-transform cursor-default">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-400"></span>
        </span>
        <span class="text-[10px] font-bold tracking-widest uppercase">Estándar Industrial HVAC-R 2026</span>
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-slate-900 tracking-tighter leading-[1.05] mb-8 drop-shadow-sm">
        Inteligencia Real Para<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-700 via-blue-600 to-cyan-500">
          Operaciones HVAC-R.
        </span>
      </h1>

      <p class="text-xl md:text-2xl text-slate-500 mb-12 leading-relaxed max-w-3xl mx-auto font-medium text-balance">
        Lissi es el cerebro operativo diseñado para empresas de climatización. Control de activos críticos, parámetros de refrigeración y rentabilidad automatizada.
      </p>

      <div class="flex flex-col sm:flex-row gap-5 justify-center items-center mb-10">
        <a 
          href="https://wa.me/56963192849?text=Hola,%20vi%20la%20web%20y%20quiero%20hablar%20con%20un%20ingeniero." 
          target="_blank"
          class="group relative px-8 py-4 bg-blue-600 text-white rounded-2xl font-bold text-lg shadow-2xl shadow-blue-500/30 hover:bg-blue-700 transition-all hover:-translate-y-1 flex items-center gap-3"
        >
          <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Hablemos por WhatsApp
        </a>

        <button 
          onclick="window.openCalendly()"
          class="px-8 py-4 bg-white border-2 border-slate-200 text-slate-900 rounded-2xl font-bold text-lg hover:border-blue-600 transition-all hover:-translate-y-1 cursor-pointer"
        >
          Agendar Reunión
        </button>
      </div>

      <div class="mt-8 mb-10 flex flex-col items-center animate-bounce-slow text-slate-400">
        <p class="text-[10px] font-black uppercase tracking-[0.3em] mb-3">
          Mira Lissi en acción
        </p>
        <span class="text-3xl filter drop-shadow-xl cursor-default">👇</span>
      </div>

      <div class="relative mx-auto max-w-6xl perspective-1000">
          <div class="absolute -inset-10 bg-blue-500/5 rounded-[3rem] blur-3xl"></div>
          <div class="relative rounded-[2rem] bg-slate-900/5 p-2 ring-1 ring-slate-900/10 backdrop-blur-3xl shadow-2xl">
            <div class="rounded-[1.5rem] overflow-hidden bg-slate-900 aspect-video relative group">
                <iframe 
                  src="https://www.youtube.com/embed/325wASGfCJk?autoplay=1&mute=1&rel=0&modestbranding=1" 
                  title="Demo Lissi"
                  class="w-full h-full"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                  allowfullscreen
                ></iframe>
            </div>
          </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(12px); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 2s infinite ease-in-out;
  }
</style>