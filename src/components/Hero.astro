---
// src/components/Hero.astro
const SIGNUP_URL = "https://lissi-web-git-redesingv4-lissi-team.vercel.app/register";
---
<section class="relative bg-[#0A0F1C] overflow-hidden pt-24 md:pt-28 pb-20 md:pb-28">
  <div class="absolute inset-0 pointer-events-none opacity-20"
       style="background-image: linear-gradient(rgba(0,229,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(0,229,255,0.3) 1px, transparent 1px); background-size: 64px 64px; mask-image: radial-gradient(ellipse 90% 80% at 50% 30%, black 40%, transparent 100%);">
  </div>

  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-cyan-500/10 rounded-full blur-[160px] pointer-events-none animate-pulse-slow mix-blend-screen z-0"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <div class="relative z-10">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-cyan-500/30 bg-cyan-500/10 backdrop-blur-sm mb-8 shadow-[0_0_15px_rgba(0,229,255,0.1)]">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-400"></span>
          </span>
          <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-cyan-300">EL ESTÁNDAR HVAC-R EN LATAM</span>
        </div>

        <h1 class="font-display text-5xl md:text-6xl lg:text-[4.5rem] font-extrabold text-white tracking-tight leading-[1.05] mb-6 flex flex-col items-start">
          <span>Del terreno al Reporte Final,</span>
          <span class="inline-grid overflow-hidden pr-2 pb-2 mt-1">
            <span class="word-rotate col-start-1 row-start-1 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-0 opacity-100 text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 via-cyan-400 to-blue-500 drop-shadow-lg">sin papeles.</span>
            <span class="word-rotate col-start-1 row-start-1 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-full opacity-0 text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 via-cyan-400 to-blue-500 drop-shadow-lg">sin retrasos.</span>
            <span class="word-rotate col-start-1 row-start-1 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-full opacity-0 text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 via-cyan-400 to-blue-500 drop-shadow-lg">sin doble trabajo.</span>
            <span class="word-rotate col-start-1 row-start-1 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-full opacity-0 text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 via-cyan-400 to-blue-500 drop-shadow-lg">sin garantías perdidas.</span>
          </span>
        </h1>

        <p class="text-lg md:text-xl text-slate-300 leading-relaxed mb-10 max-w-lg font-light">
          Deja de perder dinero por informes atrasados y desorden en terreno. <strong class="text-white font-medium">Lissi centraliza tu operación:</strong> desde la sala de máquinas sin señal, hasta el reporte PDF automático que recibe tu cliente en segundos.
        </p>

        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 mb-5">
          
          <a href={SIGNUP_URL} class="group relative inline-flex items-center justify-center gap-3 px-8 py-4 bg-cyan-500 text-[#0A0F1C] rounded-xl font-bold text-lg overflow-hidden transition-all duration-200 border border-cyan-400 shadow-[inset_0_1px_0_rgba(255,255,255,0.6),0_10px_20px_-10px_rgba(0,229,255,0.6)] hover:bg-cyan-400 hover:scale-[1.02] active:scale-[0.98]">
            <span class="relative z-10 flex items-center gap-2">
              Prueba Lissi Gratis
              <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </span>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/40 to-transparent opacity-0 group-hover:opacity-100 translate-x-[-100%] group-hover:animate-shine z-0"></div>
          </a>

          <a href="/demo" class="group relative inline-flex items-center justify-center gap-2 px-8 py-4 bg-cyan-500/5 text-cyan-400 rounded-xl font-bold text-lg border border-cyan-500/20 transition-all duration-300 hover:bg-cyan-500/10 hover:border-cyan-500/30">
            <span class="absolute inset-x-0 -top-px h-px w-3/4 mx-auto bg-gradient-to-r from-transparent via-cyan-400 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
            
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            Agendar Demo
            
            <span class="absolute inset-x-0 -bottom-px h-px w-3/4 mx-auto bg-gradient-to-r from-transparent via-cyan-500 to-transparent opacity-30 group-hover:opacity-100 transition-opacity duration-500"></span>
          </a>
        </div>

        <div class="flex items-center gap-4 text-[11px] font-mono uppercase tracking-wider text-slate-500 mb-10 pl-1">
           <span class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg> 21 días gratis</span>
           <span class="w-1 h-1 rounded-full bg-slate-700"></span>
           <span class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg> Sin tarjeta</span>
        </div>

        <div class="flex items-center gap-4 pt-6 border-t border-slate-800/60">
          <div class="flex -space-x-3">
            <div class="w-10 h-10 rounded-full border-2 border-[#0A0F1C] bg-white overflow-hidden shadow-md shrink-0 relative z-0">
              <img src="/LOG1.png" alt="Cliente Lissi" class="w-full h-full object-cover" />
            </div>
            <div class="w-10 h-10 rounded-full border-2 border-[#0A0F1C] bg-white overflow-hidden shadow-md shrink-0 relative z-10">
              <img src="/LOG2.png" alt="Cliente Lissi" class="w-full h-full object-cover" />
            </div>
            <div class="w-10 h-10 rounded-full border-2 border-[#0A0F1C] bg-cyan-900 flex items-center justify-center text-[11px] font-bold text-cyan-400 shadow-md relative z-20">
              +100
            </div>
          </div>
          <p class="text-sm text-slate-400 leading-tight font-light">
            Empresas HVAC-R ya confían<br/>su operación a Lissi.
          </p>
        </div>
      </div>

      <div class="relative w-full h-[550px] perspective-1000 mt-12 lg:mt-0" data-reveal>

        <div class="absolute top-4 right-0 w-[95%] lg:w-[90%] z-10 rounded-[2rem] bg-[#0A0F1C]/80 backdrop-blur-2xl border border-slate-700/60 shadow-[0_30px_60px_rgba(0,0,0,0.5)] overflow-hidden transform-gpu rotate-y-[-4deg] rotate-x-[2deg] transition-transform duration-700 hover:rotate-y-0 hover:rotate-x-0">

          <div class="flex items-center justify-between px-6 py-5 border-b border-slate-800/80 bg-slate-900/50">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl bg-cyan-500/10 flex items-center justify-center border border-cyan-500/20 shadow-inner">
                <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
              </div>
              <div>
                <span class="block font-mono text-sm font-bold text-white tracking-wide">CHILLER-04-A</span>
                <span class="block text-[11px] text-slate-400 font-light mt-0.5">Edificio Las Condes Central</span>
              </div>
            </div>

            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20">
               <svg class="w-3 h-3 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
               <span class="text-[9px] font-mono uppercase tracking-widest text-emerald-400">Visita cerrada</span>
            </div>
          </div>

          <div class="p-6 grid grid-cols-2 gap-4">
            <div class="rounded-2xl bg-slate-900/30 border border-slate-800/50 p-5">
              <p class="text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-2">Presión Alta</p>
              <div class="flex items-end gap-1.5">
                <p class="font-display text-[2.5rem] font-black text-white leading-none">365</p>
                <span class="text-sm font-bold text-cyan-500 mb-1">psi</span>
              </div>
            </div>
            <div class="rounded-2xl bg-slate-900/30 border border-slate-800/50 p-5">
              <p class="text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-2">Sobrecalent.</p>
              <div class="flex items-end gap-1.5">
                <p class="font-display text-[2.5rem] font-black text-white leading-none">8.2</p>
                <span class="text-sm font-bold text-cyan-500 mb-1">°C</span>
              </div>
            </div>
          </div>

          <div class="px-6 -mt-2 mb-2">
            <div class="flex items-center gap-2 text-[10px] font-mono text-slate-500">
              <svg class="w-3.5 h-3.5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              <span>Registrado por J. Pérez · Hoy 14:30</span>
            </div>
          </div>

          <div class="px-6 pb-8">
             <div class="rounded-2xl bg-slate-900/30 border border-slate-800/50 p-5">
               <p class="text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-5">Últimas Intervenciones</p>
               <div class="space-y-5">

                 <div class="flex items-start gap-4 relative">
                   <div class="absolute top-6 left-[15px] bottom-[-20px] w-px bg-slate-800"></div>
                   <div class="w-8 h-8 rounded-full bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center flex-shrink-0 relative z-10">
                     <span class="w-2 h-2 rounded-full bg-cyan-400 shadow-[0_0_8px_rgba(0,229,255,0.8)]"></span>
                   </div>
                   <div class="mt-1.5">
                     <p class="text-sm font-bold text-white leading-none">Mantención Preventiva</p>
                     <p class="text-[11px] text-slate-400 mt-1.5 font-light">Firma técnica registrada · Hoy 14:30</p>
                   </div>
                 </div>

                 <div class="flex items-start gap-4 relative opacity-60">
                   <div class="w-8 h-8 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center flex-shrink-0 relative z-10">
                     <span class="w-2 h-2 rounded-full bg-slate-500"></span>
                   </div>
                   <div class="mt-1.5">
                     <p class="text-sm font-bold text-white leading-none">Cambio Filtros HEPA</p>
                     <p class="text-[11px] text-slate-400 mt-1.5 font-light">Hace 3 meses</p>
                   </div>
                 </div>

               </div>
             </div>
          </div>

          <div class="absolute bottom-5 right-5 z-20 flex items-center gap-3 px-4 py-2.5 rounded-xl bg-slate-900/90 backdrop-blur-md border border-cyan-500/30 shadow-[0_15px_30px_rgba(0,0,0,0.6)] animate-float-delayed">
             <div class="w-6 h-6 rounded-md bg-cyan-500/20 flex items-center justify-center border border-cyan-500/40 shrink-0">
               <svg class="w-3.5 h-3.5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
             </div>
             <div class="flex flex-col">
               <span class="text-[9px] font-mono uppercase tracking-widest text-cyan-400 leading-none mb-1">Informe PDF</span>
               <p class="text-xs font-semibold text-white leading-none">Enviado al cliente</p>
             </div>
          </div>

        </div>

      </div>
    </div>
  </div>
</section>

<style>
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.2; transform: translateX(-50%) scale(1); }
    50% { opacity: 0.4; transform: translateX(-50%) scale(1.05); }
  }
  @keyframes shine {
    100% { transform: translateX(100%); }
  }
  @keyframes float-delayed {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }
  .animate-pulse-slow { animation: pulse-slow 8s ease-in-out infinite; }
  .animate-shine { animation: shine 1s ease-out forwards; }
  .animate-float-delayed { animation: float-delayed 6s ease-in-out infinite 0.5s; }

  .perspective-1000 { perspective: 1000px; }

  @media (prefers-reduced-motion: reduce) {
    .animate-pulse-slow, .animate-float-delayed { animation: none; }
  }
</style>

<script>
  function initWordRotator() {
    const words = document.querySelectorAll('.word-rotate');
    if (words.length === 0) return;
    
    let currentIndex = 0;

    // Limpiador de seguridad: evita que se duplique la animación si Astro recarga vistas
    if (window.rotatorInterval) clearInterval(window.rotatorInterval);

    window.rotatorInterval = setInterval(() => {
      const current = words[currentIndex];
      currentIndex = (currentIndex + 1) % words.length;
      const next = words[currentIndex];

      // 1. La palabra actual sale hacia arriba
      current.classList.remove('translate-y-0', 'opacity-100');
      current.classList.add('-translate-y-full', 'opacity-0');

      // 2. La nueva palabra entra desde abajo
      next.classList.remove('translate-y-full', '-translate-y-full', 'opacity-0');
      next.classList.add('translate-y-0', 'opacity-100');

      // 3. Resetear la palabra que ya salió para que esté lista abajo en el próximo ciclo
      setTimeout(() => {
        current.classList.remove('-translate-y-full');
        current.classList.add('translate-y-full');
      }, 500); 

    }, 2500); // Rota cada 2.5 segundos
  }

  initWordRotator();
  document.addEventListener('astro:page-load', initWordRotator);
</script>